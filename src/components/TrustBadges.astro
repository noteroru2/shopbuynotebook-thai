---
const items = [
  { title: 'ประเมินฟรี', desc: 'ส่งรูป/สเปก ประเมินเบื้องต้นให้ทันที', tone: 'emerald', icon: '💬' },
  { title: 'จ่ายเงินทันที', desc: 'ตกลงราคาแล้วจ่ายเงินสด/โอนทันที', tone: 'amber', icon: '💸' },
  { title: 'รับซื้อทุกยี่ห้อ', desc: 'Windows, MacBook, Gaming Notebook', tone: 'sky', icon: '💻' },
  { title: 'รับซื้อเครื่องดีและเครื่องเสีย', desc: 'เปิดไม่ติด จอแตก แบตเสื่อม ฯลฯ', tone: 'rose', icon: '🧰' },
  { title: 'ขั้นตอนโปร่งใส', desc: 'แจ้งเงื่อนไขชัด ไม่กดราคา', tone: 'violet', icon: '✅' },
];
---

<section class="mx-auto w-full max-w-6xl px-4 pt-10">
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
    {items.map((it) => (
      <div
        class:list={[
          'group rounded-3xl border bg-white/70 p-5 shadow-sm backdrop-blur transition-all hover:-translate-y-0.5 hover:shadow-md',
          it.tone === 'emerald' && 'border-emerald-200 hover:border-emerald-300',
          it.tone === 'sky' && 'border-sky-200 hover:border-sky-300',
          it.tone === 'amber' && 'border-amber-200 hover:border-amber-300',
          it.tone === 'rose' && 'border-rose-200 hover:border-rose-300',
          it.tone === 'violet' && 'border-violet-200 hover:border-violet-300',
        ]}
      >
        <div class="flex items-center gap-2">
          <span
            class:list={[
              'inline-flex h-10 w-10 items-center justify-center rounded-2xl border text-sm font-extrabold',
              it.tone === 'emerald' && 'border-emerald-200 bg-emerald-50 text-emerald-700',
              it.tone === 'sky' && 'border-sky-200 bg-sky-50 text-sky-700',
              it.tone === 'amber' && 'border-amber-200 bg-amber-50 text-amber-700',
              it.tone === 'rose' && 'border-rose-200 bg-rose-50 text-rose-700',
              it.tone === 'violet' && 'border-violet-200 bg-violet-50 text-violet-700',
            ]}
            aria-hidden="true"
          >
            {it.icon}
          </span>
          <p class="text-sm font-semibold text-slate-900">{it.title}</p>
        </div>
        <p class="mt-2 text-sm leading-relaxed text-slate-600">{it.desc}</p>
      </div>
    ))}
  </div>
</section>

