---
import type { PartnerCategory } from '../data/partner-sites';
import {
  filterPartners,
  getFooterPartners,
  partnerCategoryThai,
  partnerFullGroups,
  partnerSites,
} from '../data/partner-sites';

interface Props {
  variant?: 'footer' | 'section' | 'compact' | 'full';
  limit?: number;
  categories?: PartnerCategory[];
  title?: string;
  description?: string;
  nofollow?: boolean;
  /** ซ่อนหัวข้อใน component เมื่อหน้าแม่มี H2 แล้ว */
  hideHeading?: boolean;
}

const {
  variant = 'section',
  limit,
  categories,
  title,
  description,
  nofollow = false,
  hideHeading = false,
} = Astro.props;

const relBase = 'noopener noreferrer';
const relAttr = nofollow ? `${relBase} nofollow` : relBase;

function anchorFor(site: (typeof partnerSites)[number], idx: number) {
  const anchors = site.recommendedAnchors;
  return anchors[idx % anchors.length] ?? site.brand;
}

let items: typeof partnerSites = [];

if (variant === 'footer') {
  items = getFooterPartners();
  const lim = limit ?? 4;
  items = items.slice(0, lim);
} else if (variant === 'full') {
  items = [];
} else {
  const lim = limit ?? (variant === 'compact' ? 4 : 6);
  items = filterPartners({ categories, limit: lim });
}

const defaultTitles: Record<typeof variant, string> = {
  footer: 'เว็บไซต์ในเครือ',
  section: 'บริการอื่นในเครือ',
  compact: 'บริการรับซื้อสินค้าไอทีอื่นในเครือ',
  full: 'เว็บไซต์ในเครือ',
};

const heading = title !== undefined && title !== '' ? title : defaultTitles[variant];
const intro = description;
const showHeading = variant === 'footer' ? true : !hideHeading && Boolean(heading);
const footerHeading = title !== undefined && title !== '' ? title : defaultTitles.footer;
---

{variant === 'footer' && (
  <div class="text-sm">
    <p class="font-semibold text-slate-900">{footerHeading}</p>
    {intro && <p class="mt-1 text-xs leading-relaxed text-slate-600">{intro}</p>}
    <ul class="mt-2 space-y-1.5 text-slate-700">
      {items.map((site) => (
        <li>
          <a
            href={site.url}
            class="font-medium text-emerald-700 underline-offset-2 hover:text-emerald-800 hover:underline"
            target="_blank"
            rel={relAttr}
            aria-label={`${site.brand} (เปิดในแท็บใหม่)`}
          >
            {site.brand}
          </a>
        </li>
      ))}
    </ul>
  </div>
)}

{variant === 'compact' && (
  <div class="rounded-2xl border border-slate-200 bg-slate-50/80 px-4 py-4 text-sm text-slate-700">
    {showHeading && <p class="font-semibold text-slate-900">{heading}</p>}
    {intro && <p class="mt-2 text-xs leading-relaxed text-slate-600">{intro}</p>}
    <p class="mt-3 leading-relaxed">
      {items.map((site, i) => (
        <span class="inline">
          {i > 0 && <span class="text-slate-400"> · </span>}
          <a
            href={site.url}
            class="font-semibold text-emerald-700 underline-offset-2 hover:text-emerald-800 hover:underline"
            target="_blank"
            rel={relAttr}
            aria-label={`${anchorFor(site, i)} — ${site.brand}`}
          >
            {anchorFor(site, i)}
          </a>
        </span>
      ))}
    </p>
  </div>
)}

{variant === 'section' && (
  <div>
    {showHeading && <h2 class="text-xl font-extrabold tracking-tight text-slate-900">{heading}</h2>}
    {intro && <p class:list={['text-sm leading-relaxed text-slate-600', showHeading && 'mt-2']}>{intro}</p>}
    <div class:list={['grid gap-4 sm:grid-cols-2 lg:grid-cols-3', showHeading || intro ? 'mt-5' : 'mt-0']}>
      {items.map((site, idx) => (
        <article class="flex flex-col rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition-colors hover:border-emerald-300">
          <p class="text-xs font-semibold uppercase tracking-wide text-emerald-700">
            {partnerCategoryThai[site.category]}
          </p>
          <h4 class="mt-2 text-base font-extrabold text-slate-900">{site.brand}</h4>
          <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-600">{site.description}</p>
          <a
            href={site.url}
            class="mt-4 inline-flex text-sm font-semibold text-emerald-700 underline-offset-4 hover:text-emerald-800 hover:underline"
            target="_blank"
            rel={relAttr}
            aria-label={`${anchorFor(site, idx)} (เปิดในแท็บใหม่)`}
          >
            {anchorFor(site, idx)} →
          </a>
        </article>
      ))}
    </div>
  </div>
)}

{variant === 'full' && (
  <div class="space-y-10">
    {partnerFullGroups.map((group, gIdx) => {
      const groupSites = partnerSites.filter((p) => group.categories.includes(p.category));
      if (!groupSites.length) return null;
      const gid = `partner-g-${gIdx}`;
      return (
        <section aria-labelledby={gid}>
          <h3 id={gid} class="text-lg font-extrabold text-slate-900">
            {group.title}
          </h3>
          <div class="mt-4 grid gap-4 sm:grid-cols-2">
            {groupSites.map((site, idx) => (
              <article class="flex flex-col rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition-colors hover:border-emerald-300">
                <p class="text-xs font-semibold text-emerald-700">{partnerCategoryThai[site.category]}</p>
                <h4 class="mt-2 text-base font-extrabold text-slate-900">{site.brand}</h4>
                <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-600">{site.description}</p>
                <a
                  href={site.url}
                  class="mt-4 inline-flex text-sm font-semibold text-emerald-700 underline-offset-4 hover:text-emerald-800 hover:underline"
                  target="_blank"
                  rel={relAttr}
                  aria-label={`${anchorFor(site, idx)} (เปิดในแท็บใหม่)`}
                >
                  {anchorFor(site, idx)} →
                </a>
              </article>
            ))}
          </div>
        </section>
      );
    })}
  </div>
)}
