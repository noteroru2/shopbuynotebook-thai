---
import { SITE } from '../lib/seo';

const items = [
  {
    title: 'หน้าเครื่อง',
    desc: 'ถ่ายหน้าจอ/สภาพตัวเครื่องด้านหน้า',
    tone: 'emerald',
    img: '/images/photo-guide/rubsue-notebook-photo-front.webp',
    alt: 'ตัวอย่างรูปหน้าเครื่องโน๊ตบุ๊คเพื่อประเมินราคา',
  },
  {
    title: 'คีย์บอร์ด',
    desc: 'เห็นสภาพปุ่ม/รอย/ไฟคีย์บอร์ด (ถ้ามี)',
    tone: 'sky',
    img: '/images/photo-guide/rubsue-notebook-photo-keyboard.webp',
    alt: 'ตัวอย่างรูปคีย์บอร์ดโน๊ตบุ๊คเพื่อประเมินราคา',
  },
  {
    title: 'ฝาหลัง',
    desc: 'ถ่ายด้านล่าง/สติกเกอร์รุ่น/Serial (ถ้ามี)',
    tone: 'amber',
    img: '/images/photo-guide/rubsue-notebook-photo-back.webp',
    alt: 'ตัวอย่างรูปฝาหลังหรือข้อมูลรุ่นโน๊ตบุ๊คเพื่อประเมินราคา',
  },
  {
    title: 'อุปกรณ์ที่มี',
    desc: 'ที่ชาร์จ กล่อง ใบเสร็จ เมาส์ ดองเกิล',
    tone: 'slate',
    img: '/images/photo-guide/rubsue-notebook-photo-accessories.webp',
    alt: 'ตัวอย่างรูปอุปกรณ์ที่มี เช่น กล่องหรืออะแดปเตอร์ชาร์จ',
  },
];
---

<section class="mx-auto w-full max-w-6xl px-4 pt-12">
  <div class="rounded-3xl border border-slate-200 bg-white/70 p-6 shadow-sm backdrop-blur sm:p-8">
    <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <h2 class="text-xl font-bold text-slate-900">ถ่าย 4 รูปนี้เพื่อประเมินราคาแม่นขึ้น</h2>
        <p class="mt-2 text-sm text-slate-600">ใช้เวลาไม่นาน แต่ช่วยให้ประเมินได้เร็วและใกล้เคียงราคาจริงมากขึ้น</p>
      </div>
      <a class="text-sm font-semibold text-slate-600 hover:text-slate-900" href={SITE.lineUrl} target="_blank" rel="noopener noreferrer">
        แอดไลน์ {SITE.lineHandle}
      </a>
    </div>

    <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {items.map((it, idx) => (
        <div
          class:list={[
            'relative rounded-3xl border p-5 shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md',
            it.tone === 'emerald' && 'border-emerald-200 bg-emerald-50/70',
            it.tone === 'sky' && 'border-sky-200 bg-sky-50/70',
            it.tone === 'amber' && 'border-amber-200 bg-amber-50/70',
            it.tone === 'slate' && 'border-slate-200 bg-slate-50/70',
          ]}
        >
          <span
            aria-hidden="true"
            class="absolute right-4 top-4 inline-flex h-9 w-9 items-center justify-center rounded-2xl border border-white/70 bg-white/70 text-xs font-extrabold text-slate-900 shadow-sm backdrop-blur"
          >
            {String(idx + 1).padStart(2, '0')}
          </span>
          <img
            src={it.img}
            alt={it.alt}
            loading="lazy"
            decoding="async"
            width="600"
            height="400"
            class="mt-2 aspect-[3/2] w-full rounded-2xl border border-slate-200 bg-white object-cover"
          />
          <p class="mt-2 text-base font-bold text-slate-900">{it.title}</p>
          <p class="mt-2 text-sm leading-relaxed text-slate-700">{it.desc}</p>
          <p class="mt-2 text-xs font-semibold text-slate-600">
            แนะนำ: ให้เห็นชัด ไม่เบลอ แสงพอ และถ่ายมุมตรง ๆ
          </p>
        </div>
      ))}
    </div>

    <div class="mt-7 flex flex-col items-start justify-between gap-3 sm:flex-row sm:items-center">
      <p class="text-sm font-semibold text-slate-700">
        ถ่ายครบ 4 มุมแล้ว ส่งผ่าน LINE เพื่อประเมินราคา
      </p>
      <a
        class="inline-flex items-center justify-center rounded-2xl bg-[#06C755] px-5 py-3 text-sm font-extrabold text-white shadow-sm hover:brightness-95"
        href={SITE.lineUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="แอด LINE ส่งรูปประเมินราคา"
      >
        แอดไลน์ {SITE.lineHandle} ส่งรูปประเมินราคา
      </a>
    </div>
  </div>
</section>

