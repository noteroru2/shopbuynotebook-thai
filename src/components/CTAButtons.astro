---
import { SITE } from '../lib/seo';

interface Props {
  primaryText?: string;
  secondaryText?: string;
}

const {
  primaryText = `แอดไลน์ ${SITE.lineHandle} ส่งรูปประเมินราคา`,
  secondaryText = `โทร`,
} = Astro.props;
---

<div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
  <a
    class="inline-flex items-center justify-center gap-2 rounded-2xl bg-[#06C755] px-5 py-3 text-base font-semibold text-white shadow-lg shadow-[#06C755]/30 transition-all duration-300 hover:-translate-y-0.5 hover:scale-105 hover:shadow-xl hover:shadow-[#06C755]/40 focus-visible:outline-none"
    href={SITE.lineUrl}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="แอด LINE ส่งรูปประเมินราคา"
  >
    <span aria-hidden="true" class="inline-flex h-5 w-5 items-center justify-center rounded-full bg-white/20">✦</span>
    {primaryText}
  </a>
  <a
    class="inline-flex items-center justify-center rounded-2xl bg-slate-900 px-5 py-3 text-base font-semibold text-white shadow-lg shadow-slate-900/20 transition-all duration-300 hover:-translate-y-0.5 hover:scale-105 hover:bg-slate-800 hover:shadow-xl hover:shadow-slate-900/30 focus-visible:outline-none"
    href={`tel:${SITE.telephone}`}
  >
    {secondaryText} {SITE.telephone}
  </a>
</div>

