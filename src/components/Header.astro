---
import { SITE } from '../lib/seo';

const pathname = Astro.url.pathname;

const nav = [
  { label: 'ขายด่วน 🔥', href: '/ขายโน๊ตบุ๊คด่วน/' },
  { label: 'ประเมินราคา', href: '/รับซื้อโน๊ตบุ๊ค/' },
  { label: 'รับเหมาบริษัท', href: '/รับเหมาโน๊ตบุ๊ค/' },
  { label: 'พื้นที่บริการ', href: '/พื้นที่ให้บริการ/' },
  { label: 'บทความ', href: '/blog/' },
];

const isActive = (href: string) => (href === '/' ? pathname === '/' : pathname.startsWith(href));
---

<header class="sticky top-0 z-50 border-b border-white/20 bg-white/70 backdrop-blur-xl shadow-sm transition-all duration-300">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-3">
    
    <!-- Logo Section -->
    <a href="/" class="group flex min-w-0 items-center gap-3 transition-transform duration-300 hover:scale-105">
      <span class="rounded-2xl bg-slate-900 p-2 shadow-md ring-1 ring-slate-900/10">
        <picture>
          <source srcset="/images/logo-ranrubsue-notebook-black.webp" media="(min-width: 480px)" />
          <img
            src="/images/logo-ranrubsue-notebook-black-280.webp"
            alt="โลโก้ ร้านรับซื้อโน๊ตบุ๊ค.com"
            width="280"
            height="140"
            class="h-10 w-auto flex-none object-contain sm:h-11"
            loading="eager"
            decoding="async"
          />
        </picture>
      </span>
      <span class="min-w-0">
        <span class="block truncate text-sm font-extrabold tracking-tight text-slate-900 sm:text-lg">
          ร้านรับซื้อโน๊ตบุ๊ค.com
        </span>
        <span class="hidden truncate text-xs font-medium text-slate-500 xl:block">
          รับซื้อโน๊ตบุ๊คมือสอง • ประเมินไว • จ่ายเงินสด
        </span>
      </span>
    </a>

    <!-- Desktop Navigation -->
    <nav aria-label="เมนูหลัก" class="hidden items-center gap-2 lg:flex lg:justify-center lg:flex-1">
      {nav.map((item) => {
        const active = isActive(item.href);
        return (
          <a
            href={item.href}
            class:list={[
              'relative px-3 py-2 text-[14px] font-semibold whitespace-nowrap transition-all duration-300',
              active ? 'text-emerald-600' : 'text-slate-600 hover:text-slate-900',
            ]}
            aria-current={active ? 'page' : undefined}
          >
            <span class="relative z-10">{item.label}</span>
            {/* Animated Underline */}
            <span 
              class:list={[
                'absolute bottom-0 left-0 h-[2px] bg-gradient-to-r from-emerald-400 to-emerald-600 transition-all duration-300',
                active ? 'w-full' : 'w-0 group-hover:w-full'
              ]}
            ></span>
            {/* We add a custom hover target wrapper so hover triggers smoothly */}
            <div class="absolute inset-0 rounded-lg hover:bg-slate-50/50 -z-10 transition-colors"></div>
          </a>
        );
      })}
    </nav>

    <!-- Desktop CTA Buttons -->
    <div class="hidden items-center gap-3 lg:flex">
      <a
        class="inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-bold text-slate-800 shadow-sm transition-all duration-300 hover:scale-105 hover:bg-slate-50 hover:shadow-md"
        href={`tel:${SITE.telephone}`}
      >
        โทร {SITE.telephone}
      </a>
      <a
        class="relative inline-flex items-center justify-center overflow-hidden rounded-xl bg-[#06C755] px-5 py-2.5 text-sm font-extrabold text-white shadow-lg transition-all duration-300 hover:scale-105 hover:shadow-emerald-500/30"
        href={SITE.lineUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="relative z-10 flex items-center gap-2">
          แอดไลน์ {SITE.lineHandle}
        </span>
        <!-- Shine effect -->
        <div class="absolute inset-0 -translate-x-full animate-[shimmer_2s_infinite] bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>
      </a>
    </div>

    <!-- Mobile Navigation Menu -->
    <div class="flex min-w-0 items-center gap-2 lg:hidden">
      <a
        class="inline-flex min-w-0 items-center justify-center rounded-xl bg-[#06C755] px-3 py-2 text-xs font-extrabold text-white shadow-sm transition-transform active:scale-95"
        href={SITE.lineUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`LINE ${SITE.lineHandle}`}
      >
        <span class="truncate">LINE</span>
      </a>
      <details class="group relative">
        <summary
          class="list-none cursor-pointer rounded-xl border border-slate-200 bg-white px-4 py-2 text-xs font-bold text-slate-900 shadow-sm transition-colors hover:bg-slate-50 active:scale-95"
          aria-label="เปิดเมนู"
        >
          เมนู
        </summary>
        <!-- Mobile Dropdown -->
        <div class="absolute right-0 mt-3 w-64 origin-top-right scale-95 opacity-0 transition-all duration-200 group-open:scale-100 group-open:opacity-100 rounded-2xl border border-white/40 bg-white/90 p-3 shadow-xl backdrop-blur-xl">
          <nav aria-label="เมนูหลัก (มือถือ)" class="flex flex-col gap-1">
            {nav.map((item) => (
              <a
                href={item.href}
                class:list={[
                  'rounded-xl px-4 py-2.5 text-sm font-bold transition-all',
                  isActive(item.href) 
                    ? 'bg-emerald-50 text-emerald-600 shadow-sm' 
                    : 'text-slate-600 hover:bg-slate-50 hover:text-slate-900',
                ]}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            ))}
          </nav>
          <hr class="my-3 border-slate-100" />
          <div class="flex flex-col gap-2">
            <a
              class="inline-flex items-center justify-center rounded-xl bg-[#06C755] px-4 py-3 text-sm font-extrabold text-white shadow-md active:scale-95 transition-transform"
              href={SITE.lineUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              แอดไลน์ {SITE.lineHandle} ประเมินราคา
            </a>
            <a
              class="inline-flex items-center justify-center rounded-xl border-2 border-slate-100 bg-white px-4 py-3 text-sm font-bold text-slate-800 active:scale-95 transition-transform"
              href={`tel:${SITE.telephone}`}
            >
              โทร {SITE.telephone}
            </a>
          </div>
        </div>
      </details>
    </div>

  </div>
</header>

<style>
  /* Optional: Custom animation for the shiny button effect */
  @keyframes shimmer {
    100% {
      transform: translateX(100%);
    }
  }
</style>
