---
import { SITE } from '../lib/seo';
---

<div
  class="fixed inset-x-0 bottom-0 z-40 border-t border-slate-200 bg-white/95 pb-[max(0.35rem,env(safe-area-inset-bottom,0px))] pt-0.5 backdrop-blur sm:hidden"
>
  <div class="mx-auto grid max-w-6xl grid-cols-2 gap-2 px-2.5 py-1.5">
    <a
      class="flex min-h-[3.15rem] min-w-0 flex-col items-center justify-center gap-0.5 rounded-xl border-2 border-slate-200 bg-white px-1.5 py-1.5 text-slate-900 shadow-sm active:bg-slate-50"
      href={`tel:${SITE.telephone}`}
      aria-label={`โทรเลย ${SITE.telephone}`}
    >
      <span class="text-center text-[clamp(0.84rem,3.78vw,1.19rem)] font-black leading-none tracking-tight">โทรเลย</span>
      <span class="text-center text-xs font-bold tabular-nums tracking-wide text-slate-700">{SITE.telephone}</span>
    </a>
    <a
      class="flex min-h-[3.15rem] min-w-0 flex-col items-center justify-center gap-0 rounded-xl bg-[#06C755] px-1.5 py-1.5 text-white shadow-md active:brightness-95"
      href={SITE.lineUrl}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={`แอด LINE ${SITE.lineHandle} ส่งรูปประเมินราคา`}
    >
      <span class="text-center text-[clamp(0.74rem,3.22vw,1.02rem)] font-black leading-none tracking-tight">LINE</span>
      <span class="text-center text-[clamp(0.84rem,3.64vw,1.16rem)] font-black leading-none tracking-tight">{SITE.lineHandle}</span>
    </a>
  </div>
</div>

