---
export type RelatedLink = { label: string; href: string; description?: string };

interface Props {
  title?: string;
  links: RelatedLink[];
}

const { title = 'ลิงก์ที่เกี่ยวข้อง', links } = Astro.props;
---

<section class="mx-auto w-full max-w-6xl px-4 pt-10">
  <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
    <h2 class="text-lg font-extrabold text-slate-900">{title}</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {links.map((l) => (
        <a
          href={l.href}
          class="group rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 hover:border-emerald-200 hover:bg-emerald-50"
        >
          <p class="text-sm font-extrabold text-slate-900 group-hover:text-slate-950">{l.label}</p>
          {l.description ? <p class="mt-1 text-sm text-slate-700">{l.description}</p> : null}
        </a>
      ))}
    </div>
  </div>
</section>

