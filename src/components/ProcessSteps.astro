---
interface Props {
  title?: string;
}

const { title = 'ขายโน๊ตบุ๊คกับเรา ง่ายใน 4 ขั้นตอน' } = Astro.props;

const steps = [
  { title: 'ส่งรูปเครื่องและสเปก', desc: 'ถ่ายรูปตัวเครื่อง/สติ๊กเกอร์สเปก หรือพิมพ์สเปกคร่าว ๆ ก็ได้' },
  { title: 'แจ้งอาการและอุปกรณ์ที่มี', desc: 'เช่น แบตเสื่อม จอมีเส้น ไม่มีที่ชาร์จ มีกล่อง/ใบเสร็จหรือไม่' },
  { title: 'ร้านประเมินราคาเบื้องต้น', desc: 'ประเมินตามรุ่น/สเปก/สภาพและราคาตลาดมือสอง' },
  { title: 'นัดรับเครื่อง / ส่งเครื่อง / จ่ายเงินทันที', desc: 'สะดวกแบบไหนเลือกได้ และจ่ายเงินเมื่อรับเครื่อง' },
];
---

<section class="mx-auto w-full max-w-6xl px-4 pt-12">
  <div class="rounded-3xl border border-slate-200 bg-white/70 p-6 shadow-sm backdrop-blur sm:p-8">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
      <div class="lg:max-w-xl">
        <h2 class="text-xl font-bold text-slate-900">{title}</h2>
        <p class="mt-2 text-sm leading-relaxed text-slate-600">
          ดูภาพรวมขั้นตอนแบบเร็ว ๆ แล้วเริ่มส่งรูปประเมินได้ทันที (ตอบไวทาง LINE)
        </p>
        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          {steps.map((s, idx) => (
            <div class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
              <p class="text-xs font-semibold text-slate-500">ขั้นตอน {idx + 1}</p>
              <p class="mt-2 text-sm font-semibold text-slate-900">{s.title}</p>
              <p class="mt-2 text-sm leading-relaxed text-slate-600">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <figure class="lg:w-[520px]">
        <picture>
          <source srcset="/images/rubsue-notebook-process-steps.webp" media="(min-width: 1024px)" />
          <img
            src="/images/rubsue-notebook-process-steps-800.webp"
            alt="ขั้นตอนการขายโน๊ตบุ๊ค 4 ขั้นตอน ตั้งแต่ถ่ายรูป แชท LINE ตรวจสภาพ และรับเงิน"
            loading="lazy"
            decoding="async"
            class="w-full rounded-3xl border border-slate-200 object-cover shadow-sm"
            width="800"
            height="450"
          />
        </picture>
        <figcaption class="mt-3 text-xs text-slate-500">
          ภาพประกอบขั้นตอนการส่งรูป ประเมินราคา นัดรับเครื่อง และรับเงิน
        </figcaption>
      </figure>
    </div>
  </div>
</section>

