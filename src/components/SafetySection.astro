---
const points = [
  'ประเมินราคาก่อนตกลงขาย',
  'แจ้งเงื่อนไขและขั้นตอนชัดเจน',
  'จ่ายเงินสดหรือโอนทันทีหลังตกลงราคา',
  'แนะนำวิธีสำรองและล้างข้อมูลก่อนขาย',
  'ไม่เปิดดูไฟล์ส่วนตัวของลูกค้า',
];
---

<section class="mx-auto w-full max-w-6xl px-4 pt-12">
  <div class="relative overflow-hidden rounded-3xl border border-emerald-200 bg-gradient-to-br from-emerald-50 via-white to-sky-50 p-6 shadow-sm sm:p-8">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0">
      <div class="absolute -left-16 top-8 h-64 w-64 rounded-full bg-emerald-300/25 blur-3xl"></div>
      <div class="absolute -right-20 -top-10 h-72 w-72 rounded-full bg-sky-300/25 blur-3xl"></div>
    </div>

    <div class="relative grid gap-6 lg:grid-cols-2 lg:items-center">
      <div>
        <p class="inline-flex items-center gap-2 rounded-full border border-emerald-200 bg-white/70 px-3 py-1 text-xs font-semibold text-emerald-800 backdrop-blur">
          <span aria-hidden="true" class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-emerald-600 text-xs font-extrabold text-white">
            ✓
          </span>
          โปร่งใส • ปลอดภัย • เคารพข้อมูลส่วนตัว
        </p>
        <h2 class="mt-4 text-xl font-extrabold tracking-tight text-slate-900 sm:text-2xl">
          ขายโน๊ตบุ๊คกับเราปลอดภัยอย่างไร
        </h2>
        <p class="mt-3 text-sm leading-relaxed text-slate-700">
          เราให้ความสำคัญกับความโปร่งใสในการประเมินราคา และข้อมูลส่วนตัวของลูกค้าก่อนขายเครื่อง
        </p>
        <p class="mt-3 text-sm text-slate-600">
          ถ้าต้องการประเมินไวที่สุด แนะนำส่งรูป 3–5 รูป + รุ่น/สเปก ทาง LINE ได้เลย
        </p>
      </div>

      <div class="rounded-3xl border border-slate-200 bg-white/70 p-6 shadow-sm backdrop-blur">
        <div class="flex items-center gap-2">
          <span aria-hidden="true" class="inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-[#0F172A] text-white">
            🛡️
          </span>
          <p class="text-sm font-extrabold text-slate-900">เช็กลิสต์ความมั่นใจ</p>
        </div>
        <ul class="mt-4 grid gap-3">
          {points.map((p) => (
            <li class="flex items-start gap-3 rounded-2xl border border-slate-200 bg-white px-4 py-3 shadow-sm">
              <span aria-hidden="true" class="mt-0.5 inline-flex h-6 w-6 flex-none items-center justify-center rounded-full bg-emerald-50 text-emerald-700">
                ✓
              </span>
              <p class="text-sm font-semibold text-slate-800">{p}</p>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

