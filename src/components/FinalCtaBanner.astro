---
interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = 'พร้อมขายโน๊ตบุ๊ควันนี้? ส่งรูปประเมินราคาฟรีได้เลย',
  subtitle =
    'แอดไลน์ @webuy ส่งรูปเครื่อง รุ่น และสภาพ ทีมงานช่วยประเมินราคาเบื้องต้น พร้อมแจ้งขั้นตอนการขายอย่างชัดเจน — โทร 0642579353',
} = Astro.props;
---

<section class="mx-auto w-full max-w-6xl px-4 py-14">
  <div class="overflow-hidden rounded-3xl border border-slate-800 bg-[#0F172A] shadow-sm">
    <div class="relative grid gap-6 p-6 sm:p-10 lg:grid-cols-2 lg:items-center">
      <div aria-hidden="true" class="pointer-events-none absolute inset-0">
        <div class="absolute -left-24 -top-24 h-80 w-80 rounded-full bg-[#06C755]/18 blur-3xl"></div>
        <div class="absolute -right-24 top-10 h-96 w-96 rounded-full bg-sky-400/10 blur-3xl"></div>
      </div>
      <div>
        <h2 class="text-2xl font-extrabold tracking-tight text-white">
          พร้อมขายโน๊ตบุ๊ควันนี้? <span class="text-amber-300">ส่งรูปประเมินฟรี</span> ได้เลย
        </h2>
        <p class="mt-3 text-sm leading-relaxed text-slate-200">{subtitle}</p>
        <div class="mt-6">
          <slot />
        </div>
        <p class="mt-3 text-xs font-semibold text-slate-300">แนะนำ: ส่งรูป 3–5 รูป + รุ่น/สเปก เพื่อประเมินไวขึ้น</p>
      </div>

      <figure class="lg:justify-self-end">
        <picture>
          <source srcset="/images/cta/rubsue-notebook-final-cta-banner.webp" media="(min-width: 1024px)" />
          <img
            src="/images/cta/rubsue-notebook-final-cta-banner-720.webp"
            alt="แบนเนอร์ช่องทางติดต่อ LINE และโทรศัพท์สำหรับรับซื้อโน๊ตบุ๊ค"
            loading="lazy"
            decoding="async"
            width="720"
            height="360"
            class="w-full max-w-xl rounded-3xl border border-slate-700 object-cover shadow-sm"
          />
        </picture>
        <figcaption class="mt-3 text-xs text-slate-300">
          แอดไลน์ @webuy หรือโทร 0642579353 เพื่อส่งรูปประเมินราคา
        </figcaption>
      </figure>
    </div>
  </div>
</section>

