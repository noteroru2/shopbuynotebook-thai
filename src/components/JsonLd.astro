---
export type JsonLdSchema = Record<string, any>;

interface Props {
  schema: JsonLdSchema | JsonLdSchema[];
}

const { schema } = Astro.props;
const normalized = Array.isArray(schema) ? schema : [schema];
---

{normalized.map((item) => (
  <script type="application/ld+json" set:html={JSON.stringify(item)} />
))}

