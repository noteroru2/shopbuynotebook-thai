---
import { getCollection } from 'astro:content';
import { SITE } from '../lib/seo';

const reviews = await getCollection('reviews');

function formatMonthYear(value?: string) {
  if (!value) return '';
  const d = new Date(value);
  if (Number.isNaN(d.getTime())) return value;
  return new Intl.DateTimeFormat('th-TH', { month: 'long', year: 'numeric' }).format(d);
}

function shouldShowAvatarImage(src?: string) {
  if (!src) return false;
  const lower = src.toLowerCase();
  if (lower.includes('/images/avatars/')) return false;
  if (lower.includes('rubsue-notebook-logo-banner')) return false;
  if (lower.endsWith('.svg')) return false;
  return true;
}
---

<section class="mx-auto w-full max-w-6xl px-4 pt-12">
  <div class="flex items-end justify-between gap-4">
    <h2 class="text-xl font-bold text-slate-900">ตัวอย่างเคสรับซื้อที่ผ่านมา</h2>
    <a class="text-sm font-semibold text-slate-600 hover:text-slate-900" href="/เกี่ยวกับเรา/">ดูรายละเอียดร้าน</a>
  </div>

  <div class="mt-6 grid gap-4 lg:grid-cols-3">
    {reviews.slice(0, 3).map((r) => (
      <article class="group overflow-hidden rounded-3xl border border-slate-200 bg-white/70 shadow-sm backdrop-blur transition-all hover:-translate-y-0.5 hover:border-emerald-300 hover:shadow-md">
        <img
          src={r.data.deviceImage ?? '/images/ui/notebook-fallback.svg'}
          alt={r.data.model ? `รูปเครื่องที่รับซื้อ รุ่น ${r.data.model}` : 'รูปเครื่องตัวอย่างที่รับซื้อ'}
          loading="lazy"
          decoding="async"
          width="800"
          height="600"
          class="aspect-[4/3] w-full border-b border-slate-200 bg-white object-cover"
        />

        <div class="p-6">
          <div class="flex items-center justify-between gap-3">
            <span class="rounded-full bg-amber-100 px-3 py-1 text-xs font-extrabold text-amber-900">รับซื้อแล้ว</span>
            <span class="text-xs font-semibold text-slate-500">{formatMonthYear(r.data.date)}</span>
          </div>

          <div class="mt-4 flex flex-wrap gap-2">
            {r.data.model ? (
              <span class="rounded-full border border-slate-200 bg-white px-3 py-1 text-xs font-semibold text-slate-700">{r.data.model}</span>
            ) : null}
            {r.data.location ? (
              <span class="rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700">{r.data.location}</span>
            ) : null}
          </div>

          <p class="mt-4 text-sm leading-relaxed text-slate-700">“{r.data.summary}”</p>

          <div class="mt-5 flex items-center justify-between gap-3 border-t border-slate-200 pt-4">
            <div class="flex items-center gap-3">
              <div class="h-9 w-9 overflow-hidden rounded-full border border-slate-200 bg-slate-50">
                {shouldShowAvatarImage(r.data.avatar) ? (
                  <img
                    src={r.data.avatar}
                    alt={`รูปโปรไฟล์คุณ${r.data.name}`}
                    loading="lazy"
                    decoding="async"
                    class="h-full w-full object-cover"
                  />
                ) : (
                  <svg
                    viewBox="0 0 24 24"
                    class="h-full w-full p-1.5 text-slate-500"
                    role="img"
                    aria-label="ไอคอนโปรไฟล์ลูกค้า"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path
                      d="M12 12a4.2 4.2 0 1 0 0-8.4A4.2 4.2 0 0 0 12 12Z"
                      stroke="currentColor"
                      stroke-width="1.8"
                    />
                    <path
                      d="M4.5 20.2c1.9-3.9 5-5.8 7.5-5.8s5.6 1.9 7.5 5.8"
                      stroke="currentColor"
                      stroke-width="1.8"
                      stroke-linecap="round"
                    />
                  </svg>
                )}
              </div>
              <div class="min-w-0">
                <p class="truncate text-sm font-semibold text-slate-900">{r.data.name}</p>
                <p class="text-xs font-semibold text-slate-600">ประเมินผ่าน LINE • นัดรับเครื่อง</p>
              </div>
            </div>
            <span class="text-xs font-semibold text-slate-600 group-hover:text-slate-900">
              ดูเคส <span aria-hidden="true">→</span>
            </span>
          </div>
        </div>
      </article>
    ))}
  </div>

  <div class="mt-6 flex flex-col items-start justify-between gap-3 sm:flex-row sm:items-center">
    <p class="text-xs leading-relaxed text-slate-500">
      ด้านบนเป็นเคสจริงที่เราสรุปให้อ่านง่ายหลังคุย/ประเมินผ่าน LINE — ใช้ชื่อเล่นและซ่อนรายละเอียดที่ละเอียดอ่อนให้แล้วนะครับ
      <strong class="font-semibold text-slate-600">ไม่ได้เอาข้อความจากรีวิว Google มาวางตรง ๆ</strong>
      อยากอ่านความเห็นดิบ ๆ จากลูกค้าที่แผนที่ กดปุ่ม «รีวิวบน Google Maps» ได้เลย
      <span class="mt-1 block text-slate-500">
        ขั้นตอนซื้อขายและเรื่องราคาหลังตรวจเครื่อง อ่านแบบสบาย ๆ ได้ที่หน้า{' '}
        <a class="font-semibold text-emerald-700 underline underline-offset-2 hover:text-emerald-800" href="/ขั้นตอนและเงื่อนไขการให้บริการ/">ขั้นตอนและเงื่อนไขการให้บริการ</a>
      </span>
    </p>
    <div class="flex flex-wrap gap-2">
      <a
        class="inline-flex items-center justify-center rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-2 text-sm font-semibold text-emerald-900 hover:bg-emerald-100"
        href={SITE.googleMapsUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        รีวิวบน Google Maps
      </a>
      <a class="inline-flex items-center justify-center rounded-2xl border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-900 shadow-sm hover:bg-slate-50" href="/เกี่ยวกับเรา/">
        เกี่ยวกับเรา
      </a>
    </div>
  </div>
</section>

