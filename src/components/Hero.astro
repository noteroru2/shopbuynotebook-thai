---
import CTAButtons from './CTAButtons.astro';
import { SITE } from '../config/site';

interface Props {
  title: string;
  titleHtml?: string;
  subtitle: string;
  imageSrc: string;
  imageAlt: string;
  /** เช่น `/a.webp 640w, /b.webp 1024w` — ช่วย LCP บนมือถือให้โหลดไฟล์ที่พอดีจอ */
  imageSrcset?: string;
  imageSizes?: string;
  imageWidth?: number;
  imageHeight?: number;
}

const {
  title,
  titleHtml,
  subtitle,
  imageSrc,
  imageAlt,
  imageSrcset,
  imageSizes,
  imageWidth = 960,
  imageHeight = 720,
} = Astro.props;
---

<section class="relative mx-auto w-full max-w-6xl px-4 pt-8 sm:pt-12">
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
    <div class="absolute inset-x-0 top-0 h-[520px] bg-gradient-to-br from-emerald-50 via-white to-sky-50"></div>
    <div class="absolute -top-28 left-[-110px] h-80 w-80 rounded-full bg-emerald-300/45 blur-3xl"></div>
    <div class="absolute top-10 right-[-140px] h-96 w-96 rounded-full bg-sky-300/45 blur-3xl"></div>
    <div class="absolute bottom-[-140px] left-1/3 h-96 w-96 rounded-full bg-amber-200/35 blur-3xl"></div>
  </div>
  <div class="grid items-center gap-8 md:grid-cols-2">
    <div>
      <p class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white/80 px-3 py-1 text-xs font-semibold text-slate-800 shadow-sm backdrop-blur">
        <span class="inline-flex h-2 w-2 rounded-full bg-[#06C755]" aria-hidden="true"></span>
        ประเมินฟรี • ส่งรูปผ่าน LINE • จ่ายเงินทันที
      </p>
      <h1 class="mt-4 text-balance text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl lg:text-5xl">
        {titleHtml ? <span set:html={titleHtml} /> : title}
      </h1>
      <p class="mt-4 text-pretty text-base leading-relaxed text-slate-700 sm:text-lg">{subtitle}</p>
      <div class="mt-6">
        <CTAButtons
          primaryText={`แอดไลน์ ${SITE.lineHandle} ส่งรูปประเมินราคา`}
          secondaryText="โทร"
        />
      </div>
      <p class="mt-3 text-xs font-semibold text-slate-600">
        ส่งรูป 3–5 รูป พร้อมรุ่นเครื่อง ช่วยให้ประเมินได้เร็วขึ้น
      </p>
    </div>

    <div class="rounded-3xl border border-slate-200 bg-white/70 p-3 shadow-sm backdrop-blur">
      <img
        class="aspect-[4/3] w-full rounded-2xl object-cover"
        src={imageSrc}
        {...(imageSrcset
          ? {
              srcset: imageSrcset,
              sizes: imageSizes ?? '(max-width: 767px) 100vw, (max-width: 1023px) 50vw, 480px',
            }
          : {})}
        alt={imageAlt}
        loading="eager"
        decoding="async"
        fetchpriority="high"
        width={imageWidth}
        height={imageHeight}
      />
      <div class="mt-3 grid gap-2 sm:grid-cols-3">
        <div class="rounded-2xl border border-slate-200 bg-white px-3 py-2 text-xs font-semibold text-slate-700">
          ตอบไวทาง LINE
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white px-3 py-2 text-xs font-semibold text-slate-700">
          นัดรับ/ส่งเครื่องได้
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white px-3 py-2 text-xs font-semibold text-slate-700">
          จ่ายเงินทันที
        </div>
      </div>
    </div>
  </div>
</section>

