---
const items = [
  {
    src: '/images/home/rubsue-notebook-banner-640.webp',
    alt: 'รับซื้อ Notebook ทุกยี่ห้อ ทุกสภาพ ติดต่อผ่าน LINE',
    caption: 'รับซื้อทุกยี่ห้อ ทุกสภาพ',
  },
  {
    src: '/images/home/rubsue-notebook-delivery-640.webp',
    alt: 'รับซื้อโน๊ตบุ๊คถึงที่ ประเมินราคาไว',
    caption: 'นัดรับ/ส่งเครื่องได้',
  },
  {
    src: '/images/home/rubsue-notebook-logo-640.webp',
    alt: 'แบนเนอร์ ร้านรับซื้อโน๊ตบุ๊ค.com',
    caption: 'แบรนด์ดูน่าเชื่อถือ',
  },
  {
    src: '/images/home/rubsue-notebook-hero-team-640.webp',
    alt: 'ทีมงานตรวจสภาพโน๊ตบุ๊คก่อนประเมินราคา',
    caption: 'ประเมินไว จ่ายเงินทันที',
  },
];
---

<section class="mx-auto w-full max-w-6xl px-4 pt-10">
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    {items.map((it) => (
      <figure class="rounded-3xl border border-slate-200 bg-white/70 p-3 shadow-sm backdrop-blur">
        <img
          src={it.src}
          alt={it.alt}
          loading="lazy"
          decoding="async"
          class="aspect-[5/3] w-full rounded-2xl object-cover"
          width="600"
          height="360"
        />
        <figcaption class="mt-3 text-xs font-semibold text-slate-700">{it.caption}</figcaption>
      </figure>
    ))}
  </div>
</section>

