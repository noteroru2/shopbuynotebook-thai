---
interface Props {
  name: string;
  displayLogo?: string;
  slug?: string;
  color?: 'slate' | 'emerald' | 'sky' | 'amber' | 'rose' | 'violet';
  logo?: string;
  alt: string;
}

const { name, displayLogo, slug, color = 'slate', logo, alt } = Astro.props;
const text = displayLogo ?? name;
---

<div
  class:list={[
    'flex h-14 min-w-14 flex-none items-center justify-center overflow-hidden rounded-2xl border bg-white px-2 shadow-sm',
    color === 'slate' && 'border-slate-200',
    color === 'emerald' && 'border-emerald-200',
    color === 'sky' && 'border-sky-200',
    color === 'amber' && 'border-amber-200',
    color === 'rose' && 'border-rose-200',
    color === 'violet' && 'border-violet-200',
  ]}
>
  {logo ? (
    <img src={logo} alt={alt} loading="lazy" decoding="async" class="h-full w-full object-contain p-2" />
  ) : (
    <>
      {slug === 'dell' ? (
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-slate-300 text-xs font-extrabold tracking-tight text-slate-900" aria-label={alt}>
          DELL
        </span>
      ) : slug === 'hp' ? (
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-slate-300 bg-white text-xs font-extrabold tracking-tight text-slate-900" aria-label={alt}>
          HP
        </span>
      ) : slug === 'lenovo' ? (
        <span class="rounded-full border border-rose-200 bg-rose-50 px-3 py-1 text-xs font-extrabold tracking-tight text-rose-800" aria-label={alt}>
          Lenovo
        </span>
      ) : slug === 'acer' ? (
        <span class="whitespace-nowrap text-xs font-extrabold tracking-tight text-emerald-700" aria-label={alt}>
          acer
        </span>
      ) : slug === 'asus' ? (
        <span class="whitespace-nowrap text-xs font-black tracking-[0.12em] text-slate-900" aria-label={alt}>
          ASUS
        </span>
      ) : slug === 'surface' ? (
        <span class="inline-flex items-center gap-2" aria-label={alt}>
          <span class="grid grid-cols-2 gap-0.5">
            <span class="h-2.5 w-2.5 rounded-sm bg-slate-900"></span>
            <span class="h-2.5 w-2.5 rounded-sm bg-[#06C755]"></span>
            <span class="h-2.5 w-2.5 rounded-sm bg-sky-400"></span>
            <span class="h-2.5 w-2.5 rounded-sm bg-[#FACC15]"></span>
          </span>
          <span class="whitespace-nowrap text-xs font-extrabold tracking-tight text-slate-900">Surface</span>
        </span>
      ) : slug === 'msi' ? (
        <span class="whitespace-nowrap text-xs font-extrabold tracking-tight text-slate-900" aria-label={alt}>
          MSI
        </span>
      ) : slug === 'gaming' ? (
        <span class="whitespace-nowrap text-xs font-extrabold tracking-tight text-slate-900" aria-label={alt}>
          Gaming
        </span>
      ) : (
        <span
          class:list={[
            'whitespace-nowrap text-center text-xs font-extrabold tracking-tight',
            color === 'slate' && 'text-slate-900',
            color === 'emerald' && 'text-emerald-800',
            color === 'sky' && 'text-sky-800',
            color === 'amber' && 'text-amber-900',
            color === 'rose' && 'text-rose-800',
            color === 'violet' && 'text-violet-800',
          ]}
          aria-label={alt}
        >
          {text}
        </span>
      )}
    </>
  )}
</div>

