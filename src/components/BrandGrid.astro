---
import BrandLogo from './BrandLogo.astro';
import { BRANDS } from '../data/brands';
---

<section class="mx-auto w-full max-w-6xl px-4 pt-12">
  <div class="flex items-end justify-between gap-4">
    <h2 class="text-xl font-bold text-slate-900">รับซื้อโน๊ตบุ๊คทุกยี่ห้อ</h2>
    <a class="text-sm font-semibold text-slate-600 hover:text-slate-900" href="/รับซื้อ-notebook">
      ดูรายละเอียดการรับซื้อ
    </a>
  </div>

  <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {BRANDS.map((b) => (
      <a
        href={b.href}
        class="group rounded-3xl border border-slate-200 bg-white/70 p-5 shadow-sm backdrop-blur transition-all hover:-translate-y-0.5 hover:border-emerald-300 hover:shadow-md"
        aria-label={`ดูรายละเอียดรับซื้อ ${b.name}`}
      >
        <div class="flex items-center gap-4">
          <BrandLogo name={b.name} slug={b.slug} displayLogo={b.displayLogo} color={b.color} logo={b.logo} alt={b.alt} />
          <div class="min-w-0">
            <p class="truncate text-base font-semibold text-slate-900 group-hover:underline underline-offset-4">
              {b.name}
            </p>
            <p class="mt-1 text-sm text-slate-600">
              รุ่นยอดนิยม: {b.models.slice(0, 4).join(', ')}
            </p>
            <div class="mt-3 flex flex-wrap gap-2">
              <span class="rounded-full border border-emerald-200 bg-emerald-50 px-2.5 py-1 text-xs font-semibold text-emerald-700">รับซื้อ</span>
              <span class="rounded-full border border-slate-200 bg-white px-2.5 py-1 text-xs font-semibold text-slate-700">จ่ายเงินทันที</span>
              <span class="ml-auto inline-flex items-center gap-1 text-xs font-semibold text-slate-600 group-hover:text-slate-900">
                ดูรายละเอียด <span aria-hidden="true">→</span>
              </span>
            </div>
          </div>
        </div>
      </a>
    ))}
  </div>
</section>

