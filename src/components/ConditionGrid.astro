---
const conditions = [
  { name: 'ใช้งานปกติ', slug: 'ใช้งานปกติ', tone: 'emerald', icon: '✅', desc: 'สภาพดี ใช้งานได้ทุกฟังก์ชัน' },
  { name: 'เครื่องเก่า', slug: 'เครื่องเก่า', tone: 'sky', icon: '🕰️', desc: 'อายุหลายปี ตกรุ่น แต่ยังใช้งานได้' },
  { name: 'เปิดไม่ติด', slug: 'เปิดไม่ติด', tone: 'orange', icon: '⚡', desc: 'กดเปิดไม่ขึ้น ชาร์จไม่เข้า หรือดับเอง' },
  { name: 'จอแตก', slug: 'จอแตก', tone: 'rose', icon: '🪟', desc: 'จอร้าว/เป็นเส้น/จอดำ แต่เครื่องยังติด' },
  { name: 'แบตเสื่อม', slug: 'แบตเสื่อม', tone: 'amber', icon: '🔋', desc: 'แบตหมดไว บวม หรือชาร์จไม่เต็ม' },
  { name: 'ไม่มีที่ชาร์จ', slug: 'ไม่มีที่ชาร์จ', tone: 'violet', icon: '🔌', desc: 'ขายได้ แจ้งให้ทราบเพื่อประเมินให้ตรง' },
  { name: 'คีย์บอร์ดเสีย', slug: 'คีย์บอร์ดเสีย', tone: 'blue', icon: '⌨️', desc: 'บางปุ่มกดไม่ติด/กดซ้ำ/ไฟไม่ติด' },
  { name: 'ตกรุ่น', slug: 'ตกรุ่น', tone: 'slate', icon: '📦', desc: 'รุ่นเก่า เปลี่ยนเครื่องใหม่ ต้องการเปลี่ยนเป็นเงิน' },
];
---

<section class="mx-auto w-full max-w-6xl px-4 pt-12">
  <h2 class="text-xl font-bold text-slate-900">รับซื้อโน๊ตบุ๊คสภาพไหนบ้าง</h2>
  <p class="mt-2 text-sm text-slate-600">
    ถ้าไม่แน่ใจว่าอาการเข้าข่ายไหม ส่งรูปและอธิบายอาการทาง LINE ได้เลย เราช่วยประเมินให้ครับ
  </p>

  <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    {conditions.map((c) => (
      <a
        href={`/รับซื้อโน๊ตบุ๊ค/${c.slug}`}
        class:list={[
          'group flex h-full flex-col rounded-3xl border p-5 shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md',
          c.tone === 'emerald' && 'border-emerald-200 bg-emerald-50/70 hover:border-emerald-300',
          c.tone === 'sky' && 'border-sky-200 bg-sky-50/70 hover:border-sky-300',
          c.tone === 'orange' && 'border-orange-200 bg-orange-50/70 hover:border-orange-300',
          c.tone === 'rose' && 'border-rose-200 bg-rose-50/70 hover:border-rose-300',
          c.tone === 'amber' && 'border-amber-200 bg-amber-50/70 hover:border-amber-300',
          c.tone === 'violet' && 'border-violet-200 bg-violet-50/70 hover:border-violet-300',
          c.tone === 'blue' && 'border-sky-200 bg-sky-50/70 hover:border-sky-300',
          c.tone === 'slate' && 'border-slate-200 bg-slate-50/70 hover:border-slate-300',
        ]}
      >
        <div class="flex items-start justify-between gap-3">
          <div class="flex items-center gap-3">
            <span
              class:list={[
                'inline-flex h-10 w-10 flex-none items-center justify-center rounded-2xl border bg-white text-sm font-extrabold shadow-sm',
                c.tone === 'emerald' && 'border-emerald-200 text-emerald-800',
                c.tone === 'sky' && 'border-sky-200 text-sky-800',
                c.tone === 'orange' && 'border-orange-200 text-orange-800',
                c.tone === 'rose' && 'border-rose-200 text-rose-800',
                c.tone === 'amber' && 'border-amber-200 text-amber-800',
                c.tone === 'violet' && 'border-violet-200 text-violet-800',
                c.tone === 'blue' && 'border-sky-200 text-sky-800',
                c.tone === 'slate' && 'border-slate-200 text-slate-800',
              ]}
              aria-hidden="true"
            >
              {c.icon}
            </span>
            <p class="text-base font-extrabold text-slate-900">{c.name}</p>
          </div>
          <span class="rounded-full bg-white/70 px-3 py-1 text-xs font-semibold text-slate-700">ประเมินได้</span>
        </div>
        <p class="mt-3 text-sm leading-relaxed text-slate-700">{c.desc}</p>
        <div class="mt-auto pt-4 text-xs font-semibold text-slate-700">
          ดูรายละเอียด <span aria-hidden="true" class="inline-block transition-transform group-hover:translate-x-0.5">→</span>
        </div>
      </a>
    ))}
  </div>
</section>

