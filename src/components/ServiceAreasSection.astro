---
const locations = [
  { label: 'กรุงเทพ', href: '/รับซื้อโน๊ตบุ๊ค/กรุงเทพ' },
  { label: 'นนทบุรี', href: '/รับซื้อโน๊ตบุ๊ค/นนทบุรี' },
  { label: 'ปทุมธานี', href: '/รับซื้อโน๊ตบุ๊ค/ปทุมธานี' },
  { label: 'สมุทรปราการ', href: '/รับซื้อโน๊ตบุ๊ค/สมุทรปราการ' },
  { label: 'บางนา', href: '/รับซื้อโน๊ตบุ๊ค/บางนา' },
  { label: 'ลาดพร้าว', href: '/รับซื้อโน๊ตบุ๊ค/ลาดพร้าว' },
  { label: 'รังสิต', href: '/รับซื้อโน๊ตบุ๊ค/รังสิต' },
  { label: 'พระราม 2', href: '/รับซื้อโน๊ตบุ๊ค/พระราม2' },
  { label: 'รามคำแหง', href: '/รับซื้อโน๊ตบุ๊ค/รามคำแหง' },
  { label: 'ห้วยขวาง', href: '/รับซื้อโน๊ตบุ๊ค/ห้วยขวาง' },
];
---

<section class="mx-auto w-full max-w-6xl px-4 pt-12">
  <div class="rounded-3xl border border-slate-200 bg-gradient-to-br from-sky-50 via-white to-emerald-50 p-6 shadow-sm sm:p-8">
    <h2 class="text-xl font-extrabold text-slate-900">
      รับซื้อโน๊ตบุ๊ค กรุงเทพ ปริมณฑล ภาคอีสาน และพื้นที่ให้บริการอื่น ๆ
    </h2>
    <p class="mt-2 text-sm leading-relaxed text-slate-700">
      ให้บริการในกรุงเทพและปริมณฑล ทุกจังหวัดในภาคอีสาน รวมถึงสระแก้ว จันทบุรี ตราด พัทลุง ภูเก็ต และหาดใหญ่/สงขลา ดูรายละเอียดทั้งหมดได้ที่หน้า{' '}
      <a class="underline underline-offset-4" href="/พื้นที่ให้บริการ/">พื้นที่ให้บริการ</a>
    </p>
    <p class="mt-3 text-sm leading-relaxed text-slate-700">
      ในกรุงเทพและปริมณฑล เรารับซื้อและนัดดูตัวเครื่องในโซนยอดนิยม เช่น กรุงเทพ นนทบุรี ปทุมธานี สมุทรปราการ และพื้นที่ใกล้เคียง ลูกค้าสามารถส่งรูปประเมินราคาเบื้องต้นก่อนนัดรับหรือส่งเครื่องได้
    </p>

    <div class="mt-5 flex flex-wrap gap-2">
      {locations.map((l) => (
        <a
          href={l.href}
          class="rounded-full border border-slate-200 bg-white px-3 py-1.5 text-xs font-semibold text-slate-800 shadow-sm hover:bg-emerald-50 hover:border-emerald-200"
        >
          {l.label}
        </a>
      ))}
    </div>

    <p class="mt-4 text-xs text-slate-500">
      หมายเหตุ: ถ้าอยู่โซนอื่น ๆ (เช่น ภาคอีสาน/ตะวันออก/ใต้) ก็ส่งโลเคชันมาได้ เราช่วยแนะนำวิธีนัดรับ/ส่งเครื่องที่เหมาะที่สุด{' '}
      <a class="underline underline-offset-4" href="/พื้นที่ให้บริการ/">ดูพื้นที่ให้บริการทั้งหมด</a>
    </p>
  </div>
</section>

