---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAButtons from '../components/CTAButtons.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import TrustBadges from '../components/TrustBadges.astro';
import SafetySection from '../components/SafetySection.astro';
import FAQ from '../components/FAQ.astro';
import { SITE, absoluteUrl, breadcrumbListSchema, faqPageSchema, serviceSchema } from '../lib/seo';

const title = 'รับเหมาโน๊ตบุ๊ค รับซื้อโน๊ตบุ๊คบริษัท โละออฟฟิศ ให้ราคาสูง จ่ายเงินสด';
const description =
  'บริการรับเหมาโน๊ตบุ๊ค รับซื้อโน๊ตบุ๊คองค์กร บริษัท สำนักงาน ทุกสภาพ มีบริการล้างข้อมูลระดับมาตรฐาน ลบ Asset Tag ขนย้ายฟรี ตีราคาเหมาให้ราคาสูง จ่ายเงินสดทันที';
const canonical = absoluteUrl('/รับเหมาโน๊ตบุ๊ค/');

const breadcrumbs = [
  { name: 'หน้าแรก', url: absoluteUrl('/') },
  { name: 'รับเหมาโน๊ตบุ๊คองค์กร', url: canonical },
];

const faqs = [
  { question: 'รับเหมาโน๊ตบุ๊คขั้นต่ำกี่เครื่อง?', answer: 'เรารับเหมาตั้งแต่ 5 เครื่องขึ้นไป จนถึงหลัก 1,000 เครื่องครับ สามารถประเมินราคาเหมาล่วงหน้าได้ฟรีเพียงส่งรายการและสเปกมาให้เรา' },
  { question: 'โน๊ตบุ๊คเก่ามากๆ เสีย เปิดไม่ติด รับไหม?', answer: 'รับครับ ในกรณีรับเหมา เราพิจารณารับซื้อทุกสภาพ ทั้งเครื่องที่ใช้งานได้ปกติ เครื่องตกรุ่น และเครื่องเสีย เพื่อความสะดวกในการโละทรัพย์สินของบริษัทในครั้งเดียว' },
  { question: 'มีบริการล้างข้อมูลก่อนนำออกจากบริษัทหรือไม่?', answer: 'เรามีบริการล้างข้อมูล (Data Wiping) ด้วยมาตรฐานความปลอดภัย และสามารถออกใบรับรองการทำลายข้อมูลเพื่อป้องกันความลับบริษัทรั่วไหลได้ครับ' },
  { question: 'เครื่องติดรหัส BIOS หรือ MDM ของบริษัท รับไหม?', answer: 'เรารับซื้อครับ แต่ขอให้ทางบริษัทแจ้งรหัสปลดล็อค หรือให้ฝ่าย IT ช่วยทำการปลดล็อคระบบจัดการองค์กร (MDM) ก่อน เพื่อให้ได้ราคาประเมินที่สูงที่สุด' },
  { question: 'มีการรับลอก Asset Tag ออกให้ด้วยไหม?', answer: 'ทีมงานของเราจะจัดการลอกสติ๊กเกอร์ ทรัพย์สิน (Asset Tag) และทำความสะอาดตัวเครื่องให้ทั้งหมดครับ คุณไม่ต้องกังวลเรื่องการติดตามรอยเครื่องกลับมายังบริษัท' },
];

const schemas = [
  breadcrumbListSchema(breadcrumbs),
  faqPageSchema(faqs),
  serviceSchema({
    name: 'บริการรับเหมาโน๊ตบุ๊คระดับองค์กร (B2B ITAD)',
    url: canonical,
    description: 'รับเหมาซื้อโน๊ตบุ๊คสำนักงาน โละสต็อกบริษัท รับซื้อคอมพิวเตอร์พกพาองค์กรจำนวนมาก',
  })
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemas={schemas}>
  <!-- Hero Section -->
  <section class="relative mx-auto w-full max-w-6xl px-4 pt-12 pb-8 sm:pt-20 lg:pt-24 lg:pb-16 text-center">
    <div class="inline-flex items-center rounded-full bg-blue-100 px-3 py-1 text-sm font-semibold text-blue-800 ring-1 ring-inset ring-blue-600/20 mb-6">
      💼 B2B Corporate Services - บริการสำหรับองค์กร
    </div>
    <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl max-w-4xl mx-auto leading-tight">
      รับเหมาโน๊ตบุ๊ค <br class="hidden sm:block" /> <span class="text-blue-700">โละโน๊ตบุ๊คออฟฟิศ ให้ราคาสูง</span>
    </h1>
    <p class="mt-6 text-lg leading-relaxed text-slate-600 max-w-3xl mx-auto font-medium">
      บริการรับซื้อโน๊ตบุ๊คจำนวนมากจากองค์กร บริษัท ราชการ และสถานศึกษา หมดปัญหาเรื่องการจัดเก็บและเสื่อมราคา เคลียร์พื้นที่ไว พร้อมการจัดการข้อมูลระดับองค์กร (Data Destruction) ขนย้ายฟรี ทุนหนาจ่ายสดทันที 
    </p>

    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        class="inline-flex w-full sm:w-auto items-center justify-center gap-2 rounded-full bg-blue-700 px-8 py-4 text-base font-extrabold text-white shadow-lg shadow-blue-500/30 hover:bg-blue-800 transition-all hover:scale-105"
        href={SITE.lineUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        ส่งลิสต์สเปกประเมินราคาเหมา
      </a>
      <a
        class="inline-flex w-full sm:w-auto items-center justify-center gap-2 rounded-full bg-slate-900 px-8 py-4 text-base font-extrabold text-white shadow-lg hover:bg-slate-800 transition-all"
        href={`tel:${SITE.phone.replace(/[^0-9]/g, '')}`}
      >
        ติดต่อฝ่าย B2B: {SITE.phone}
      </a>
    </div>
  </section>

  <TrustBadges />

  <!-- Comprehensive Content Section -->
  <section class="bg-white py-16">
    <div class="mx-auto max-w-4xl px-4 prose prose-lg prose-slate prose-headings:font-extrabold prose-headings:text-slate-900 prose-a:text-blue-600">
      
      <h2>ปัญหาของการเก็บโน๊ตบุ๊คเก่าไว้ในบริษัท</h2>
      <p>
        เมื่อถึงรอบการอัปเกรดอุปกรณ์ไอทีประจำปี (IT Refresh Cycle) หลายบริษัทมักพบกับปัญหาใหญ่คือ <strong>"โน๊ตบุ๊คเครื่องเก่าที่ถูกปลดระวาง"</strong> ไม่รู้จะจัดการอย่างไร การเก็บเครื่องเก่าเหล่านี้ไว้ในห้องเก็บขององค์กร นอกจากจะใช้พื้นที่เปล่าประโยชน์แล้ว ยังทำให้มูลค่าของอุปกรณ์ลดลงตามกาลเวลา (Depreciation) อย่างรวดเร็ว นอกจากนี้ หากไม่มีการจัดการข้อมูลภายในตัวเครื่องที่ถูกต้อง อาจสุ่มเสี่ยงต่อการที่ความลับทางธุรกิจและข้อมูลส่วนบุคคล (PDPA) รั่วไหลออกไปได้
      </p>
      <p>
        บริการ <strong>รับเหมาโน๊ตบุ๊ค (IT Asset Disposition - ITAD)</strong> ของเรา จึงเข้ามาแก้ปัญหานี้โดยตรง เราคือผู้รับซื้อเครื่องคอมพิวเตอร์พกพาจำนวนมากที่เชี่ยวชาญการทำงานร่วมกับองค์กรขนาดใหญ่ ไม่ว่าคุณจะมีเครื่องหลักสิบ หลักร้อย หรือหลักพันเครื่อง เรามีกระบวนการประเมินราคาที่เป็นธรรม รวดเร็ว และเป็นระบบ
      </p>

      <h3>ทำไมบริษัทชั้นนำถึงเลือกใช้บริการรับเหมาโน๊ตบุ๊คของเรา?</h3>
      <ul>
        <li><strong>ประเมินราคาสูง ยุติธรรม:</strong> เราไม่ได้เหมากิโลขาย แต่เราคำนวณราคาจากสเปก ชิปประมวลผล (CPU) และสภาพการใช้งานจริง ทำให้บริษัทของคุณได้รับเงินคืน (Return on Investment) อย่างคุ้มค่าที่สุด</li>
        <li><strong>ความปลอดภัยของข้อมูลอันดับ 1:</strong> เราให้ความสำคัญกับการลบข้อมูลในฮาร์ดดิสก์และ SSD ด้วยซอฟต์แวร์ระดับมาตรฐาน เพื่อให้แน่ใจว่าข้อมูลทางธุรกิจของคุณถูกลบอย่างถาวร (Secure Data Wiping)</li>
        <li><strong>ปลดระวาง Asset Tag รัดกุม:</strong> อุปกรณ์องค์กรมักมีสติ๊กเกอร์รหัสทรัพย์สิน (Asset Tag) ติดอยู่ เรามีทีมงานลอกสติ๊กเกอร์และทำความสะอาดคราบกาวอย่างมืออาชีพ ป้องกันไม่ให้เกิดการสืบย้อนกลับมายังองค์กรของคุณ</li>
        <li><strong>รับซื้อทุกสภาพ (All Conditions Accepted):</strong> หมดปัญหาต้องแยกเครื่องขาย เราเหมาจบในครั้งเดียว ทั้งเครื่องดี เครื่องที่แบตเตอรี่เสื่อม หน้าจอมีปัญหา หรือแม้กระทั่งเครื่องที่เมนบอร์ดพังเปิดไม่ติด</li>
        <li><strong>โลจิสติกส์ครบวงจร ขนย้ายฟรี:</strong> มีทีมงานพร้อมแพ็คและรถขนส่งเข้าไปรับของถึงสถานที่ทำงาน ไม่ว่าจะเป็นอาคารสำนักงานใจกลางกรุง นิคมอุตสาหกรรม หรือต่างจังหวัด อำนวยความสะดวกสูงสุดแก่ฝ่าย IT และฝ่ายจัดซื้อ</li>
        <li><strong>จ่ายเงินสดทันที มีเอกสารครบ:</strong> เมื่อตรวจนับจำนวนและสภาพเบื้องต้นตรงตามตกลง เราพร้อมทำธุรกรรมโอนเงินหรือจ่ายเงินสดทันที ไม่มียืดเยื้อ และสามารถออกเอกสารใบเสร็จรับเงินหรือหนังสือสัญญาซื้อขายได้อย่างถูกต้องตามกระบวนการทางบัญชีและกฎหมาย</li>
      </ul>

      <h2>กระบวนการรับเหมาที่โปร่งใส (Our B2B Process)</h2>
      <p>
        การทำงานกับลูกค้าระดับองค์กร เราเน้นกระบวนการที่รวดเร็ว ตรวจสอบได้ และลดภาระของฝั่งผู้ขายให้มากที่สุด โดยมีขั้นตอนง่ายๆ ดังนี้:
      </p>
      <ol>
        <li><strong>จัดทำรายการ (Inventory List):</strong> ฝ่าย IT ของท่านสามารถรวบรวมรายการสเปกโน๊ตบุ๊ค (Brand, Model, CPU, RAM, HDD/SSD) พร้อมระบุสภาพคร่าวๆ และส่งไฟล์ Excel มาให้ทีมงานของเราทาง LINE หรืออีเมล</li>
        <li><strong>ประเมินราคาเบื้องต้น (Quotation):</strong> ทีมงานจะทำการวิเคราะห์ราคาจากฐานข้อมูลราคากลาง และส่งใบเสนอราคารับเหมากลับไปให้ท่านพิจารณาภายใน 24-48 ชั่วโมง</li>
        <li><strong>นัดหมายดูหน้างาน (On-site Inspection):</strong> หากท่านพึงพอใจในกรอบราคาเบื้องต้น เราจะนัดหมายส่งทีมงานเข้าไปสุ่มตรวจสภาพเครื่องจริงที่สำนักงานของท่าน เพื่อยืนยันราคาตกลงขั้นสุดท้าย</li>
        <li><strong>ทำสัญญาและขนย้าย:</strong> เมื่อบรรลุข้อตกลง จะมีการเซ็นเอกสารซื้อขายอย่างถูกต้อง ทีมงานของเราจะดำเนินการขนย้ายอุปกรณ์ทั้งหมดขึ้นรถอย่างระมัดระวัง</li>
        <li><strong>ชำระเงินและจัดการข้อมูล:</strong> ทางเราจะชำระเงินเต็มจำนวนตามเงื่อนไขที่ตกลงกันไว้ (เงินสด/โอนเข้าบัญชีบริษัท) จากนั้นโน๊ตบุ๊คจะถูกนำกลับไปยังศูนย์ปฏิบัติการของเราเพื่อทำการลบข้อมูลขั้นเด็ดขาด (Data Sanitization) ต่อไป</li>
      </ol>

      <div class="bg-blue-50 border-l-4 border-blue-600 p-6 my-8 rounded-r-lg">
        <h4 class="text-blue-900 mt-0">ติดต่อขอใบเสนอราคา (Request for Proposal)</h4>
        <p class="text-blue-800 mb-0">
          ไม่ว่าบริษัทของคุณกำลังจะย้ายออฟฟิศ, อัปเกรดเครื่องพนักงาน, หรือปิดแผนกกะทันหัน อย่าปล่อยให้โน๊ตบุ๊คกลายเป็นขยะอิเล็กทรอนิกส์ (e-Waste) ที่ไร้มูลค่า ติดต่อเราวันนี้เพื่อเปลี่ยนอุปกรณ์ไอทีเก่าให้เป็นเงินหมุนเวียนในบริษัทอย่างรวดเร็ว โทรศัพท์: <strong>{SITE.phone}</strong>
        </p>
      </div>

    </div>
  </section>

  <!-- Process & Safety integration -->
  <div class="bg-slate-50 py-12 border-t border-slate-100">
    <SafetySection />
  </div>

  <section class="mx-auto w-full max-w-6xl px-4 py-16">
    <FAQ faqs={faqs} />
  </section>

</BaseLayout>
