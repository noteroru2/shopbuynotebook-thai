---
import BaseLayout from '../layouts/BaseLayout.astro';
import { absoluteUrl } from '../lib/seo';

const title = 'นโยบายความเป็นส่วนตัว | ร้านรับซื้อโน๊ตบุ๊ค.com';
const description =
  'นโยบายความเป็นส่วนตัวของร้านรับซื้อโน๊ตบุ๊ค.com อธิบายการเก็บและใช้ข้อมูลเมื่อคุณส่งข้อมูลผ่าน LINE เพื่อประเมินราคาโน๊ตบุ๊ค';
const canonical = absoluteUrl('/นโยบายความเป็นส่วนตัว/');
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <article class="mx-auto w-full max-w-4xl px-4 pt-10 prose prose-slate prose-headings:tracking-tight">
    <h1>นโยบายความเป็นส่วนตัว</h1>
    <p>
      เอกสารนี้เป็นนโยบายความเป็นส่วนตัวสำหรับเว็บไซต์ “ร้านรับซื้อโน๊ตบุ๊ค.com” โดยมีจุดประสงค์เพื่ออธิบายว่าข้อมูลใดอาจถูกเก็บ
      และนำไปใช้อย่างไร เมื่อคุณติดต่อเราเพื่อประเมินราคาโน๊ตบุ๊คหรือใช้บริการรับซื้อ
    </p>

    <h2>ข้อมูลที่เราอาจเก็บ</h2>
    <ul>
      <li>ข้อมูลติดต่อ เช่น ชื่อ เบอร์โทร LINE ID</li>
      <li>ข้อมูลเกี่ยวกับเครื่อง เช่น ยี่ห้อ รุ่น สเปก สภาพ อาการ และรูปภาพประกอบ</li>
      <li>ข้อมูลการใช้งานเว็บไซต์แบบไม่ระบุตัวตน (ถ้ามีการติดตั้งเครื่องมือวิเคราะห์ภายหลัง)</li>
    </ul>

    <h2>วัตถุประสงค์ในการใช้ข้อมูล</h2>
    <ul>
      <li>เพื่อประเมินราคาและติดต่อกลับเกี่ยวกับการรับซื้อ</li>
      <li>เพื่อปรับปรุงคุณภาพการให้บริการและประสบการณ์ใช้งาน</li>
      <li>เพื่อป้องกันสแปม/การใช้งานที่ผิดปกติ</li>
    </ul>

    <h2>การเปิดเผยข้อมูล</h2>
    <p>
      เราไม่ขายข้อมูลส่วนบุคคลให้บุคคลที่สาม. ข้อมูลที่คุณส่งมาจะถูกใช้เพื่อประเมินราคาและการติดต่อกลับตามวัตถุประสงค์เท่านั้น
    </p>

    <h2>การเก็บรักษาข้อมูล</h2>
    <p>
      เราจะเก็บข้อมูลเท่าที่จำเป็นตามวัตถุประสงค์ของการให้บริการ และลบ/ทำให้ไม่สามารถระบุตัวตนได้เมื่อไม่จำเป็นอีกต่อไป
    </p>

    <h2>ข้อควรระวังเมื่อส่งรูปเครื่อง</h2>
    <p>
      รูปเครื่องอาจมีข้อมูลส่วนตัวบางอย่าง เช่น ชื่อผู้ใช้ เอกสารในพื้นหลัง หรือสติ๊กเกอร์ที่มีเลขประจำเครื่อง. แนะนำหลีกเลี่ยงการส่งภาพที่มีข้อมูลอ่อนไหว
      และส่งเฉพาะรูปที่จำเป็นต่อการประเมินราคา (ตัวเครื่อง/หน้าจอ/สเปก/อาการ) เพื่อความเป็นส่วนตัวของคุณ
    </p>

    <h2>การติดต่อ</h2>
    <p>
      หากมีคำถามเกี่ยวกับนโยบายความเป็นส่วนตัว สามารถติดต่อได้ที่หน้า <a href="/ติดต่อเรา/">ติดต่อเรา</a>
    </p>
  </article>
</BaseLayout>

