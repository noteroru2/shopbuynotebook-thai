---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import MiniProcessBarDark from '../components/MiniProcessBarDark.astro';
import TrustBadges from '../components/TrustBadges.astro';
import SeoIntroSection from '../components/SeoIntroSection.astro';
import SoftImageStrip from '../components/SoftImageStrip.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import BrandGrid from '../components/BrandGrid.astro';
import NotebookTypesSection from '../components/NotebookTypesSection.astro';
import ConditionGrid from '../components/ConditionGrid.astro';
import PriceFactors from '../components/PriceFactors.astro';
import HomeConditionPricingSection from '../components/HomeConditionPricingSection.astro';
import HomeNotebookTerminologySection from '../components/HomeNotebookTerminologySection.astro';
import HomeSellPrepSection from '../components/HomeSellPrepSection.astro';
import PhotoGuide from '../components/PhotoGuide.astro';
import TrustGallery from '../components/TrustGallery.astro';
import ReviewCards from '../components/ReviewCards.astro';
import HomeCaseStudies from '../components/HomeCaseStudies.astro';
import SafetySection from '../components/SafetySection.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import FAQ from '../components/FAQ.astro';
import CTAButtons from '../components/CTAButtons.astro';
import FinalCtaBanner from '../components/FinalCtaBanner.astro';
import ServiceAreasSection from '../components/ServiceAreasSection.astro';
import PopularServicesLinks from '../components/PopularServicesLinks.astro';
import HomeFeaturedArticles from '../components/HomeFeaturedArticles.astro';
import { getCollection } from 'astro:content';
import { HOME_FEATURED_BLOG_SLUGS } from '../data/home-featured-blog';
import { faqPageSchema, absoluteUrl } from '../lib/seo';
import { itemListSchema } from '../lib/schema';

const title = 'รับซื้อโน๊ตบุ๊ค ประเมินฟรี จ่ายเงินสด | ร้านรับซื้อโน๊ตบุ๊ค.com';
const description =
  'ร้านรับซื้อโน๊ตบุ๊ค รับซื้อ Notebook มือสองหลายยี่ห้อ ประเมินตามสภาพจริงผ่าน LINE แจ้งราคาก่อนตัดสินใจขาย จ่ายเงินสดหรือโอน รับ MacBook Gaming และเครื่องเสียบางอาการ';

const toSlug = (p: { id: string; data: { slug?: string } }) =>
  p.data.slug ? p.data.slug : String(p.id).replace(/\.(md|mdx)$/i, '');

const allBlogPosts = await getCollection('blog');
const postBySlug = new Map(allBlogPosts.map((p) => [toSlug(p), p]));
const homeFeaturedPosts = HOME_FEATURED_BLOG_SLUGS.map((s) => postBySlug.get(s)).filter(Boolean);
const featuredArticleListItems = homeFeaturedPosts.map((p) => ({
  name: p.data.title,
  url: absoluteUrl(`/blog/${toSlug(p)}/`),
}));

const heroImageSrc = '/images/home/rubsue-notebook-hero-team-640.webp';
const heroImageSrcset =
  '/images/home/rubsue-notebook-hero-team-640.webp 640w, /images/rubsue-notebook-hero-team.webp 1024w';
const heroImageSizes = '(max-width: 767px) 100vw, (max-width: 1023px) 50vw, 480px';

const faqs = [
  {
    question: 'รับซื้อโน๊ตบุ๊คเสียไหม?',
    answer:
      'รับครับ เรารับซื้อทั้งเครื่องใช้งานปกติและเครื่องเสีย “บางอาการ” เช่น เปิดไม่ติด จอแตก แบตเสื่อม คีย์บอร์ดบางปุ่มเสีย ราคาจะขึ้นกับรุ่น/สเปก/สภาพรวม และอุปกรณ์ที่มี',
  },
  {
    question: 'รับซื้อโน๊ตบุ๊คไม่มีที่ชาร์จไหม?',
    answer:
      'รับครับ แค่แจ้งว่าไม่มีที่ชาร์จเพื่อให้ประเมินตรงขึ้น ราคามักปรับตามความครบของอุปกรณ์ แต่ยังรับซื้อได้ตามสภาพจริง',
  },
  {
    question: 'เช็คราคาโน๊ตบุ๊คก่อนขายได้ไหม?',
    answer:
      'ได้ครับ ส่งรูป + รุ่น + สเปก + สภาพ/อาการ (ถ้ามี) มาทาง LINE เราช่วยเช็คราคาและประเมินเบื้องต้นให้ฟรี',
  },
  {
    question: 'ขายโน๊ตบุ๊คมือสองต้องเตรียมอะไร?',
    answer:
      'แนะนำเตรียมรูปเครื่องชัด ๆ 3–5 รูป แจ้งรุ่น/สเปก อุปกรณ์ที่มี (ที่ชาร์จ/กล่อง/ใบเสร็จถ้ามี) และอาการที่พบ ถ้าล้างข้อมูลได้ก่อนจะช่วยให้ปิดงานเร็วขึ้น',
  },
  {
    question: 'รับซื้อโน๊ตบุ๊คถึงที่ไหม?',
    answer:
      'แล้วแต่พื้นที่และเงื่อนไขครับ บางพื้นที่สามารถนัดรับได้ หรือเลือกส่งเครื่องผ่านขนส่ง/นัดเจอจุดที่สะดวก เพื่อให้เหมาะกับเคสของคุณ',
  },
  {
    question: 'ประเมินราคาโน๊ตบุ๊คฟรีหรือไม่?',
    answer:
      'ฟรีครับ เราประเมินเบื้องต้นจากรูป/สเปก/สภาพ และจะแจ้งขั้นตอนให้ชัดเจนก่อนตกลงขายเสมอ',
  },
  {
    question: 'ก่อนขายโน๊ตบุ๊คต้องล้างข้อมูลไหม?',
    answer:
      'แนะนำให้สำรองข้อมูลและล้างเครื่องก่อนขายเสมอเพื่อความปลอดภัยของข้อมูลส่วนตัว หากไม่สะดวก เราช่วยแนะนำขั้นตอน reset/ล้างข้อมูลอย่างปลอดภัยตามระบบได้',
  },
  {
    question: 'เครื่องติดรหัสขายได้ไหม?',
    answer:
      'กรณีติดรหัส Windows/Apple ID ต้องปลดล็อกได้ก่อนเพื่อความถูกต้องในการรับซื้อ แนะนำเตรียมข้อมูลบัญชีเพื่อปลดก่อนนัดส่งเครื่อง',
  },
];

const schemas = [
  faqPageSchema(faqs),
  ...(featuredArticleListItems.length > 0
    ? [
        itemListSchema({
          name: 'บทความแนะนำเกี่ยวกับรับซื้อโน๊ตบุ๊ค เช็คราคา และประเมินราคา',
          url: absoluteUrl('/#featured-articles'),
          items: featuredArticleListItems,
        }),
      ]
    : []),
];
---
<BaseLayout
  title={title}
  description={description}
  schemas={schemas}
  lcpImageSrc={heroImageSrc}
  lcpImageSrcset={heroImageSrcset}
  lcpImageSizes={heroImageSizes}
>
  <div class="absolute inset-x-0 top-0 -z-10 h-[520px] bg-gradient-to-b from-slate-50/80 to-transparent"></div>
  <Hero
    title="รับซื้อโน๊ตบุ๊ค ประเมินฟรี จ่ายเงินสด"
    titleHtml={`<span class="block"><span class="bg-gradient-to-r from-emerald-600 to-sky-600 bg-clip-text text-transparent">รับซื้อโน๊ตบุ๊ค</span></span><span class="mt-1 block">ประเมินตามสภาพจริง <span class="relative inline-flex items-center rounded-full bg-[#FACC15]/45 px-3 py-1 text-slate-900">จ่ายเงินสด</span></span>`}
    subtitle="ส่งรูปเครื่องผ่าน LINE เพื่อเช็คราคาเบื้องต้นฟรี รับซื้อทั้งเครื่องดี เครื่องเก่า และเครื่องเสียบางอาการ"
    imageSrc={heroImageSrc}
    imageSrcset={heroImageSrcset}
    imageSizes={heroImageSizes}
    imageWidth={640}
    imageHeight={480}
    imageAlt="ทีมงานตรวจสภาพโน๊ตบุ๊คก่อนประเมินราคา"
  />
  <MiniProcessBarDark />

  <TrustBadges />
  <SeoIntroSection />
  <HomeFeaturedArticles />
  <SoftImageStrip />
  <ProcessSteps />
  <PhotoGuide />
  <BrandGrid />
  <NotebookTypesSection />
  <ConditionGrid />
  <PriceFactors />
  <HomeConditionPricingSection />
  <HomeNotebookTerminologySection />
  <HomeSellPrepSection />
  <TrustGallery />
  <ReviewCards />
  <HomeCaseStudies />
  <SafetySection />
  <WhyChooseUs />
  <FAQ faqs={faqs} />
  <ServiceAreasSection />
  <PopularServicesLinks />

  <section class="mx-auto w-full max-w-6xl px-4 pt-10" aria-labelledby="home-models-heading">
    <div class="rounded-2xl border border-emerald-200 bg-white px-6 py-6 sm:px-8">
      <h2 id="home-models-heading" class="text-xl font-extrabold text-slate-900">
        รุ่นที่รับประเมินบ่อยและเกณฑ์การพิจารณาเบื้องต้น
      </h2>
      <p class="mt-3 text-sm leading-relaxed text-slate-600">
        เราให้บริการประเมินราคารับซื้อโน๊ตบุ๊คมือสองโดยอิงตามสเปก สภาพการใช้งานจริง และกลไกราคาประเมินอ้างอิง โดยกลุ่มเครื่องยอดนิยมที่มีการส่งเช็คราคาบ่อย ได้แก่:
      </p>
      <ul class="mt-3 list-disc pl-5 text-sm text-slate-600 space-y-1">
        <li><strong>สายทำงานพรีเมียม:</strong> <a class="font-semibold text-emerald-700 underline" href="/รับซื้อโน๊ตบุ๊ค/dell-latitude/">Dell Latitude</a>, <a class="font-semibold text-emerald-700 underline" href="/รับซื้อโน๊ตบุ๊ค/lenovo/">Lenovo ThinkPad</a>, <a class="font-semibold text-emerald-700 underline" href="/รับซื้อโน๊ตบุ๊ค/hp-elitebook/">HP EliteBook</a> และ <a class="font-semibold text-emerald-700 underline" href="/รับซื้อโน๊ตบุ๊ค/asus-zenbook/">Asus ZenBook</a></li>
        <li><strong>สายเกมมิ่งและกราฟิก:</strong> <a class="font-semibold text-emerald-700 underline" href="/รับซื้อโน๊ตบุ๊ค/gaming/">Gaming Notebook</a> หลายรุ่นยอดนิยม เช่น <a class="font-semibold text-emerald-700 underline" href="/รับซื้อโน๊ตบุ๊ค/asus-tuf-a15-f15/">Asus TUF</a>, <a class="font-semibold text-emerald-700 underline" href="/รับซื้อโน๊ตบุ๊ค/lenovo-legion-5/">Lenovo Legion</a> และ <a class="font-semibold text-emerald-700 underline" href="/รับซื้อโน๊ตบุ๊ค/dell-g15-g16/">Dell G Series</a></li>
        <li><strong>สาย Apple:</strong> <a class="font-semibold text-emerald-700 underline" href="/รับซื้อโน๊ตบุ๊ค/macbook/">MacBook Air</a> และ MacBook Pro ชิป Apple Silicon</li>
      </ul>

      <h3 class="mt-6 text-base font-bold text-slate-900">ข้อมูลที่ควรส่งใน LINE @webuy เพื่อประเมินราคา</h3>
      <p class="mt-1 text-sm text-slate-600">
        เพื่อความรวดเร็ว แนะนำส่ง: 1) รูปตัวเครื่องรอบด้านตอนเปิดจอ 2) หน้าจอสเปก (ดูวิธีที่ <a class="text-emerald-700 underline" href="/blog/วิธีดูสเปก-cpu-ram-ssd-ของโน๊ตบุ๊ค/">วิธีดูสเปกโน๊ตบุ๊ค</a>) 3) ข้อมูลอาการเสื่อมเฉพาะจุด เช่น แบตเตอรี่เก็บไฟได้น้อยลง หรือหน้าจอมีรอยร้าว (ดูเพิ่มที่ <a class="text-emerald-700 underline" href="/รับซื้อโน๊ตบุ๊ค/จอแตก/">โน๊ตบุ๊คจอแตก</a>) และ 4) อุปกรณ์ที่มี เช่น สายชาร์จแท้ หรือกล่อง
      </p>

      <h3 class="mt-6 text-base font-bold text-slate-900">ตัวอย่างเคสประเมินราคา (จำลองสถานการณ์ทั่วไป)</h3>
      <div class="mt-3 grid gap-4 sm:grid-cols-3 text-sm text-slate-600">
        <div class="rounded-xl border border-slate-100 bg-slate-50/50 p-4">
          <p class="font-semibold text-slate-900">เคสที่ 1: โน๊ตบุ๊คทำงานปกติ</p>
          <p class="mt-1 text-xs">ThinkPad สภาพบอดี้มีรอยขนแมวเล็กน้อย จอแสดงผลปกติ อุปกรณ์สายชาร์จครบถ้วน แบตเตอรี่เสื่อมตามอายุการใช้งาน — <em>ประเมินตามราคาประเมินอ้างอิงเครื่องทำงานปกติโดยปรับลดส่วนต่างตามค่าชิ้นส่วนแบตเตอรี่</em></p>
        </div>
        <div class="rounded-xl border border-slate-100 bg-slate-50/50 p-4">
          <p class="font-semibold text-slate-900">เคสที่ 2: โน๊ตบุ๊คเล่นเกมสเปกสูง</p>
          <p class="mt-1 text-xs">Asus TUF สเปกการ์ดจอแยก บอดี้ภายนอกสมบูรณ์ มีฝุ่นสะสมในพัดลม หน้าจอปกติ มีสายชาร์จและกล่องตรงรุ่น — <em>ประเมินราคาประเมินอ้างอิงระดับสูงของรุ่นเนื่องจากอุปกรณ์เสริมครบและสภาพจอสมบูรณ์</em></p>
        </div>
        <div class="rounded-xl border border-slate-100 bg-slate-50/50 p-4">
          <p class="font-semibold text-slate-900">เคสที่ 3: โน๊ตบุ๊คชำรุดชิ้นส่วน</p>
          <p class="mt-1 text-xs">โน๊ตบุ๊คทั่วไปเปิดติดปกติ แต่หน้าจอร้าวบางส่วน อุปกรณ์สายชาร์จแท้ยังใช้งานได้ปกติ — <em>ประเมินโดยหักลบราคาตามต้นทุนชิ้นส่วนหน้าจอและค่าแรงช่างในการเปลี่ยนอะไหล่ของรุ่นนั้น ๆ</em></p>
        </div>
      </div>

      <p class="mt-4 text-xs text-slate-500">
        *การประเมินราคาเบื้องต้นผ่าน LINE เป็นไปเพื่ออำนวยความสะดวกในการตัดสินใจของผู้ขาย โดยไม่มีข้อผูกมัดหรือค่าใช้จ่ายใด ๆ ยินดีให้คำแนะนำตลอดเวลาทำการ*
      </p>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-10" aria-labelledby="partner-it-heading">
    <div class="rounded-2xl border border-slate-200 bg-slate-50/90 px-4 py-5 sm:px-6">
      <h2 id="partner-it-heading" class="text-lg font-extrabold text-slate-900">
        บริการรับซื้อสินค้าไอทีอื่นในเครือ
      </h2>
      <p class="mt-2 max-w-3xl text-sm leading-relaxed text-slate-600">
        หากคุณมีอุปกรณ์ไอทีอื่นนอกจากโน๊ตบุ๊ค เช่น คอมพิวเตอร์ iPhone iPad MacBook กล้อง หรือเลนส์ เรามีเว็บไซต์ในเครือที่แยกตามประเภทสินค้าและพื้นที่ให้บริการ
        — ดูรายการลิงก์ที่โปร่งใสและเลือกช่องทางที่เหมาะได้ที่หน้า{' '}
        <a class="font-semibold text-emerald-700 underline underline-offset-4 hover:text-emerald-800" href="/เว็บไซต์ในเครือ/">
          เว็บไซต์ในเครือทั้งหมด
        </a>
      </p>
    </div>
  </section>

  <FinalCtaBanner>
    <CTAButtons primaryText="แอดไลน์ @webuy ส่งรูปประเมินราคา" secondaryText="โทร" />
  </FinalCtaBanner>
</BaseLayout>
