---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAButtons from '../components/CTAButtons.astro';
import { SITE, absoluteUrl, breadcrumbListSchema } from '../lib/seo';

const title = 'ขั้นตอนและเงื่อนไขการให้บริการ | ร้านรับซื้อโน๊ตบุ๊ค.com';
const description =
  'อธิบายแบบเข้าใจง่าย: ประเมินราคาผ่าน LINE ราคาหลังตรวจเครื่องจริง การชำระเงิน และสิ่งที่ควรรู้ก่อนขายโน๊ตบุ๊คกับร้านรับซื้อโน๊ตบุ๊ค.com';
const canonical = absoluteUrl('/ขั้นตอนและเงื่อนไขการให้บริการ/');

const breadcrumbs = [
  { name: 'หน้าแรก', url: absoluteUrl('/') },
  { name: 'ขั้นตอนและเงื่อนไขการให้บริการ', url: canonical },
];

const schemas = [breadcrumbListSchema(breadcrumbs)];
---

<BaseLayout title={title} description={description} canonical={canonical} schemas={schemas}>
  <article class="mx-auto w-full max-w-4xl px-4 pt-10 prose prose-slate prose-headings:tracking-tight">
    <h1>ขั้นตอนและเงื่อนไขการให้บริการ (อ่านแบบสบาย ๆ)</h1>
    <p class="text-lg text-slate-600">
      หน้านี้สรุปให้ฟังแบบไม่เป็นทางการเกินไปครับ — เพื่อให้รู้ว่าก่อนและหลังตกลงขายเครื่อง เราทำงานยังไง อะไรปรับได้ อะไรควรเตรียม
      ถ้าข้อไหนยังสงสัย ทัก LINE <strong>{SITE.lineHandle}</strong> ถามได้เลย
    </p>

    <h2>ใครเป็นผู้ให้บริการ</h2>
    <p>
      เว็บ <strong>{SITE.name}</strong> ให้บริการภายใต้ <strong>{SITE.companyLegalName}</strong> ที่อยู่จดทะเบียน:{' '}
      {SITE.companyRegisteredAddress}
    </p>

    <h2>ขั้นตอนคร่าว ๆ (ไม่ต้องจำเป๊ะ)</h2>
    <ol>
      <li>
        <strong>ส่งข้อมูลมาก่อน</strong> — ส่งรูป + รุ่น/สเปก + สภาพหรืออาการเสีย (ถ้ามี) ทาง LINE หรือโทรคุยเบื้องต้น
      </li>
      <li>
        <strong>ประเมินเบื้องต้น</strong> — เราให้กรอบราคาหรือแนวทางจากข้อมูลที่ส่งมา <strong>ฟรี</strong> ยังไม่ถือว่าต้องขาย
      </li>
      <li>
        <strong>นัดดูเครื่องจริง / ส่งเครื่อง</strong> — ตามที่คุยกันในพื้นที่หรือช่องทางที่เหมาะกับเคส
      </li>
      <li>
        <strong>ตกลงราคาและจ่ายเงิน</strong> — เมื่อตรวจเครื่องจริงแล้วตกลงกัน จึงรับเครื่องและจ่ายตามที่คุย (เงินสดหรือโอน ตามดีลนั้น ๆ)
      </li>
    </ol>

    <h2>เรื่องราคา — พูดตรง ๆ</h2>
    <p>
      ราคาประเมินตอนส่งรูปเป็น <strong>แนวทาง</strong> จากข้อมูลที่เห็นในภาพ/ข้อความ ยังไม่เท่ากับการเปิดเครื่องดูทุกจุด
      พอเจอของจริง บางทีจะเจอรอย/อาการ/ของปลอม/อะไหล่ที่ไม่ตรงที่แจ้ง — ราคาสุดท้ายเลยอาจปรับขึ้นหรือลงให้สมเหตุผล เราจะอธิบายให้ฟังก่อนตัดสินใจ ไม่ใช่มากดราคาแบบไม่บอกเหตุผล
    </p>
    <p>
      ถ้าราคาหลังตรวจไม่โอเคสำหรับคุณ <strong>ไม่ซื้อก็ได้ครับ</strong> — เราไม่ได้คิดค่าประเมินเบื้องต้นจากการคุยทาง LINE ในทางที่ทำให้คุณต้องขาย
    </p>

    <h2>การชำระเงินและการส่งมอบเครื่อง</h2>
    <p>
      เมื่อตกลงราคาแล้ว เราจะรับเครื่องและจ่ายตามที่คุยกัน (มักเป็นเงินสดหรือโอน) ช่วงเวลาและวิธีส่งมอบขึ้นกับเคสและพื้นที่ — คุยให้ชัดก่อนส่งของหรือก่อนนัดหน้าร้านเสมอ
    </p>

    <h2>ข้อมูลและความปลอดภัย</h2>
    <p>
      แนะนำให้สำรองและล้างข้อมูลก่อนส่งมอบเครื่อง เพื่อความปลอดภัยของข้อมูลส่วนตัว หากยังไม่สะดวก เราช่วยแนะนำขั้นตอนเบื้องต้นได้ตามระบบ (ไม่ใช่คำสัญญาว่าจะลบได้ทุกกรณีในทันที — บางเคสขึ้นกับรหัส/บัญชีที่คุณถืออยู่)
    </p>
    <p>
      รายละเอียดการเก็บข้อมูลเมื่อคุณติดต่อเราอ่านได้ที่หน้า{' '}
      <a href="/นโยบายความเป็นส่วนตัว/">นโยบายความเป็นส่วนตัว</a>
    </p>

    <h2>สิ่งที่เราไม่รับหรือต้องเคลียร์ก่อน</h2>
    <ul>
      <li>เครื่องที่มีประเด็นผิดกฎหมาย หรือมีเหตุให้สงสัยว่าไม่ใช่ของคุณโดยชอบธรรม — เราขอไม่เข้าไปเกี่ยวข้อง</li>
      <li>
        เครื่องที่ติดล็อกสำคัญ เช่น Apple ID / Find My / PIN สำคัญที่ปลดไม่ได้ — ต้องจัดการให้ปลดได้ตามขั้นตอนของระบบก่อนรับซื้อ เพื่อความถูกต้องของทั้งสองฝ่าย
      </li>
    </ul>

    <h2>เคสตัวอย่างบนหน้าแรก</h2>
    <p>
      การ์ดเคสบางส่วนเป็นการสรุปจากการประเมินและการให้บริการจริง — ใช้ชื่อเล่นและซ่อนรายละเอียดที่ละเอียดอ่อน ไม่ได้คัดลอกข้อความรีวิวจาก Google มาวางทั้งดุ้น
      อยากอ่านความเห็นจากลูกค้าที่แผนที่ เปิดลิงก์ Google Maps จากหน้าเว็บได้เลย
    </p>

    <h2>เปลี่ยนแปลงหน้านี้</h2>
    <p>
      เราอาจปรับข้อความในหน้านี้เป็นครั้งคราวให้เข้ากับบริการจริง — เวอร์ชันที่เห็นบนเว็บถือเป็นตัวล่าสุด ถ้ามีข้อสงสัยเรื่องดีลของคุณโดยตรง ให้อิงการคุยทาง LINE/โทรเป็นหลัก
    </p>

    <div class="not-prose mt-10 rounded-3xl border border-slate-200 bg-slate-50 p-6">
      <p class="text-sm font-semibold text-slate-900">อยากเริ่มส่งรูปประเมินเลย?</p>
      <div class="mt-4">
        <CTAButtons />
      </div>
      <p class="mt-4 text-sm text-slate-600">
        หรือจะอ่านเพิ่มที่หน้า <a class="font-semibold text-emerald-700 underline" href="/ติดต่อเรา/">ติดต่อเรา</a> และ{' '}
        <a class="font-semibold text-emerald-700 underline" href="/คำถามที่พบบ่อย/">คำถามที่พบบ่อย</a>
      </p>
    </div>
  </article>
</BaseLayout>
