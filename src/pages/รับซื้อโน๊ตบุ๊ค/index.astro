---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQ from '../../components/FAQ.astro';
import SeoCTA from '../../components/SeoCTA.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import { absoluteUrl, breadcrumbListSchema, faqPageSchema } from '../../lib/seo';
import { generalFaqs, pricingFaqs, conditionFaqs } from '../../data/faqs';
import { SITE } from '../../config/site';

const title = 'รับซื้อโน๊ตบุ๊คทุกยี่ห้อ ประเมินฟรี | ร้านรับซื้อโน๊ตบุ๊ค.com';
const description =
  'รวมบริการรับซื้อโน๊ตบุ๊ค รับซื้อ Notebook, รับซื้อโน้ตบุ๊ก, MacBook, Gaming Notebook และเครื่องเสียบางอาการ ส่งรูปเช็คราคาโน๊ตบุ๊คฟรีผ่านไลน์ @webuy หรือโทร 0642579353';
const canonical = absoluteUrl('/รับซื้อโน๊ตบุ๊ค/');

const breadcrumbs = [
  { name: 'หน้าแรก', url: absoluteUrl('/') },
  { name: 'รับซื้อโน๊ตบุ๊ค', url: canonical },
];

const faqs = [...generalFaqs, ...pricingFaqs, ...conditionFaqs].slice(0, 8);

const schemas = [breadcrumbListSchema(breadcrumbs), faqPageSchema(faqs)];
---

<BaseLayout title={title} description={description} canonical={canonical} schemas={schemas}>
  <section class="mx-auto w-full max-w-6xl px-4 pt-10">
    <h1 class="text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">รับซื้อโน๊ตบุ๊คทุกยี่ห้อ ประเมินราคาฟรี</h1>
    <p class="mt-4 text-base leading-relaxed text-slate-600">
      หน้านี้เป็น “หน้า hub รวมบริการ” สำหรับคนที่ต้องการ <strong>รับซื้อโน๊ตบุ๊ค</strong> แบบจบไวและคุยง่าย โดยรวบรวมบริการหลักทั้งหมดของร้านไว้ในที่เดียว
      คุณสามารถเริ่มจากการส่งรูปเครื่องจริงพร้อมรุ่น/สเปก/สภาพ เพื่อเช็คราคาเบื้องต้นฟรีผ่าน LINE ก่อนตัดสินใจขาย
    </p>
    <p class="mt-4 text-base leading-relaxed text-slate-600">
      เรารับซื้อทั้งโน๊ตบุ๊คมือสองใช้งานปกติ เครื่องทำงานทั่วไป เครื่องเรียนออนไลน์ รวมถึง <strong>MacBook</strong> และ <strong>Gaming Notebook</strong>.
      กรณีเครื่องมีอาการเสียบางอย่าง เช่น เปิดไม่ติด จอแตก หรือแบตเสื่อม ก็ยังสามารถส่งข้อมูลมาประเมินได้ โดยยึดตามรุ่น สเปก สภาพ และราคาตลาดมือสองเป็นหลัก
    </p>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-10">
    <div class="rounded-3xl border border-slate-200 bg-slate-50 p-6 shadow-sm sm:p-8">
      <h2 class="text-xl font-extrabold text-slate-900">คำตอบสั้น (AEO): รับซื้อโน๊ตบุ๊คต้องทำยังไง</h2>
      <ol class="mt-4 space-y-2 text-sm text-slate-700">
        <li><strong>1)</strong> ส่งรูป 3–5 รูป + รุ่น/สเปก + สภาพ/อาการ เพื่อเช็คราคาเบื้องต้นฟรี</li>
        <li><strong>2)</strong> ตกลงเงื่อนไขและวิธีนัดรับ/ส่งเครื่องตามความสะดวก</li>
        <li><strong>3)</strong> รับเงินสด/โอนทันทีเมื่อรับเครื่องและตรวจสภาพตามข้อมูลที่ส่งไว้</li>
      </ol>
      <p class="mt-3 text-sm leading-relaxed text-slate-700">
        เริ่มได้เลยที่ไลน์ <strong>{SITE.lineHandle}</strong> หรือโทร <strong>{SITE.phone}</strong>
      </p>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-10">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
      <h2 class="text-xl font-extrabold text-slate-900">ส่งอะไรให้ประเมินไว (คัดลอกไปใช้ได้)</h2>
      <div class="mt-4 grid gap-4 lg:grid-cols-2">
        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4 text-sm leading-relaxed text-slate-800">
          ขอเช็คราคาโน๊ตบุ๊คครับ
          <br />รุ่น ______ (แนบรูปใต้เครื่อง)
          <br />CPU ______ / RAM ___GB / SSD ___GB / GPU ______ (ถ้ามี)
          <br />สภาพ: ใช้งานปกติ / มีรอย / แบตเสื่อม / จอมีเส้น / เปิดไม่ติด
          <br />อุปกรณ์: มีที่ชาร์จ / ไม่มีกล่อง (แจ้งตามจริง)
          <br />อยู่โซน ______
        </div>
        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4 text-sm leading-relaxed text-slate-800">
          ขอประเมินโน๊ตบุ๊คตามสภาพครับ
          <br />รุ่น ______ (แนบรูปใต้เครื่อง)
          <br />อาการ: ______ (เปิดไม่ติด/จอแตก/แบตบวม)
          <br />มีที่ชาร์จครับ (แนบรูป)
          <br />แนบวิดีโออาการ 5–10 วินาที (ถ้ามี)
          <br />อยู่โซน ______
        </div>
      </div>
      <p class="mt-4 text-sm leading-relaxed text-slate-700">
        ถ้าคุณส่งข้อมูลครบตั้งแต่ต้น เราจะประเมินได้ไวขึ้นมาก และลดการถามซ้ำหลายรอบ
      </p>
      <div class="mt-5">
        <SeoCTA heading="เริ่มส่งรูปประเมินราคา" description={`แอดไลน์ ${SITE.lineHandle} ส่งรูปเครื่อง รุ่น สเปก และสภาพ เพื่อเช็คราคาเบื้องต้นฟรี`} />
      </div>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-10">
    <div class="rounded-3xl border border-slate-200 bg-slate-50 p-6 shadow-sm sm:p-8">
      <h2 class="text-xl font-extrabold text-slate-900">ร้านรับซื้อโน๊ตบุ๊คสำหรับเครื่องใช้งานปกติและเครื่องเสียบางอาการ</h2>
      <p class="mt-3 text-sm leading-relaxed text-slate-700">
        เป้าหมายของหน้านี้คือช่วยให้คุณเลือก “ทางลัด” ที่เหมาะกับเคสของตัวเอง ไม่ว่าจะเป็นการ <strong>รับซื้อโน๊ตบุ๊คมือสอง</strong> สำหรับเครื่องใช้งานปกติ
        หรือการส่งประเมินสำหรับเครื่องที่มีอาการบางอย่าง เช่น <strong>รับซื้อโน๊ตบุ๊คเสีย</strong>, เปิดไม่ติด, จอแตก หรือแบตเสื่อม
        เราเน้นประเมินจากสภาพจริงและอธิบายเหตุผลของราคาแบบตรงไปตรงมา เพื่อให้คุณตัดสินใจง่ายก่อนนัดรับ/ส่งเครื่อง
      </p>
      <p class="mt-3 text-sm leading-relaxed text-slate-700">
        ถ้าต้องการเริ่มเร็วที่สุด แอดไลน์ <strong>{SITE.lineHandle}</strong> แล้วส่ง “รูปเครื่อง + รุ่น/สเปก + สภาพ” เพื่อให้เช็คราคาเบื้องต้นฟรี
        หรือโทร <strong>{SITE.phone}</strong> หากต้องการคุยก่อน
      </p>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-10">
    <div class="grid gap-4 lg:grid-cols-3">
      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm lg:col-span-2">
        <h2 class="text-xl font-extrabold text-slate-900">รับซื้อโน๊ตบุ๊คประเภทไหนบ้าง</h2>
        <p class="mt-3 text-sm leading-relaxed text-slate-700">
          เรารับซื้อโน๊ตบุ๊คหลากหลายประเภท ตั้งแต่เครื่องทำงานทั่วไป เครื่องเรียนออนไลน์ ไปจนถึงเครื่องสเปกสูง โดยจะพิจารณาจาก “รุ่น/สเปก/สภาพจริง” เป็นหลัก
          เพื่อให้สอดคล้องกับการใช้งานและตลาดมือสองในช่วงนั้น
        </p>
        <ul class="mt-3 list-disc pl-5 text-sm text-slate-700">
          <li>โน๊ตบุ๊คทำงานทั่วไป (Office/Business/Creator)</li>
          <li>Notebook มือสองสำหรับเรียน/ใช้งานเอกสาร</li>
          <li>MacBook (Air/Pro, Intel และ Apple Silicon)</li>
          <li>Gaming Notebook ที่มี GPU แยก</li>
          <li>เครื่องเก่า/ตกรุ่น ที่ยังมีมูลค่าตามสภาพ</li>
        </ul>
        <p class="mt-3 text-sm leading-relaxed text-slate-700">
          ถ้าเครื่องมีอาการบางอย่าง ก็ยังส่งประเมินได้ เช่น เปิดไม่ติด จอแตก แบตเสื่อม หรือไม่มีที่ชาร์จ (แจ้งให้ครบเพื่อประเมินตรงขึ้น)
        </p>
      </div>
      <aside class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-extrabold text-slate-900">สภาพเครื่องที่ส่งประเมินได้</h2>
        <ul class="mt-3 space-y-2 text-sm text-slate-700">
          <li class="flex gap-2"><span aria-hidden="true">✓</span> เปิดติด ใช้งานปกติ</li>
          <li class="flex gap-2"><span aria-hidden="true">✓</span> เครื่องเก่า/ตกรุ่น</li>
          <li class="flex gap-2"><span aria-hidden="true">✓</span> แบตเสื่อม/ชาร์จไม่เข้า (บางอาการ)</li>
          <li class="flex gap-2"><span aria-hidden="true">✓</span> จอมีตำหนิ/จอแตก (บางอาการ)</li>
          <li class="flex gap-2"><span aria-hidden="true">✓</span> เปิดไม่ติด/บูตไม่ขึ้น (บางอาการ)</li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-10">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
      <h2 class="text-xl font-extrabold text-slate-900">ปัจจัยที่ทำให้ราคาประเมินต่างกัน (สรุปแบบเข้าใจง่าย)</h2>
      <p class="mt-3 text-sm leading-relaxed text-slate-700">
        รุ่นเดียวกันอาจมีหลายสเปก และสภาพเล็ก ๆ บางจุดมีผลกับการใช้งานจริง เช่น จอ แบต และบานพับ ดังนั้นการประเมินจะดู “สเปก + สภาพ + อุปกรณ์”
        เพื่อให้ใกล้เคียงราคาตลาดมือสอง ณ ช่วงนั้น
      </p>
      <div class="mt-4 grid gap-4 lg:grid-cols-3">
        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
          <h3 class="text-base font-bold text-slate-900">สเปก</h3>
          <ul class="mt-2 list-disc pl-5 text-sm leading-relaxed text-slate-700">
            <li>CPU รุ่นเต็มและเจน</li>
            <li>RAM และ SSD ความจุ</li>
            <li>GPU (สำคัญมากสำหรับเกมมิ่ง)</li>
          </ul>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
          <h3 class="text-base font-bold text-slate-900">สภาพ</h3>
          <ul class="mt-2 list-disc pl-5 text-sm leading-relaxed text-slate-700">
            <li>จอมีเส้น/จุด/รอยร้าว</li>
            <li>แบตหมดไว/ต้องเสียบตลอด/แบตบวม</li>
            <li>บานพับหลวม บอดี้บุบ พอร์ตหลวม</li>
          </ul>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
          <h3 class="text-base font-bold text-slate-900">อุปกรณ์</h3>
          <ul class="mt-2 list-disc pl-5 text-sm leading-relaxed text-slate-700">
            <li>ที่ชาร์จมีผลมาก</li>
            <li>กล่อง/ใบเสร็จช่วยเพิ่มความมั่นใจ (ถ้ามี)</li>
            <li>อุปกรณ์เสริมอื่น ๆ แล้วแต่เคส</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-10">
    <div class="rounded-3xl border border-slate-200 bg-slate-50 p-6 shadow-sm sm:p-8">
      <h2 class="text-xl font-extrabold text-slate-900">ความปลอดภัยข้อมูลก่อนขาย</h2>
      <p class="mt-3 text-base leading-relaxed text-slate-700">
        คุณสามารถขอประเมินจากรูปก่อนโดยยังไม่ต้องล้างเครื่องทันที แต่ก่อนส่งมอบจริง แนะนำสำรองข้อมูลและล้างข้อมูลเพื่อความปลอดภัยเสมอ
        โดยเฉพาะบัญชีที่ผูกกับเครื่อง หากเป็น MacBook ต้องออก Apple ID และปิด Find My เพื่อไม่ให้ติดล็อกบัญชี
      </p>
      <p class="mt-3 text-sm leading-relaxed text-slate-700">
        อ่านต่อ: <a class="underline" href="/blog/ก่อนขายโน๊ตบุ๊คต้องล้างข้อมูลอย่างไร/">ก่อนขายโน๊ตบุ๊คต้องล้างข้อมูลอย่างไร</a>
      </p>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-10">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
      <h2 class="text-xl font-extrabold text-slate-900">เช็คราคาโน๊ตบุ๊คก่อนขายต้องส่งข้อมูลอะไร</h2>
      <p class="mt-3 text-sm leading-relaxed text-slate-700">
        เพื่อให้การ <strong>เช็คราคาโน๊ตบุ๊ค</strong> และ <strong>ประเมินราคาโน๊ตบุ๊ค</strong> ใกล้เคียงขึ้น แนะนำส่งข้อมูลแบบสั้น ๆ แต่ครบ:
        รูปเครื่องชัด ๆ 3–5 รูป + รุ่น/สเปก (ถ้าทราบ) + สภาพ/อาการ และอุปกรณ์ที่มี ข้อมูลเหล่านี้ช่วยให้ประเมินไวขึ้นและลดการถามซ้ำหลายรอบ
      </p>
      <ul class="mt-3 list-disc pl-5 text-sm text-slate-700">
        <li>ส่งรูปหน้าเครื่อง (เปิดจอถ้าได้) และรูปคีย์บอร์ด</li>
        <li>ส่งรูปฝาหลัง/สติ๊กเกอร์รุ่น หรือพิมพ์รุ่นเครื่อง</li>
        <li>แจ้ง CPU / RAM / SSD (ถ้าทราบ)</li>
        <li>แจ้งสภาพ/อาการ เช่น เปิดไม่ติด จอแตก แบตเสื่อม หรือไม่มีที่ชาร์จ</li>
        <li>แจ้งอุปกรณ์ที่มี เช่น ที่ชาร์จ กล่อง ใบเสร็จ (ถ้ามี)</li>
      </ul>
      <p class="mt-4 text-sm text-slate-700">
        ส่งข้อมูลผ่านไลน์ <strong>{SITE.lineHandle}</strong> ได้เลย หรือโทร <strong>{SITE.phone}</strong> ถ้าต้องการคุยก่อน
      </p>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-10">
    <div class="rounded-3xl border border-slate-200 bg-slate-50 p-6 shadow-sm sm:p-8">
      <h2 class="text-xl font-extrabold text-slate-900">พื้นที่ให้บริการรับซื้อโน๊ตบุ๊ค</h2>
      <p class="mt-3 text-sm leading-relaxed text-slate-700">
        เราให้บริการหลายโซน เช่น กรุงเทพและปริมณฑล รวมถึงโซนภาคอีสานและพื้นที่อื่น ๆ ตามที่ระบุไว้ในหน้า <a class="underline" href="/พื้นที่ให้บริการ/">พื้นที่ให้บริการ</a>.
        ไม่ว่าคุณจะอยู่พื้นที่ไหน แนะนำส่งโลเคชันพร้อมรูปเครื่องเพื่อให้เราแนะนำวิธีนัดรับ/ส่งเครื่องที่เหมาะที่สุด
      </p>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-10">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
      <h2 class="text-xl font-extrabold text-slate-900">เลือกขายกับร้านรับซื้อหรือขายเอง ควรคิดจากอะไร</h2>
      <p class="mt-3 text-base leading-relaxed text-slate-700">
        การขายโน๊ตบุ๊คมือสองมีหลายช่องทาง และไม่มีคำตอบเดียวที่ถูกที่สุดสำหรับทุกคน เพราะเป้าหมายไม่เหมือนกัน บางคนอยากได้เงินเร็วและไม่อยากคุยซ้ำหลายรอบ บางคนอยากได้ราคาสูงสุดถึงแม้จะต้องใช้เวลานานขึ้น
