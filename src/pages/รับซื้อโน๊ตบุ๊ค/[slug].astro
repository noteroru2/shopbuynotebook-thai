---
import BrandLayout from '../../layouts/BrandLayout.astro';
import LocationLayout from '../../layouts/LocationLayout.astro';
import CTAButtons from '../../components/CTAButtons.astro';
import FAQ from '../../components/FAQ.astro';
import ProcessSteps from '../../components/ProcessSteps.astro';
import PriceFactors from '../../components/PriceFactors.astro';
import { getCollection, render } from 'astro:content';
import { absoluteUrl } from '../../lib/seo';
import { SITE } from '../../lib/seo';

export async function getStaticPaths() {
  const [brands, conditions, locations] = await Promise.all([
    getCollection('brands'),
    getCollection('conditions'),
    getCollection('locations'),
  ]);

  const all = [
    ...brands.map((e) => ({ kind: 'brand' as const, entry: e })),
    ...conditions.map((e) => ({ kind: 'condition' as const, entry: e })),
    ...locations.map((e) => ({ kind: 'location' as const, entry: e })),
  ];

  return all.map(({ kind, entry }) => ({
    params: { slug: entry.data.slug },
    props: { kind, entry },
  }));
}

const { kind, entry } = Astro.props as { kind: 'brand' | 'condition' | 'location'; entry: any };
const { Content } = await render(entry);

const slug = entry.data.slug;
const canonical = absoluteUrl(`/รับซื้อโน๊ตบุ๊ค/${slug}/`);

const breadcrumbs = [
  { name: 'หน้าแรก', url: absoluteUrl('/') },
  { name: 'รับซื้อโน๊ตบุ๊ค', url: absoluteUrl('/รับซื้อโน๊ตบุ๊ค/') },
  { name: entry.data.title, url: canonical },
];

const layoutTitle = `${entry.data.title} | ร้านรับซื้อโน๊ตบุ๊ค.com`;
const description = entry.data.description;
const ogImage = entry.data.featuredImage ? absoluteUrl(entry.data.featuredImage) : undefined;
const faqs = entry.data.faqs ?? [];

const internalLinks = [
  { label: 'รับซื้อโน๊ตบุ๊ค (รวมบริการ)', href: '/รับซื้อโน๊ตบุ๊ค/' },
  { label: 'รับซื้อโน๊ตบุ๊คมือสอง', href: '/รับซื้อโน๊ตบุ๊คมือสอง/' },
  { label: 'เช็คราคาโน๊ตบุ๊ค', href: '/เช็คราคาโน๊ตบุ๊ค/' },
  { label: 'ตีราคาโน๊ตบุ๊ค', href: '/ตีราคาโน๊ตบุ๊ค/' },
  { label: 'ขายโน๊ตบุ๊ค', href: '/ขายโน๊ตบุ๊ค/' },
];

const prepChecklist = [
  'ถ่ายรูป 3–5 รูป (หน้าเครื่อง/คีย์บอร์ด/ฝาหลัง/อุปกรณ์)',
  'แจ้งรุ่น/สเปก (CPU, RAM, SSD, GPU) และปีโดยประมาณ',
  'แจ้งสภาพ/อาการที่พบแบบตรงไปตรงมา',
  'เตรียมที่ชาร์จ/กล่อง/ใบเสร็จ (ถ้ามี) เพื่อประเมินแม่นขึ้น',
  'สำรองข้อมูลและล้างเครื่องก่อนขายเพื่อความปลอดภัย',
];

const conditionCauseMap: Record<string, string[]> = {
  'เปิดไม่ติด': ['อะแดปเตอร์/สายชาร์จมีปัญหา', 'แบตเสื่อมหรือมีอาการบวม', 'เมนบอร์ด/ภาคจ่ายไฟ', 'RAM/SSD หลวม/เสีย', 'ระบบค้าง/บูตไม่ขึ้น'],
  'จอแตก': ['กระแทกหรือกดทับ', 'จอเป็นเส้น/จอดำบางส่วน', 'บานพับฝืดทำให้จอเสียหาย', 'สายแพรจอมีปัญหา'],
  'แบตเสื่อม': ['แบตหมดไว/ชาร์จไม่เข้า', 'แบตบวม', 'สุขภาพแบตต่ำ', 'อะแดปเตอร์ไม่ตรงสเปก'],
  'ไม่มีที่ชาร์จ': ['ต้องใช้ที่ชาร์จแท้/เทียบที่เหมาะสม', 'ประเมินอาจปรับตามความครบอุปกรณ์', 'แจ้งรุ่นหัวชาร์จ/Type-C ได้จะช่วยมาก'],
  'เครื่องเก่า': ['สเปกเก่าแต่ยังใช้งานได้', 'อัปเกรด SSD/RAM ช่วยเพิ่มมูลค่า', 'สภาพภายนอกและแบตมีผลมาก'],
  'ตกรุ่น': ['รุ่นเก่า/เปลี่ยนเครื่องใหม่', 'ราคาขึ้นกับสเปกและความต้องการตลาด', 'อุปกรณ์ครบช่วยให้ปิดงานไว'],
  'เครื่องเสีย': ['อาการหลากหลาย ควรส่งวิดีโอ/รูปให้เห็นชัด', 'สภาพบอร์ด/จอ/แบต/พอร์ตมีผลต่อราคา', 'รับซื้อได้ถ้าแจ้งอาการตรงไปตรงมา'],
};
---

{kind === 'location' ? (
  <LocationLayout
    title={layoutTitle}
    description={description}
    canonical={canonical}
    ogImage={ogImage}
    breadcrumbs={breadcrumbs}
    faqs={faqs}
    serviceName={`รับซื้อโน๊ตบุ๊ค ${entry.data.title}`}
  >
    <section class="mx-auto w-full max-w-6xl px-4 pt-10">
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
        รับซื้อโน๊ตบุ๊ค {entry.data.title} ประเมินไว จ่ายเงินสด
      </h1>
      <p class="mt-4 text-base leading-relaxed text-slate-600">{description}</p>
      <p class="mt-4 text-base leading-relaxed text-slate-600">
        ถ้าต้องการเช็คราคาไว แนะนำส่งรูป 3–5 รูป + รุ่น/สเปก + สภาพ/อาการ ผ่าน LINE ก่อนนัดรับหรือส่งเครื่อง
        เพื่อให้ประเมินเบื้องต้นได้ตรงขึ้นและลดเวลาหน้างาน
      </p>

      <div class="mt-6 rounded-3xl border border-slate-200 bg-slate-50 p-6">
        <h2 class="text-lg font-bold text-slate-900">นัดรับ/นัดเจอในพื้นที่</h2>
        <ul class="mt-3 list-disc pl-5 text-sm text-slate-700">
          {(entry.data.meetingOptions ?? []).map((m: string) => (
            <li>{m}</li>
          ))}
        </ul>
        <div class="mt-4">
          <CTAButtons primaryText="แอดไลน์ @webuy ส่งรูปประเมินราคา" secondaryText="โทร" />
        </div>
      </div>
    </section>

    <section class="mx-auto w-full max-w-6xl px-4 pt-12">
      <div class="grid gap-4 lg:grid-cols-3">
        <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
          <h2 class="text-lg font-bold text-slate-900">พื้นที่ย่อย</h2>
          <ul class="mt-3 list-disc pl-5 text-sm text-slate-700">
            {(entry.data.subAreas ?? []).map((a: string) => (
              <li>{a}</li>
            ))}
          </ul>
        </div>
        <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm lg:col-span-2">
          <h2 class="text-lg font-bold text-slate-900">จุดเด่นของพื้นที่</h2>
          <ul class="mt-3 list-disc pl-5 text-sm text-slate-700">
            {(entry.data.highlights ?? []).map((h: string) => (
              <li>{h}</li>
            ))}
          </ul>
          <p class="mt-4 text-sm text-slate-600">
            หมายเหตุ: เนื้อหาพื้นที่ถูกเขียนให้ไม่ซ้ำกันเป๊ะ เพื่อให้เป็น SEO page ที่มีประโยชน์จริงกับผู้ใช้งาน
          </p>
        </div>
      </div>
    </section>

    <section class="mx-auto w-full max-w-6xl px-4 pt-12">
      <div class="grid gap-4 lg:grid-cols-3">
        <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm lg:col-span-2">
          <h2 class="text-lg font-bold text-slate-900">ส่งรูปประเมินก่อนนัดได้ไหม</h2>
          <p class="mt-2 text-sm leading-relaxed text-slate-700">
            ได้ครับ ส่งรูปหน้าเครื่องเปิดจอ, คีย์บอร์ด, ฝาหลัง/สติ๊กเกอร์รุ่น และอุปกรณ์ที่มี พร้อมพิมพ์สเปกคร่าว ๆ
            เราจะช่วยประเมินราคาโน๊ตบุ๊คเบื้องต้นให้ฟรีผ่าน LINE แล้วค่อยนัดรับ/ส่งเครื่องตามสะดวก
          </p>
          <div class="mt-4 flex flex-wrap gap-2">
            <a
              class="inline-flex items-center justify-center rounded-2xl bg-[#06C755] px-4 py-2 text-sm font-extrabold text-white shadow-sm hover:brightness-95"
              href={SITE.lineUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              แอด LINE ส่งรูปประเมินราคา
            </a>
          </div>
        </div>
        <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
          <h2 class="text-lg font-bold text-slate-900">Internal links</h2>
          <ul class="mt-3 space-y-2 text-sm">
            {internalLinks.map((l) => (
              <li><a class="text-slate-700 underline underline-offset-4 hover:text-slate-900" href={l.href}>{l.label}</a></li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="mx-auto w-full max-w-6xl px-4 pt-12">
      <div class="prose prose-slate max-w-none prose-headings:tracking-tight prose-a:underline-offset-4">
        <Content />
      </div>
    </section>

    <ProcessSteps />
    <PriceFactors />
    {faqs.length ? <FAQ faqs={faqs} /> : null}
  </LocationLayout>
) : (
  <BrandLayout
    title={layoutTitle}
    description={description}
    canonical={canonical}
    ogImage={ogImage}
    breadcrumbs={breadcrumbs}
    faqs={faqs}
    serviceName={kind === 'brand' ? `รับซื้อโน๊ตบุ๊ค ${entry.data.title}` : `รับซื้อโน๊ตบุ๊ค${entry.data.title}`}
  >
    <section class="mx-auto w-full max-w-6xl px-4 pt-10">
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
        {kind === 'brand'
          ? `รับซื้อโน๊ตบุ๊ค ${entry.data.title} มือสอง ทุกรุ่น`
          : `รับซื้อโน๊ตบุ๊ค${entry.data.title} ประเมินไว จ่ายเงินสด`}
      </h1>
      <p class="mt-4 text-base leading-relaxed text-slate-600">{description}</p>
      <p class="mt-4 text-base leading-relaxed text-slate-600">
        ประเมินราคาเบื้องต้นได้ฟรีจากรูปเครื่อง โดยดูรุ่น/สเปก/สภาพและอุปกรณ์ที่มี เพื่อให้คุณตัดสินใจได้ง่ายก่อนนัดรับหรือส่งเครื่อง
      </p>

      <div class="mt-6 rounded-3xl border border-slate-200 bg-slate-50 p-6">
        <h2 class="text-lg font-bold text-slate-900">
          {kind === 'brand' ? 'รุ่นยอดนิยมที่ลูกค้าส่งประเมินบ่อย' : 'สภาพที่รับซื้อและแนวทางประเมิน'}
        </h2>
        {kind === 'brand' ? (
          <ul class="mt-3 list-disc pl-5 text-sm text-slate-700">
            {(entry.data.popularModels ?? []).map((m: string) => (
              <li>{m}</li>
            ))}
          </ul>
        ) : (
          <ul class="mt-3 list-disc pl-5 text-sm text-slate-700">
            {(entry.data.whatWeBuy ?? []).map((w: string) => (
              <li>{w}</li>
            ))}
          </ul>
        )}
        <div class="mt-4">
          <CTAButtons primaryText="แอดไลน์ @webuy ส่งรูปประเมินราคา" secondaryText="โทร" />
        </div>
        <p class="mt-3 text-xs text-slate-500">
          ลิงก์ที่เกี่ยวข้อง: <a class="underline" href="/รับซื้อโน๊ตบุ๊คมือสอง/">รับซื้อโน๊ตบุ๊คมือสอง</a> •{' '}
          <a class="underline" href="/เช็คราคาโน๊ตบุ๊ค/">เช็คราคา</a> • <a class="underline" href="/">หน้าแรก</a>
        </p>
      </div>
    </section>

    <section class="mx-auto w-full max-w-6xl px-4 pt-12">
      <div class="grid gap-4 lg:grid-cols-3">
        <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm lg:col-span-2">
          <h2 class="text-lg font-bold text-slate-900">
            {kind === 'brand' ? 'วิธีส่งรูปประเมินราคา' : `อาการ “${entry.data.title}” ขายได้ไหม`}
          </h2>
          {kind === 'brand' ? (
            <div>
              <p class="mt-2 text-sm leading-relaxed text-slate-700">
                เพื่อให้ประเมินไว แนะนำส่งรูป 3–5 รูป + ระบุรุ่น/สเปก (CPU/RAM/SSD/GPU) + แจ้งสภาพ/อาการ (ถ้ามี) รวมถึงอุปกรณ์ที่มี
                เช่น ที่ชาร์จ กล่อง ใบเสร็จ (ถ้ามี) ทีมงานจะประเมินราคาเบื้องต้นให้ฟรีผ่าน LINE
              </p>
              <ul class="mt-3 list-disc pl-5 text-sm text-slate-700">
                <li>หน้าเครื่องเปิดจอ (ให้เห็นสภาพจอ)</li>
                <li>คีย์บอร์ด/ทัชแพด (ให้เห็นรอยและสภาพปุ่ม)</li>
                <li>ฝาหลัง/สติ๊กเกอร์รุ่น (ช่วยยืนยันรุ่น)</li>
                <li>อุปกรณ์ที่มี (ที่ชาร์จ/กล่อง)</li>
              </ul>
            </div>
          ) : (
            <div>
              <p class="mt-2 text-sm leading-relaxed text-slate-700">
                ขายได้ครับ โดยเราจะดู “รุ่น/สเปก + อาการ + สภาพรวม” เพื่อประเมินว่ารับซื้อได้ในเงื่อนไขไหน แนะนำส่งรูป/วิดีโอสั้น ๆ
                ให้เห็นอาการชัด เพื่อช่วยให้ประเมินใกล้เคียงขึ้น
              </p>
              <p class="mt-3 text-sm font-semibold text-slate-900">สาเหตุที่พบบ่อย (เพื่อช่วยบอกอาการ)</p>
              <ul class="mt-2 list-disc pl-5 text-sm text-slate-700">
                {(conditionCauseMap[entry.data.title] ?? conditionCauseMap['เครื่องเสีย']).map((c) => (
                  <li>{c}</li>
                ))}
              </ul>
            </div>
          )}

          <div class="mt-4 flex flex-wrap gap-2">
            <a
              class="inline-flex items-center justify-center rounded-2xl bg-[#06C755] px-4 py-2 text-sm font-extrabold text-white shadow-sm hover:brightness-95"
              href={SITE.lineUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              แอด LINE ส่งรูปประเมินราคา
            </a>
          </div>
        </div>

        <aside class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
          <h2 class="text-lg font-bold text-slate-900">สิ่งที่ควรเตรียมก่อนขาย</h2>
          <ul class="mt-3 space-y-2 text-sm text-slate-700">
            {prepChecklist.map((p) => (
              <li class="flex items-start gap-2"><span aria-hidden="true">✓</span><span>{p}</span></li>
            ))}
          </ul>
        </aside>
      </div>
    </section>

    <section class="mx-auto w-full max-w-6xl px-4 pt-12">
      <div class="prose prose-slate max-w-none prose-headings:tracking-tight prose-a:underline-offset-4">
        <Content />
      </div>
    </section>

    <ProcessSteps />
    <PriceFactors />
    {faqs.length ? <FAQ faqs={faqs} /> : null}
  </BrandLayout>
)}

