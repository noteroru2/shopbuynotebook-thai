---
import BrandLayout from '../../layouts/BrandLayout.astro';
import LocationLayout from '../../layouts/LocationLayout.astro';
import CTAButtons from '../../components/CTAButtons.astro';
import FAQ from '../../components/FAQ.astro';
import ProcessSteps from '../../components/ProcessSteps.astro';
import PriceFactors from '../../components/PriceFactors.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import { getCollection, render } from 'astro:content';
import { absoluteUrl } from '../../lib/seo';
import { SITE } from '../../lib/seo';

export async function getStaticPaths() {
  const [brands, conditions, locations] = await Promise.all([
    getCollection('brands'),
    getCollection('conditions'),
    getCollection('locations'),
  ]);

  const all = [
    ...brands.map((e) => ({ kind: 'brand' as const, entry: e })),
    ...conditions.map((e) => ({ kind: 'condition' as const, entry: e })),
    ...locations.map((e) => ({ kind: 'location' as const, entry: e })),
  ];

  return all.map(({ kind, entry }) => ({
    params: { slug: entry.data.slug },
    props: { kind, entry },
  }));
}

const { kind, entry } = Astro.props as { kind: 'brand' | 'condition' | 'location'; entry: any };
const { Content } = await render(entry);

const slug = entry.data.slug;
const canonical = absoluteUrl(`/รับซื้อโน๊ตบุ๊ค/${slug}/`);

const breadcrumbs = [
  { name: 'หน้าแรก', url: absoluteUrl('/') },
  { name: 'รับซื้อโน๊ตบุ๊ค', url: absoluteUrl('/รับซื้อโน๊ตบุ๊ค/') },
  { name: entry.data.title, url: canonical },
];

const layoutTitle =
  kind === 'location'
    ? (entry.data.seoTitle ??
        `รับซื้อโน๊ตบุ๊ค ${entry.data.title} ประเมินฟรีผ่านไลน์ @webuy | ร้านรับซื้อโน๊ตบุ๊ค.com`)
    : (entry.data.seoTitle ?? `${entry.data.title} | ร้านรับซื้อโน๊ตบุ๊ค.com`);
const locationH1 =
  kind === 'location'
    ? (entry.data.h1 ?? `รับซื้อโน๊ตบุ๊ค ${entry.data.title} ประเมินไว ส่งรูปเช็คราคาฟรี`)
    : '';
const brandOrConditionH1 =
  kind === 'brand'
    ? (entry.data.pageH1 ?? `รับซื้อโน๊ตบุ๊ค ${entry.data.title} มือสอง ทุกรุ่น`)
    : (entry.data.pageH1 ?? `รับซื้อโน๊ตบุ๊ค ${entry.data.title} ประเมินไว จ่ายเงินสด`);
const description = entry.data.description;
const ogImage = entry.data.featuredImage ? absoluteUrl(entry.data.featuredImage) : undefined;
const serviceName =
  kind === 'location'
    ? `รับซื้อโน๊ตบุ๊ค ${entry.data.title}`
    : (entry.data.serviceName ?? `รับซื้อโน๊ตบุ๊ค ${entry.data.title}`);

const internalLinks = [
  { label: 'หน้าแรก', href: '/' },
  { label: 'บริการรับซื้อโน๊ตบุ๊คทุกยี่ห้อ', href: '/รับซื้อโน๊ตบุ๊ค/' },
  { label: 'รับซื้อโน๊ตบุ๊คมือสอง', href: '/รับซื้อโน๊ตบุ๊คมือสอง/' },
  { label: 'เช็คราคาโน๊ตบุ๊คก่อนขาย', href: '/เช็คราคาโน๊ตบุ๊ค/' },
  { label: 'ตีราคาโน๊ตบุ๊ค', href: '/ตีราคาโน๊ตบุ๊ค/' },
  { label: 'พื้นที่ให้บริการรับซื้อโน๊ตบุ๊ค', href: '/พื้นที่ให้บริการ/' },
  { label: 'ขายโน๊ตบุ๊ค', href: '/ขายโน๊ตบุ๊ค/' },
];

const prepChecklist = [
  'ถ่ายรูป 3–5 รูป (หน้าเครื่อง/คีย์บอร์ด/ฝาหลัง/อุปกรณ์)',
  'แจ้งรุ่น/สเปก (CPU, RAM, SSD, GPU) และปีโดยประมาณ',
  'แจ้งสภาพ/อาการที่พบแบบตรงไปตรงมา',
  'เตรียมที่ชาร์จ/กล่อง/ใบเสร็จ (ถ้ามี) เพื่อประเมินแม่นขึ้น',
  'สำรองข้อมูลและล้างเครื่องก่อนขายเพื่อความปลอดภัย',
];

const conditionCauseMap: Record<string, string[]> = {
  'เปิดไม่ติด': ['อะแดปเตอร์/สายชาร์จมีปัญหา', 'แบตเสื่อมหรือมีอาการบวม', 'เมนบอร์ด/ภาคจ่ายไฟ', 'RAM/SSD หลวม/เสีย', 'ระบบค้าง/บูตไม่ขึ้น'],
  'จอแตก': ['กระแทกหรือกดทับ', 'จอเป็นเส้น/จอดำบางส่วน', 'บานพับฝืดทำให้จอเสียหาย', 'สายแพรจอมีปัญหา'],
  'แบตเสื่อม': ['แบตหมดไว/ชาร์จไม่เข้า', 'แบตบวม', 'สุขภาพแบตต่ำ', 'อะแดปเตอร์ไม่ตรงสเปก'],
  'ไม่มีที่ชาร์จ': ['ต้องใช้ที่ชาร์จแท้/เทียบที่เหมาะสม', 'ประเมินอาจปรับตามความครบอุปกรณ์', 'แจ้งรุ่นหัวชาร์จ/Type-C ได้จะช่วยมาก'],
  'เครื่องเก่า': ['สเปกเก่าแต่ยังใช้งานได้', 'อัปเกรด SSD/RAM ช่วยเพิ่มมูลค่า', 'สภาพภายนอกและแบตมีผลมาก'],
  'ตกรุ่น': ['รุ่นเก่า/เปลี่ยนเครื่องใหม่', 'ราคาขึ้นกับสเปกและความต้องการตลาด', 'อุปกรณ์ครบช่วยให้ปิดงานไว'],
  'เครื่องเสีย': ['อาการหลากหลาย ควรส่งวิดีโอ/รูปให้เห็นชัด', 'สภาพบอร์ด/จอ/แบต/พอร์ตมีผลต่อราคา', 'รับซื้อได้ถ้าแจ้งอาการตรงไปตรงมา'],
};

type RelatedLink = { label: string; href: string; description?: string };

const MACBOOK_FOCUS_SLUGS = new Set([
  'macbook-air-13',
  'macbook-air-15',
  'macbook-air-m1',
  'macbook-air-m2',
  'macbook-air-m3',
  'macbook-air-m4',
  'macbook-air-m5',
  'macbook-pro-14',
  'macbook-pro-16',
  'macbook-pro-m1',
  'macbook-pro-m3',
  'macbook-pro-m5',
]);

const GAMING_FOCUS_SLUGS = new Set([
  'asus-rog-strix',
  'asus-tuf-a15-f15',
  'asus-zephyrus-g14',
  'acer-nitro-v',
  'acer-predator-helios',
  'lenovo-legion-5',
  'lenovo-legion-pro-7',
  'hp-victus-15',
  'alienware-m16',
  'msi-katana-15',
]);

const OFFICE_FOCUS_SLUGS = new Set([
  'asus-zenbook',
  'thinkpad-x1-carbon',
  'thinkpad-t14',
  'dell-latitude',
  'dell-xps-13-15',
  'hp-elitebook',
  'hp-probook',
  'surface-laptop',
]);

function getEnhancedBrandSeoTitle(slug: string, title: string, fallback: string) {
  if (MACBOOK_FOCUS_SLUGS.has(slug)) {
    return `รับซื้อ ${title} มือสอง ราคาดี เช็กฟรี | ร้านรับซื้อโน๊ตบุ๊ค.com`;
  }

  if (GAMING_FOCUS_SLUGS.has(slug)) {
    return `รับซื้อ ${title} มือสอง ราคาดี ประเมินฟรี | ร้านรับซื้อโน๊ตบุ๊ค.com`;
  }

  if (OFFICE_FOCUS_SLUGS.has(slug)) {
    return `รับซื้อ ${title} มือสอง ราคาดี ประเมินฟรี | ร้านรับซื้อโน๊ตบุ๊ค.com`;
  }

  return fallback;
}

function getEnhancedBrandH1(slug: string, title: string, fallback: string) {
  if (MACBOOK_FOCUS_SLUGS.has(slug)) {
    return `รับซื้อ ${title} มือสอง เช็กราคาไว ส่งรูปประเมินฟรี`;
  }

  if (GAMING_FOCUS_SLUGS.has(slug)) {
    return `รับซื้อ ${title} มือสอง เช็กราคาไวตามสเปก`;
  }

  if (OFFICE_FOCUS_SLUGS.has(slug)) {
    return `รับซื้อ ${title} มือสอง เช็กราคาไวตามรุ่น`;
  }

  return fallback;
}

function getEnhancedBrandDescription(slug: string, title: string, fallback: string) {
  if (MACBOOK_FOCUS_SLUGS.has(slug)) {
    return `รับซื้อ ${title} มือสอง ประเมินราคาฟรีจากรูปเครื่อง เช็กชิป สเปก Battery Health และอุปกรณ์ครบก่อนขาย พร้อมนัดรับหรือส่งเครื่องได้ตามสะดวก`;
  }

  if (GAMING_FOCUS_SLUGS.has(slug)) {
    return `รับซื้อ ${title} มือสอง เช็กสเปก CPU GPU RAM SSD และสภาพจริงก่อนตีราคา ส่งรูปประเมินฟรี เหมาะกับเครื่องเกมมิ่งที่ต้องการเช็กราคาไวและปิดดีลชัดเจน`;
  }

  if (OFFICE_FOCUS_SLUGS.has(slug)) {
    return `รับซื้อ ${title} มือสอง ประเมินฟรีตามรุ่น สเปก และสภาพเครื่อง เหมาะกับโน๊ตบุ๊คทำงาน เครื่องบริษัท และเครื่องใช้งานทั่วไปที่ต้องการเช็กราคาไว`;
  }

  return fallback;
}

function getBrandFeaturedLinks(slug: string, title: string): RelatedLink[] {
  if (slug.startsWith('macbook-')) {
    return [
      { label: 'รับซื้อ MacBook ทุกรุ่น', href: '/รับซื้อโน๊ตบุ๊ค/macbook/', description: 'หน้า hub หลักของ MacBook พร้อมลิงก์รุ่นและเคสที่เกี่ยวข้อง' },
      {
        label: slug.includes('air') ? 'รับซื้อ MacBook Air ราคาเท่าไหร่' : 'รับซื้อ MacBook Pro ราคาเท่าไหร่',
        href: slug.includes('air') ? '/blog/รับซื้อ-macbook-air-13-15-ราคาเท่าไหร่/' : '/blog/รับซื้อ-macbook-pro-14-16-ราคาเท่าไหร่/',
        description: 'ดู intent เชิงราคาและปัจจัยที่มีผลกับรุ่นนี้',
      },
      { label: 'MacBook Battery Health มีผลกับราคาไหม', href: '/รับซื้อโน๊ตบุ๊ค/macbook-battery-health/', description: 'เหมาะกับเคสที่แบตเริ่มเสื่อมหรือใช้มานาน' },
      { label: 'MacBook ติด MDM หรือบัญชีองค์กร', href: '/รับซื้อโน๊ตบุ๊ค/macbook-mdm/', description: 'เช็กเงื่อนไขก่อนส่งประเมินสำหรับเครื่ององค์กร' },
      { label: 'ขาย MacBook ต้องเตรียมอะไรบ้าง', href: '/blog/ขาย-macbook-ต้องเตรียมอะไรบ้าง/', description: 'คู่มือปิด Apple ID, Find My, กล่อง และอุปกรณ์' },
      { question: `ประเมิน ${title} แล้ว ถ้าราคายังไม่ตรงใจ ต้องขายทันทีไหม`, answer: 'ไม่จำเป็นต้องขายทันทีครับ คุณสามารถส่งรุ่น สเปก รูปเครื่องเพื่อรับกรอบราคาก่อนได้ แล้วค่อยตัดสินใจหลังตรวจสภาพจริง จุดประสงค์คือให้คุณเห็นกรอบราคาชัดเจนก่อนนัดรับหรือส่งเครื่อง' },
    ];
  }

  if (GAMING_FOCUS_SLUGS.has(slug)) {
    const brandHubMap: Record<string, string> = {
      asus: '/รับซื้อโน๊ตบุ๊ค/asus/',
      acer: '/รับซื้อโน๊ตบุ๊ค/acer/',
      lenovo: '/รับซื้อโน๊ตบุ๊ค/lenovo/',
      hp: '/รับซื้อโน๊ตบุ๊ค/hp/',
      alienware: '/รับซื้อโน๊ตบุ๊ค/dell/',
      msi: '/รับซื้อโน๊ตบุ๊ค/msi/',
    };
    const brandPrefix = slug.split('-')[0];
    return [
      { label: 'รับซื้อ Gaming Notebook', href: '/รับซื้อโน๊ตบุ๊ค/gaming/', description: 'หน้า hub รวมรุ่นเกมมิ่ง แบรนด์หลัก และบทความ GPU' },
      { label: `รับซื้อ ${title.split(' ')[0]} รุ่นใกล้เคียง`, href: brandHubMap[brandPrefix] ?? '/รับซื้อโน๊ตบุ๊ค/gaming/', description: 'ไปหน้าแบรนด์เพื่อเชื่อมรุ่นใกล้เคียงและรุ่นย่อยอื่น' },
      { label: 'Gaming Notebook ตามสเปก GPU', href: '/blog/รับซื้อ-gaming-notebook-rtx-4070-4080-4090-ราคาเท่าไหร่/', description: 'เหมาะกับเคสที่ราคาขึ้นกับ GPU และสเปกเกมมิ่งโดยตรง' },
      { label: 'Gaming Notebook มือสองขายได้ราคาดีกว่าไหม', href: '/blog/gaming-notebook-มือสองขายได้ราคาดีกว่าไหม/', description: 'มุมมองเรื่องสภาพ ความร้อน และความต้องการของตลาด' },
      { label: 'เครื่องร้อนจัด ดับเอง ยังรับซื้อไหม', href: '/รับซื้อโน๊ตบุ๊ค/ร้อนจัดดับเอง/', description: 'ลิงก์รองสำหรับเครื่องเกมมิ่งที่มีอาการด้านความร้อน' },
      { question: `ส่งประเมิน ${title} แล้ว ร้านจะนัดตรวจแบบไหน`, answer: 'ทั่วไปเริ่มจากกรอบราคาจากรูปและสเปกก่อน หากคุยกรอบราคาได้แล้วจึงนัดตรวจสภาพจริงอีกครั้ง จุดนี้ช่วยให้คุณรู้ทิศทางราคาก่อนโดยไม่ต้องหอบเครื่องไปหลายรอบ' },
    ];
  }

  if (OFFICE_FOCUS_SLUGS.has(slug)) {
    const officeBlogMap: Record<string, string> = {
      'asus-zenbook': '/blog/รับซื้อ-asus-zenbook-vivobook-ราคาเท่าไหร่/',
      'thinkpad-x1-carbon': '/blog/รับซื้อ-thinkpad-x1-carbon-t14-e14-e15-ราคาเท่าไหร่/',
      'thinkpad-t14': '/blog/รับซื้อ-thinkpad-x1-carbon-t14-e14-e15-ราคาเท่าไหร่/',
      'dell-latitude': '/blog/รับซื้อ-dell-latitude-xps-ราคาเท่าไหร่/',
      'dell-xps-13-15': '/blog/รับซื้อ-dell-latitude-xps-ราคาเท่าไหร่/',
      'hp-elitebook': '/blog/รับซื้อ-hp-elitebook-probook-ราคาเท่าไหร่/',
      'hp-probook': '/blog/รับซื้อ-hp-elitebook-probook-ราคาเท่าไหร่/',
      'surface-laptop': '/blog/รับซื้อ-surface-laptop-pro-ราคาเท่าไหร่/',
    };
    const officeHubMap: Record<string, string> = {
      asus: '/รับซื้อโน๊ตบุ๊ค/asus/',
      thinkpad: '/รับซื้อโน๊ตบุ๊ค/lenovo/',
      dell: '/รับซื้อโน๊ตบุ๊ค/dell/',
      hp: '/รับซื้อโน๊ตบุ๊ค/hp/',
      surface: '/รับซื้อโน๊ตบุ๊ค/surface/',
    };
    const officePrefix = slug.split('-')[0];
    return [
      { label: 'รับซื้อโน๊ตบุ๊คราคาดี เริ่มจากหน้าเช็กราคา', href: '/เช็คราคาโน๊ตบุ๊ค/', description: 'ทางลัดสำหรับส่งรูป รุ่น สเปก และรับกรอบราคาเบื้องต้น' },
      { label: `รับซื้อ ${title.split(' ')[0]} รุ่นใกล้เคียง`, href: officeHubMap[officePrefix] ?? '/รับซื้อโน๊ตบุ๊ค/', description: 'กลับไปหน้าแบรนด์เพื่อเชื่อมรุ่นงานและรุ่นใกล้เคียง' },
      { label: 'บทความราคาในกลุ่มเดียวกัน', href: officeBlogMap[slug] ?? '/blog/รับซื้อโน๊ตบุ๊ค-ราคาเท่าไหร่/', description: 'Intent เชิงราคาและปัจจัยที่ร้านใช้ประเมินในกลุ่ม office' },
      { label: 'แบตเสื่อมหรือใช้งานมานาน ยังขายได้ไหม', href: '/รับซื้อโน๊ตบุ๊ค/แบตเสื่อม/', description: 'เหมาะกับเครื่องทำงานที่สภาพรวมดีแต่แบตเริ่มเสื่อม' },
      { label: 'ก่อนขายโน๊ตบุ๊คต้องล้างข้อมูลอย่างไร', href: '/blog/ก่อนขายโน๊ตบุ๊คต้องล้างข้อมูลอย่างไร/', description: 'คู่มือสั้นสำหรับเครื่องงาน เครื่องบริษัท และข้อมูลส่วนตัว' },
      { question: `ถ้าจะขาย ${title} แบบไม่เสียเวลา ควรเตรียมอะไรเพิ่ม`, answer: 'แนะนำให้เตรียมรูปเครื่องทุกมุม รูปสเปก อะแดปเตอร์เดิม และแจ้งอาการจุดที่มีตรง ๆ ตั้งแต่ต้น วิธีนี้ช่วยให้ร้านให้กรอบราคาได้ไวขึ้นและลดรอบการถามกลับ' },
    ];
  }

  return [];
}

function getAutoBrandFaqs(slug: string, title: string) {
  if (MACBOOK_FOCUS_SLUGS.has(slug)) {
    return [
      { question: `${title} แบตเสื่อมหรือมีรอยใช้งาน ยังรับซื้อไหม`, answer: 'รับครับ โดยจะประเมินจากรุ่น ชิป ความจุ Battery Health/Cycle Count สภาพจอ และสภาพบอดี้จริง หากมีรอยหรือแบตเริ่มเสื่อมยังส่งรูปประเมินได้ แค่ควรแจ้งตามตรงตั้งแต่ต้น' },
      { question: `${title} ไม่มีกล่องหรือไม่มีที่ชาร์จ ประเมินได้ไหม`, answer: 'ประเมินได้ครับ แต่กรอบราคาอาจปรับตามความครบของอุปกรณ์ โดยเฉพาะที่ชาร์จ แนะนำถ่ายรูปอุปกรณ์ที่มีจริงและแจ้งให้ครบเพื่อให้ตีราคาได้ใกล้เคียงขึ้น' },
      { question: `ส่งอะไรเพื่อเช็กราคา ${title} ให้ไวที่สุด`, answer: 'ส่งรูปตัวเครื่องรอบด้าน รูปหน้า About This Mac รูป Battery Health หรือ Cycle Count และแจ้งว่ามีที่ชาร์จ กล่อง หรือใบเสร็จหรือไม่ ข้อมูลชุดนี้ช่วยให้ประเมินได้เร็วและแม่นขึ้น' },
      { question: `ประเมิน ${title} แล้ว ถ้าราคายังไม่ตรงใจ ต้องขายทันทีไหม`, answer: 'ไม่จำเป็นต้องขายทันทีครับ คุณสามารถส่งรุ่น สเปก รูปเครื่องเพื่อรับกรอบราคาก่อนได้ แล้วค่อยตัดสินใจหลังตรวจสภาพจริง จุดประสงค์คือให้คุณเห็นกรอบราคาชัดเจนก่อนนัดรับหรือส่งเครื่อง' },
    ];
  }

  if (GAMING_FOCUS_SLUGS.has(slug)) {
    return [
      { question: `${title} ร้อนจัด พัดลมดัง หรือมีอาการดับเอง ยังรับซื้อไหม`, answer: 'รับประเมินได้ครับ โดยเฉพาะถ้ายังเปิดติดและแจ้งอาการได้ชัด ควรส่งรูปสเปกและวิดีโอสั้น ๆ ให้เห็นอาการจริง เพื่อให้ร้านประเมินตามต้นทุนตรวจเช็กและสภาพเครื่องได้ตรงขึ้น' },
      { question: `GPU และสเปกมีผลกับราคารับซื้อ ${title} แค่ไหน`, answer: 'มีผลมากครับ รุ่น GPU ระดับ RTX/ความจุ RAM/SSD รวมถึงหน้าจอและสภาพระบบระบายความร้อน มักเป็นตัวกำหนดช่วงราคาหลักของเครื่องเกมมิ่งมากกว่ารุ่นใช้งานทั่วไป' },
      { question: `ส่งอะไรเพื่อเช็กราคา ${title} ให้ไว`, answer: 'แนะนำส่งรูปตัวเครื่อง รูปสเปก CPU RAM SSD GPU รูปที่ชาร์จเดิม และแจ้งอาการด้านความร้อนหรือพัดลมถ้ามี ยิ่งข้อมูลครบ ร้านยิ่งให้กรอบราคาได้ใกล้เคียงขึ้น' },
      { question: `ส่งประเมิน ${title} แล้ว ร้านจะนัดตรวจแบบไหน`, answer: 'ทั่วไปเริ่มจากกรอบราคาจากรูปและสเปกก่อน หากคุยกรอบราคาได้แล้วจึงนัดตรวจสภาพจริงอีกครั้ง จุดนี้ช่วยให้คุณรู้ทิศทางราคาก่อนโดยไม่ต้องหอบเครื่องไปหลายรอบ' },
    ];
  }

  if (OFFICE_FOCUS_SLUGS.has(slug)) {
    return [
      { question: `${title} มีรอยใช้งานหรือแบตเสื่อม ยังรับซื้อไหม`, answer: 'รับครับ โดยเฉพาะถ้าเครื่องยังเปิดติดและใช้งานพื้นฐานได้ปกติ ร้านจะดูรุ่น สเปก สภาพจอ คีย์บอร์ด บอดี้ และสุขภาพแบตรวมกันก่อนประเมินราคา' },
      { question: `${title} เป็นเครื่องบริษัทหรือมี asset tag ประเมินได้ไหม`, answer: 'ประเมินได้ครับ แต่ควรแจ้งสถานะเครื่องให้ชัด เช่น มีสติ๊กเกอร์องค์กรหรือมีบัญชีบริษัทผูกอยู่หรือไม่ เพื่อให้เช็กเงื่อนไขการปลดล็อกและเอกสารได้ก่อนนัดรับ' },
      { question: `ส่งอะไรเพื่อเช็กราคา ${title} ให้แม่นขึ้น`, answer: 'ส่งรูปตัวเครื่องทุกด้าน รูปสเปก CPU RAM SSD รูปแบตหรือ Battery Report ถ้ามี และแจ้งว่ามีอะแดปเตอร์เดิม กล่อง หรือใบเสร็จหรือไม่ ข้อมูลเหล่านี้ช่วยให้ประเมินตามรุ่นได้ละเอียดขึ้น' },
      { question: `ถ้าจะขาย ${title} แบบไม่เสียเวลา ควรเตรียมอะไรเพิ่ม`, answer: 'แนะนำให้เตรียมรูปเครื่องทุกมุม รูปสเปก อะแดปเตอร์เดิม และแจ้งอาการจุดที่มีตรง ๆ ตั้งแต่ต้น วิธีนี้ช่วยให้ร้านให้กรอบราคาได้ไวขึ้นและลดรอบการถามกลับ' },
    ];
  }

  return [];
}

const enhancedLayoutTitle = kind === 'brand' ? getEnhancedBrandSeoTitle(slug, entry.data.title, layoutTitle) : layoutTitle;
const enhancedBrandOrConditionH1 =
  kind === 'brand' ? getEnhancedBrandH1(slug, entry.data.title, brandOrConditionH1) : brandOrConditionH1;
const pageDescription =
  kind === 'brand' ? getEnhancedBrandDescription(slug, entry.data.title, description) : description;

const brandFeaturedLinks = kind === 'brand' ? getBrandFeaturedLinks(slug, entry.data.title) : [];
const faqs = kind === 'brand' ? [...(entry.data.faqs ?? []), ...getAutoBrandFaqs(slug, entry.data.title)] : (entry.data.faqs ?? []);
---

{kind === 'location' ? (
  <LocationLayout
    title={layoutTitle}
    description={description}
    canonical={canonical}
    ogImage={ogImage}
    breadcrumbs={breadcrumbs}
    faqs={faqs}
    serviceName={`รับซื้อโน๊ตบุ๊ค ${entry.data.title}`}
  >
    <section class="mx-auto w-full max-w-6xl px-4 pt-10">
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
        {locationH1}
      </h1>
      <p class="mt-4 text-base leading-relaxed text-slate-600">{description}</p>
      <p class="mt-4 text-base leading-relaxed text-slate-600">
        ถ้าต้องการเช็คราคาไว แนะนำส่งรูป 3–5 รูป + รุ่น/สเปก + สภาพ/อาการ ผ่าน LINE ก่อนนัดรับหรือส่งเครื่อง
        เพื่อให้ประเมินเบื้องต้นได้ตรงขึ้นและลดเวลาหน้างาน
      </p>

      <div class="mt-6 rounded-3xl border border-slate-200 bg-slate-50 p-6">
        <h2 class="text-lg font-bold text-slate-900">นัดรับ/นัดเจอในพื้นที่</h2>
        <ul class="mt-3 list-disc pl-5 text-sm text-slate-700">
          {(entry.data.meetingOptions ?? []).map((m: string) => (
            <li>{m}</li>
          ))}
        </ul>
        <div class="mt-4">
          <CTAButtons primaryText="แอดไลน์ @webuy ส่งรูปประเมินราคา" secondaryText="โทร" />
        </div>
      </div>
    </section>

    <section class="mx-auto w-full max-w-6xl px-4 pt-12">
      <div class="grid gap-4 lg:grid-cols-3">
        <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
          <h2 class="text-lg font-bold text-slate-900">พื้นที่ย่อย</h2>
          <ul class="mt-3 list-disc pl-5 text-sm text-slate-700">
            {(entry.data.subAreas ?? []).map((a: string) => (
              <li>{a}</li>
            ))}
          </ul>
        </div>
        <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm lg:col-span-2">
          <h2 class="text-lg font-bold text-slate-900">จุดเด่นของพื้นที่</h2>
          <ul class="mt-3 list-disc pl-5 text-sm text-slate-700">
            {(entry.data.highlights ?? []).map((h: string) => (
              <li>{h}</li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="mx-auto w-full max-w-6xl px-4 pt-12">
      <div class="grid gap-4 lg:grid-cols-3">
        <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm lg:col-span-2">
          <h2 class="text-lg font-bold text-slate-900">ส่งรูปประเมินก่อนนัดได้ไหม</h2>
          <p class="mt-2 text-sm leading-relaxed text-slate-700">
            ได้ครับ ส่งรูปหน้าเครื่องเปิดจอ, คีย์บอร์ด, ฝาหลัง/สติ๊กเกอร์รุ่น และอุปกรณ์ที่มี พร้อมพิมพ์สเปกคร่าว ๆ
            เราจะช่วยประเมินราคาโน๊ตบุ๊คเบื้องต้นให้ฟรีผ่าน LINE แล้วค่อยนัดรับ/ส่งเครื่องตามสะดวก
          </p>
          <div class="mt-4 flex flex-wrap gap-2">
            <a
              class="inline-flex items-center justify-center rounded-2xl bg-[#06C755] px-4 py-2 text-sm font-extrabold text-white shadow-sm hover:brightness-95"
              href={SITE.lineUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              แอด LINE ส่งรูปประเมินราคา
            </a>
          </div>
        </div>
        <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
          <h2 class="text-lg font-bold text-slate-900">Internal links</h2>
          <ul class="mt-3 space-y-2 text-sm">
            {internalLinks.map((l) => (
              <li><a class="text-slate-700 underline underline-offset-4 hover:text-slate-900" href={l.href}>{l.label}</a></li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="mx-auto w-full max-w-6xl px-4 pt-12">
      <div class="prose prose-slate max-w-none prose-headings:tracking-tight prose-a:underline-offset-4">
        <Content />
      </div>
    </section>

    <ProcessSteps />
    <PriceFactors />
    {faqs.length ? <FAQ faqs={faqs} /> : null}
  </LocationLayout>
) : (
  <BrandLayout
    title={enhancedLayoutTitle}
    description={pageDescription}
    canonical={canonical}
    ogImage={ogImage}
    breadcrumbs={breadcrumbs}
    faqs={faqs}
    serviceName={serviceName}
  >
    <section class="mx-auto w-full max-w-6xl px-4 pt-10">
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
        {enhancedBrandOrConditionH1}
      </h1>
      <p class="mt-4 text-base leading-relaxed text-slate-600">{pageDescription}</p>
      <p class="mt-4 text-base leading-relaxed text-slate-600">
        ประเมินราคาเบื้องต้นได้ฟรีจากรูปเครื่อง โดยดูรุ่น/สเปก/สภาพและอุปกรณ์ที่มี เพื่อให้คุณตัดสินใจได้ง่ายก่อนนัดรับหรือส่งเครื่อง
      </p>

      <div class="mt-6 rounded-3xl border border-slate-200 bg-slate-50 p-6">
        <h2 class="text-lg font-bold text-slate-900">
          {kind === 'brand' ? 'รุ่นยอดนิยมที่ลูกค้าส่งประเมินบ่อย' : 'สภาพที่รับซื้อและแนวทางประเมิน'}
        </h2>
        {kind === 'brand' ? (
          <ul class="mt-3 list-disc pl-5 text-sm text-slate-700">
            {(entry.data.popularModels ?? []).map((m: string) => (
              <li>{m}</li>
            ))}
          </ul>
        ) : (
          <ul class="mt-3 list-disc pl-5 text-sm text-slate-700">
            {(entry.data.whatWeBuy ?? []).map((w: string) => (
              <li>{w}</li>
            ))}
          </ul>
        )}
        <div class="mt-4">
          <CTAButtons primaryText="แอดไลน์ @webuy ส่งรูปประเมินราคา" secondaryText="โทร" />
        </div>
        <p class="mt-3 text-xs text-slate-500">
          ลิงก์ที่เกี่ยวข้อง: <a class="underline" href="/รับซื้อโน๊ตบุ๊คมือสอง/">รับซื้อโน๊ตบุ๊คมือสอง</a> •{' '}
          <a class="underline" href="/เช็คราคาโน๊ตบุ๊ค/">เช็คราคา</a> • <a class="underline" href="/">หน้าแรก</a>
        </p>
      </div>
    </section>

    <section class="mx-auto w-full max-w-6xl px-4 pt-12">
      <div class="grid gap-4 lg:grid-cols-3">
        <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm lg:col-span-2">
          <h2 class="text-lg font-bold text-slate-900">
            {kind === 'brand' ? 'วิธีส่งรูปประเมินราคา' : `อาการ "${entry.data.title}" ขายได้ไหม`}
          </h2>
          {kind === 'brand' ? (
            <div>
              <p class="mt-2 text-sm leading-relaxed text-slate-700">
                เพื่อให้ประเมินไว แนะนำส่งรูป 3–5 รูป + ระบุรุ่น/สเปก (CPU/RAM/SSD/GPU) + แจ้งสภาพ/อาการ (ถ้ามี) รวมถึงอุปกรณ์ที่มี
                เช่น ที่ชาร์จ กล่อง ใบเสร็จ (ถ้ามี) ทีมงานจะประเมินราคาเบื้องต้นให้ฟรีผ่าน LINE
              </p>
              <ul class="mt-3 list-disc pl-5 text-sm text-slate-700">
                <li>หน้าเครื่องเปิดจอ (ให้เห็นสภาพจอ)</li>
                <li>คีย์บอร์ด/ทัชแพด (ให้เห็นรอยและสภาพปุ่ม)</li>
                <li>ฝาหลัง/สติ๊กเกอร์รุ่น (ช่วยยืนยันรุ่น)</li>
                <li>อุปกรณ์ที่มี (ที่ชาร์จ/กล่อง)</li>
              </ul>
            </div>
          ) : (
            <div>
              <p class="mt-2 text-sm leading-relaxed text-slate-700">
                ขายได้ครับ โดยเราจะดู "รุ่น/สเปก + อาการ + สภาพรวม" เพื่อประเมินว่ารับซื้อได้ในเงื่อนไขไหน แนะนำส่งรูป/วิดีโอสั้น ๆ
                ให้เห็นอาการชัด เพื่อช่วยให้ประเมินใกล้เคียงขึ้น
              </p>
              <p class="mt-3 text-sm font-semibold text-slate-900">สาเหตุที่พบบ่อย (เพื่อช่วยบอกอาการ)</p>
              <ul class="mt-2 list-disc pl-5 text-sm text-slate-700">
                {(conditionCauseMap[entry.data.title] ?? conditionCauseMap['เครื่องเสีย']).map((c) => (
                  <li>{c}</li>
                ))}
              </ul>
            </div>
          )}

          <div class="mt-4 flex flex-wrap gap-2">
            <a
              class="inline-flex items-center justify-center rounded-2xl bg-[#06C755] px-4 py-2 text-sm font-extrabold text-white shadow-sm hover:brightness-95"
              href={SITE.lineUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              แอด LINE ส่งรูปประเมินราคา
            </a>
          </div>
        </div>

        <aside class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
          <h2 class="text-lg font-bold text-slate-900">สิ่งที่ควรเตรียมก่อนขาย</h2>
          <ul class="mt-3 space-y-2 text-sm text-slate-700">
            {prepChecklist.map((p) => (
              <li class="flex items-start gap-2"><span aria-hidden="true">✓</span><span>{p}</span></li>
            ))}
          </ul>
        </aside>
      </div>
    </section>

    <section class="mx-auto w-full max-w-6xl px-4 pt-12">
      <div class="prose prose-slate max-w-none prose-headings:tracking-tight prose-a:underline-offset-4">
        <Content />
      </div>
    </section>

        {brandFeaturedLinks.length ? (
      <RelatedLinks title="ทางลัดในคลัสเตอร์รับซื้อรุ่นใกล้เคียง" links={brandFeaturedLinks} />
    ) : null}
<ProcessSteps />
    <PriceFactors />
    {faqs.length ? <FAQ faqs={faqs} /> : null}
  </BrandLayout>
)}

