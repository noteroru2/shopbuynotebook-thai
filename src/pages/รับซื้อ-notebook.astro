---
import ServicePageShell from '../components/ServicePageShell.astro';

const title = 'รับซื้อ Notebook ประเมินตามสภาพจริง | ร้านรับซื้อโน๊ตบุ๊ค.com';
const description =
  'บริการรับซื้อ Notebook มือสองหลายยี่ห้อ ส่งรูปและสเปกเพื่อประเมินเบื้องต้นฟรี แจ้งราคาก่อนตัดสินใจขาย เทียบราคาตลาด รับทั้งเครื่องปกติและเครื่องเสียบางอาการ';

const faqs = [
  {
    question: 'รับซื้อ Notebook หลายยี่ห้อไหม?',
    answer:
      'รับครับ ทั้ง Dell HP Lenovo ASUS Acer MSI และแบรนด์อื่น ๆ ราคาขึ้นกับรุ่น สเปก สภาพ และอุปกรณ์ที่มี',
  },
  {
    question: 'รับซื้อ Notebook ที่ไม่มีที่ชาร์จไหม?',
    answer:
      'รับได้ครับ แจ้งล่วงหน้าว่าไม่มีที่ชาร์จเพื่อให้ประเมินตรง ราคามักปรับตามความครบของอุปกรณ์',
  },
  {
    question: 'ต้องส่งรูปอะไรบ้างก่อนประเมิน?',
    answer:
      'แนะนำส่งรูปด้านบน ด้านล่าง หน้าจอ คีย์บอร์ด รอยตำหนิ (ถ้ามี) และแคปหน้าจอสเปกจาก Windows Settings หรือ About This Mac',
  },
];
---

<ServicePageShell
  title={title}
  description={description}
  canonicalPath="/รับซื้อ-notebook/"
  breadcrumbLabel="รับซื้อ Notebook"
  serviceName="รับซื้อ Notebook"
  h1="รับซื้อ Notebook"
  h1Accent="คำค้นภาษาอังกฤษ ครอบคลุม Dell HP Lenovo ASUS"
  heroSubtitle="ส่งรูปและสเปก Notebook ผ่าน LINE เพื่อเช็คราคาเบื้องต้นฟรี รับทั้งเครื่องใช้งานปกติ เครื่องเก่า และเครื่องเสียบางอาการ"
  accentClass="text-purple-400"
  gradientFrom="from-purple-900/60"
  proseLinkClass="prose-a:text-purple-600 hover:prose-a:text-purple-500"
  faqs={faqs}
>
  <p class="lead">
    หน้านี้เน้นคำว่า <strong>รับซื้อ Notebook</strong> สำหรับผู้ที่ค้นหาด้วยภาษาอังกฤษ ส่วนบริการหลักของร้านอยู่ที่หน้า
    <a href="/รับซื้อโน๊ตบุ๊คมือสอง/">รับซื้อโน๊ตบุ๊คมือสอง</a> ซึ่งครอบคลุมทุกแบรนด์และหลายสภาพเครื่องเช่นกัน
  </p>

  <h2>รูปที่ควรส่งก่อนประเมินราคา</h2>
  <ul>
    <li>รูปด้านบนและด้านล่างตัวเครื่อง — ให้เห็นรอยบุบ รอยแตก หรือสีซีด</li>
    <li>รูปหน้าจอตอนเปิด — ตรวจรอยแตก จุด dead pixel หรือรอยขีดข่วน</li>
    <li>รูปคีย์บอร์ดและทัชแพด — ปุ่มลอก ปุ่มเสีย หรือทัชแพดไม่ตอบสนอง</li>
    <li>รูปพอร์ตชาร์จและขอบจอ — จุดที่ชาร์จหลวมหรือจอแตกมักอยู่บริเวณนี้</li>
    <li>แคปหน้าจอสเปก — Windows: Settings &gt; System &gt; About / Mac: About This Mac</li>
    <li>รูปอุปกรณ์ที่มี — ที่ชาร์จ กล่อง ใบเสร็จ (ถ้ามี)</li>
  </ul>

  <h2>สเปกที่มีผลต่อราคารับซื้อ</h2>
  <h3>CPU และ RAM</h3>
  <p>
    รุ่น CPU ใหม่กว่าและแรงกว่ามักได้ราคาสูงกว่า เช่น Intel Core i5/i7 รุ่นใหม่ หรือ AMD Ryzen 5/7
    RAM 8GB เป็นฐานทั่วไป ถ้ามี 16GB ขึ้นไปมักช่วยดึงราคาได้ดีกว่า โดยเฉพาะเครื่องทำงานหรือตัดต่อ
  </p>
  <h3>SSD และการ์ดจอ</h3>
  <p>
    SSD 512GB ขึ้นไปมักได้รับการประเมินดีกว่า HDD หรือ SSD ขนาดเล็ก Notebook ที่มีการ์ดจอแยก NVIDIA/AMD
    (Gaming หรือ Workstation) มักมีตลาดรองรับกว้างกว่าเครื่องกราฟิกออนบอร์ด
  </p>

  <h2>อาการเสียที่ยังรับซื้อได้</h2>
  <ul>
    <li><strong>ไม่มีที่ชาร์จ</strong> — รับได้ แต่ราคาลดตามความครบของอุปกรณ์</li>
    <li><strong>แบตเสื่อม</strong> — รับได้ แจ้งอาการชาร์จไม่เข้าหรือถอดสายแล้วดับเร็ว</li>
    <li><strong>จอแตก/จอเป็นเส้น</strong> — รับได้ ราคาขึ้นกับขนาดความเสียหายและรุ่นจอ</li>
    <li><strong>เปิดไม่ติด</strong> — รับได้บางเคส ขึ้นกับรุ่นและว่ามีข้อมูลสเปกครบหรือไม่</li>
    <li><strong>คีย์บอร์ดบางปุ่มเสีย</strong> — รับได้ แจ้งปุ่มที่ใช้งานไม่ได้</li>
  </ul>

  <h2>ความปลอดภัยข้อมูลก่อนขาย</h2>
  <p>
    แนะนำสำรองข้อมูลสำคัญก่อนขาย จากนั้น Sign out บัญชี Microsoft/Apple และทำ Factory Reset
    หากไม่สะดวก แจ้งทีมงานได้ เราช่วยแนะนำขั้นตอนล้างข้อมูลตามระบบก่อนส่งมอบเครื่อง
  </p>

  <h2>ขั้นตอนรับซื้อ Notebook</h2>
  <ol>
    <li>แอดไลน์ @webuy ส่งรูปและสเปกตามรายการด้านบน</li>
    <li>รับราคาเบื้องต้นและยืนยันเงื่อนไขก่อนตัดสินใจ</li>
    <li>นัดรับเครื่องหรือส่งขนส่งตามพื้นที่ที่สะดวก</li>
    <li>ตรวจสภาพตามที่แจ้ง จ่ายเงินหลังตรวจรับและตกลงราคา</li>
  </ol>

  <p>
    ดูแบรนด์ยอดนิยมได้ที่ <a href="/รับซื้อโน๊ตบุ๊ค/asus/">รับซื้อ Asus</a>,
    <a href="/รับซื้อโน๊ตบุ๊ค/lenovo/">Lenovo</a> หรือ
    <a href="/รับซื้อโน๊ตบุ๊ค/gaming/">Gaming Notebook</a>
  </p>
</ServicePageShell>
