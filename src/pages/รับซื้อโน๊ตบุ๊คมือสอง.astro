---
import ServicePageShell from '../components/ServicePageShell.astro';

const title = 'รับซื้อโน๊ตบุ๊คมือสอง ประเมินตามสภาพจริง | ร้านรับซื้อโน๊ตบุ๊ค.com';
const description =
  'รับซื้อโน๊ตบุ๊คมือสองหลายยี่ห้อ ส่งรูปและสเปกเพื่อประเมินฟรี แจ้งราคาก่อนตัดสินใจขาย เทียบราคาตลาด รับทั้งเครื่องสภาพดี เครื่องเก่า และเครื่องเสียบางอาการ';

const faqs = [
  {
    question: 'รับซื้อโน๊ตบุ๊คมือสองหลายยี่ห้อไหม?',
    answer:
      'รับครับ ทั้ง Dell HP Lenovo ASUS Acer และแบรนด์อื่น ๆ ราคาขึ้นกับรุ่น สภาพการใช้งาน และอุปกรณ์ที่มี',
  },
  {
    question: 'โน๊ตบุ๊คมือสองที่แบตเสื่อมรับไหม?',
    answer:
      'รับครับ แจ้งอาการแบต เช่น ชาร์จไม่เข้า ถอดสายแล้วดับเร็ว หรือแบตบวม ราคาจะปรับตามสภาพแบตและรุ่น',
  },
  {
    question: 'ต้องล้างข้อมูลก่อนขายโน๊ตบุ๊คมือสองไหม?',
    answer:
      'แนะนำให้สำรองและล้างข้อมูลก่อนส่งมอบ หากไม่สะดวก เราช่วยแนะนำขั้นตอน reset ตามระบบได้',
  },
];
---

<ServicePageShell
  title={title}
  description={description}
  canonicalPath="/รับซื้อโน๊ตบุ๊คมือสอง/"
  breadcrumbLabel="รับซื้อโน๊ตบุ๊คมือสอง"
  serviceName="รับซื้อโน๊ตบุ๊คมือสอง"
  h1="รับซื้อโน๊ตบุ๊คมือสอง"
  h1Accent="เน้นเครื่องที่ผ่านการใช้งาน ประเมินตามสภาพจริง"
  heroSubtitle="เหมาะสำหรับเครื่องที่ผ่านการใช้งานมาแล้ว ส่งรูปและสเปกมาประเมินเบื้องต้นฟรีผ่าน LINE"
  accentClass="text-sky-400"
  gradientFrom="from-sky-900/60"
  proseLinkClass="prose-a:text-sky-600 hover:prose-a:text-sky-500"
  faqs={faqs}
>
  <p class="lead">
    หน้านี้เน้นคำว่า <strong>รับซื้อโน๊ตบุ๊คมือสอง</strong> สำหรับเครื่องที่มีประวัติการใช้งาน
    บริการหลักของร้านอยู่ที่ <a href="/">รับซื้อโน๊ตบุ๊ค</a> ซึ่งรับทั้งเครื่องใหม่และมือสอง
  </p>

  <h2>รูปที่ควรส่งก่อนประเมิน</h2>
  <ul>
    <li>รูปตัวเครื่อง 4 ด้าน — ให้เห็นรอยใช้งาน รอยบุบ หรือสีลอก</li>
    <li>รูปหน้าจอ — ตรวจรอยแตก จุดสี หรือ Backlight bleed</li>
    <li>รูปคีย์บอร์ด — ปุ่มลอก ปุ่มเสีย หรือคราบที่ล้างยาก</li>
    <li>รูปแบต/ฝาแบต (ถ้าแบตบวมหรือเสื่อม) — ช่วยประเมินได้ตรงขึ้น</li>
    <li>แคปหน้าจอสเปก CPU RAM SSD และรุ่นการ์ดจอ</li>
    <li>รูปอุปกรณ์ — ที่ชาร์จ กล่อง ใบเสร็จ (ถ้ามี)</li>
  </ul>

  <h2>สภาพมือสองที่มีผลต่อราคา</h2>
  <h3>เครื่องสภาพดี ใช้งานปกติ</h3>
  <p>
    รอยขีดข่วนเล็กน้อยหรือความมันบนคีย์บอร์ดเป็นเรื่องปกติของเครื่องมือสอง หากเปิดติด ทุกฟังก์ชันใช้ได้
    และอุปกรณ์ครบ มักได้ราคาตามสภาพจริงของตลาด
  </p>
  <h3>เครื่องมีตำหนิหรืออาการเสีย</h3>
  <p>
    จอแตก แบตเสื่อม ไม่มีที่ชาร์จ หรือเปิดไม่ติด ยังรับซื้อได้บางเคส ราคาจะปรับตามรุ่น สเปก
    และความรุนแรงของอาการ แจ้งตรงตั้งแต่แรกเพื่อให้ราคาเบื้องต้นตรงกับหน้างาน
  </p>

  <h2>สเปกที่ช่วยดึงราคาเครื่องมือสอง</h2>
  <ul>
    <li>CPU รุ่นใหม่กว่า (เช่น Core i5/i7 Gen ใหม่ หรือ Ryzen 5/7)</li>
    <li>RAM 16GB ขึ้นไป</li>
    <li>SSD 512GB ขึ้นไป (ดีกว่า HDD หรือ SSD 128GB)</li>
    <li>การ์ดจอแยกสำหรับ Gaming หรืองานกราฟิก</li>
    <li>ที่ชาร์จแท้และกล่องครบ</li>
  </ul>

  <h2>ความปลอดภัยข้อมูลก่อนขาย</h2>
  <p>
    โน๊ตบุ๊คมือสองมักมีข้อมูลส่วนตัวค้างอยู่ แนะนำสำรองไฟล์สำคัญ ออกจากบัญชี cloud
    และทำ Factory Reset ก่อนส่งมอบ หากไม่มั่นใจ ทีมงานช่วยแนะนำขั้นตอนตาม Windows หรือ macOS ได้
  </p>

  <h2>ขั้นตอนรับซื้อโน๊ตบุ๊คมือสอง</h2>
  <ol>
    <li>ส่งรูปและสเปกผ่าน LINE @webuy</li>
    <li>รับราคาเบื้องต้นและยืนยันก่อนตัดสินใจ</li>
    <li>นัดรับหรือส่งขนส่งตามพื้นที่</li>
    <li>ตรวจสภาพตามที่แจ้ง จ่ายเงินเมื่อตกลงราคา</li>
  </ol>
  <p>
    ต้องการเช็คราคาก่อนตัดสินใจ ดูหน้า <a href="/เช็คราคาโน๊ตบุ๊ค/">เช็คราคาโน๊ตบุ๊ค</a>
    หรืออ่านคู่มือ <a href="/ขายโน๊ตบุ๊ค/">ขายโน๊ตบุ๊ค</a> สำหรับขั้นตอนเตรียมเครื่อง
  </p>
</ServicePageShell>
