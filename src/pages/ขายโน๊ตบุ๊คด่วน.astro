---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAButtons from '../components/CTAButtons.astro';
import FAQ from '../components/FAQ.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import RelatedLinks from '../components/RelatedLinks.astro';
import { SITE, absoluteUrl, breadcrumbListSchema, faqPageSchema, serviceSchema } from '../lib/seo';

const title = 'ขายโน๊ตบุ๊คด่วน ได้เงินทันที ตีราคาไวใน 5 นาที | ร้านรับซื้อโน๊ตบุ๊ค.com';
const description =
  'ต้องการขายโน๊ตบุ๊คด่วน? เรารับซื้อโน๊ตบุ๊คให้ราคาสูง ประเมินราคาฟรีผ่าน LINE ใน 5 นาที นัดรับถึงที่ จ่ายเงินสดหรือโอนเข้าบัญชีทันทีหลังตรวจเครื่อง';
const canonical = absoluteUrl('/ขายโน๊ตบุ๊คด่วน/');

const breadcrumbs = [
  { name: 'หน้าแรก', url: absoluteUrl('/') },
  { name: 'ขายโน๊ตบุ๊คด่วน', url: canonical },
];

const faqs = [
  { question: 'ขายโน๊ตบุ๊คด่วน ต้องเตรียมอะไรบ้างเพื่อให้ตีราคาได้เร็วที่สุด?', answer: 'รบกวนส่งรูปตัวเครื่องทุกมุม (หน้าจอ คีย์บอร์ด ฝาหลัง ใต้เครื่อง) พร้อมถ่ายรูปสเปกหรือแจ้งชื่อรุ่นให้ชัดเจน หากมีอุปกรณ์ครบ เช่น สายชาร์จ กล่อง ใบเสร็จ จะช่วยให้ตีราคาได้ไวและได้ราคาดีขึ้นครับ' },
  { question: 'ประเมินราคาผ่าน LINE ใช้เวลานานแค่ไหน?', answer: 'หากข้อมูลครบถ้วน ทีมงานสามารถประเมินกรอบราคาเบื้องต้นให้คุณตัดสินใจได้ภายใน 5-10 นาทีในเวลาทำการครับ' },
  { question: 'ถ้าตกลงราคาแล้ว จะได้เงินตอนไหน?', answer: 'หลังจากทีมงานนัดรับและตรวจเช็กสภาพเครื่องหน้างานตรงตามที่แจ้งไว้ เราทำการโอนเงินสดเข้าบัญชีของคุณทันทีเต็มจำนวน ไม่มีการหักค่าใช้จ่ายแอบแฝง' },
  { question: 'รับซื้อโน๊ตบุ๊คถึงที่ไหม?', answer: 'เรารับซื้อถึงที่ในเขตกทม.และปริมณฑลครับ หรือนัดพบตามจุดที่สะดวกและปลอดภัย สำหรับต่างจังหวัดสามารถส่งผ่านขนส่งด่วนได้' },
  { question: 'โน๊ตบุ๊คติดรหัส เปิดไม่ติด หรือจอแตก รับซื้อไหม?', answer: 'รับประเมินตามสภาพครับ รบกวนแจ้งอาการเสียตามตรงตั้งแต่ตอนประเมินผ่าน LINE เพื่อให้ตีราคาได้แม่นยำที่สุด' },
];

const schemas = [
  breadcrumbListSchema(breadcrumbs),
  faqPageSchema(faqs),
  serviceSchema({
    name: 'บริการรับซื้อโน๊ตบุ๊คด่วน',
    url: canonical,
    description: 'บริการรับซื้อโน๊ตบุ๊คมือสองด่วนพิเศษ ประเมินราคาไว จ่ายเงินสดทันทีหลังรับเครื่อง',
  })
];

const h1 = "ขายโน๊ตบุ๊คด่วน ได้เงินทันที";
const subheading = "เรารู้ว่าเวลาของคุณมีค่า! ส่งรูปตีราคาผ่าน LINE ทราบผลใน 5 นาที นัดรับเครื่องถึงที่ จ่ายเงินสดหรือโอนทันทีไม่ยืดเยื้อ";
---

<BaseLayout title={title} description={description} canonical={canonical} schemas={schemas}>
  <!-- Hero Section -->
  <section class="relative mx-auto w-full max-w-6xl px-4 pt-12 pb-8 sm:pt-20 lg:pt-24 lg:pb-16 text-center">
    <div class="inline-flex items-center rounded-full bg-red-100 px-3 py-1 text-sm font-semibold text-red-700 ring-1 ring-inset ring-red-600/20 mb-6">
      🔥 บริการด่วนพิเศษ รับเงินใน 24 ชม.
    </div>
    <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl max-w-4xl mx-auto leading-tight">
      {h1} <br class="hidden sm:block" /> <span class="text-emerald-600">ตีราคาไว จ่ายจริง ไม่มีตุกติก</span>
    </h1>
    <p class="mt-6 text-lg leading-relaxed text-slate-600 max-w-2xl mx-auto font-medium">
      {subheading} ไม่ว่าจะเป็นเครื่องทำงานสเปกเก่า, เกมมิ่งรุ่นท็อป, หรือ MacBook เราพร้อมรับซื้อในราคาที่เป็นธรรมที่สุด
    </p>

    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        class="inline-flex w-full sm:w-auto items-center justify-center gap-2 rounded-full bg-[#06C755] px-8 py-4 text-base font-extrabold text-white shadow-lg shadow-emerald-500/30 hover:bg-[#05b34c] transition-all hover:scale-105"
        href={SITE.lineUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor">
          <path d="M24 10.304c0-5.369-5.383-9.738-12-9.738-6.616 0-12 4.369-12 9.738 0 4.814 3.55 8.888 8.535 9.619.349.074.811.233.929.544.108.283.036.711.018.918l-.134.802c-.035.215-.164.818.723.447.886-.372 4.783-2.82 6.574-4.854 1.543-1.745 2.355-3.834 2.355-6.071z"/>
        </svg>
        ส่งรูปตีราคาด่วน (รู้ผลใน 5 นาที)
      </a>
      <a
        class="inline-flex w-full sm:w-auto items-center justify-center gap-2 rounded-full bg-slate-900 px-8 py-4 text-base font-extrabold text-white shadow-lg hover:bg-slate-800 transition-all"
        href={`tel:${SITE.phone.replace(/[^0-9]/g, '')}`}
      >
        โทรสอบถามด่วน: {SITE.phone}
      </a>
    </div>
    <p class="mt-4 text-sm text-slate-500 font-medium">*เตรียมรูปเครื่องและสเปกให้พร้อม เพื่อความรวดเร็วสูงสุด</p>
  </section>

  <!-- Benefits Section -->
  <section class="bg-slate-50 py-16">
    <div class="mx-auto w-full max-w-6xl px-4">
      <h2 class="text-center text-2xl font-extrabold text-slate-900 mb-10">ทำไมต้องขายด่วนกับเรา?</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white p-8 rounded-3xl shadow-sm border border-slate-100 flex flex-col items-center text-center">
          <div class="h-14 w-14 rounded-full bg-amber-100 flex items-center justify-center mb-4">
            <span class="text-2xl">⏱️</span>
          </div>
          <h3 class="text-lg font-bold text-slate-900 mb-2">รู้ราคาใน 5 นาที</h3>
          <p class="text-sm text-slate-600 leading-relaxed">ไม่ต้องเสียเวลาเดินทางไปที่ร้าน เพียงส่งรูปเครื่องและสเปกผ่าน LINE เราประเมินราคากลางให้คุณตัดสินใจได้ทันที</p>
        </div>
        <div class="bg-white p-8 rounded-3xl shadow-sm border border-slate-100 flex flex-col items-center text-center">
          <div class="h-14 w-14 rounded-full bg-emerald-100 flex items-center justify-center mb-4">
            <span class="text-2xl">💸</span>
          </div>
          <h3 class="text-lg font-bold text-slate-900 mb-2">รับเงินสดโอนไว</h3>
          <p class="text-sm text-slate-600 leading-relaxed">เมื่อนัดหมายตรวจรับเครื่องหน้างานเสร็จสิ้น เราทำการโอนเงินเข้าบัญชีคุณทันที ไม่มีกั๊ก ไม่ลีลา ไม่ดองยอด</p>
        </div>
        <div class="bg-white p-8 rounded-3xl shadow-sm border border-slate-100 flex flex-col items-center text-center">
          <div class="h-14 w-14 rounded-full bg-blue-100 flex items-center justify-center mb-4">
            <span class="text-2xl">🛵</span>
          </div>
          <h3 class="text-lg font-bold text-slate-900 mb-2">นัดรับถึงที่ (กทม./ปริมณฑล)</h3>
          <p class="text-sm text-slate-600 leading-relaxed">สะดวกสบายยิ่งขึ้นด้วยบริการนัดรับเครื่องตามจุดที่คุณสะดวกในพื้นที่กรุงเทพและปริมณฑล หรือส่งขนส่งสำหรับต่างจังหวัด</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How to prepare section -->
  <section class="mx-auto w-full max-w-6xl px-4 py-16">
    <div class="rounded-3xl border border-slate-200 bg-white overflow-hidden shadow-sm lg:flex">
      <div class="p-8 lg:w-1/2 lg:p-12 flex flex-col justify-center">
        <h2 class="text-2xl font-extrabold text-slate-900">3 สิ่งที่ต้องเตรียม เพื่อให้ประเมินได้ "ราคาสูงที่สุด"</h2>
        <p class="mt-4 text-base leading-relaxed text-slate-600">
          เพื่อให้การตีราคาด่วนของเรามีความแม่นยำและให้ราคาที่สูงที่สุดเท่าที่จะทำได้ กรุณาเตรียมข้อมูลเหล่านี้:
        </p>
        <ul class="mt-6 space-y-4">
          <li class="flex items-start gap-3">
            <div class="flex-shrink-0 mt-0.5 w-6 h-6 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center text-sm font-bold">1</div>
            <div>
              <p class="font-bold text-slate-900 text-sm">ถ่ายรูปชัดเจนทุกมุม</p>
              <p class="text-sm text-slate-600 mt-1">หน้าจอเปิดติด, คีย์บอร์ด, ฝาหลัง, และใต้เครื่อง (ให้เห็นสติ๊กเกอร์สเปก/ซีเรียล)</p>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <div class="flex-shrink-0 mt-0.5 w-6 h-6 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center text-sm font-bold">2</div>
            <div>
              <p class="font-bold text-slate-900 text-sm">แจ้งสเปกและอุปกรณ์ที่มี</p>
              <p class="text-sm text-slate-600 mt-1">CPU, RAM, SSD, การ์ดจอ และแจ้งว่ามีสายชาร์จ กล่อง หรือใบเสร็จหรือไม่ (ถ้ามีครบจะได้ราคาเพิ่ม)</p>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <div class="flex-shrink-0 mt-0.5 w-6 h-6 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center text-sm font-bold">3</div>
            <div>
              <p class="font-bold text-slate-900 text-sm">บอกตำหนิตามตรง</p>
              <p class="text-sm text-slate-600 mt-1">เช่น แบตเสื่อม จอมีเส้น รอยบุบ หรือเปิดไม่ติด การบอกตามจริงช่วยลดปัญหาถูกกดราคาหน้างาน</p>
            </div>
          </li>
        </ul>
      </div>
      <div class="bg-slate-100 p-8 lg:w-1/2 lg:p-12 border-t border-slate-200 lg:border-t-0 lg:border-l">
        <h3 class="font-bold text-slate-900 text-lg mb-4">ตัวอย่างข้อความแชท (ก็อปปี้ไปวางได้เลย)</h3>
        <div class="bg-white p-5 rounded-2xl shadow-sm border border-slate-200 text-sm text-slate-700 font-mono leading-relaxed">
          "ต้องการขายด่วนครับ<br/>
          รุ่น: Asus ROG Strix G15<br/>
          สเปก: Ryzen 7, RAM 16GB, RTX 3060<br/>
          อุปกรณ์: มีสายชาร์จแท้ ไม่มีกล่อง<br/>
          สภาพ: ใช้งานปกติ มีรอยขีดข่วนเล็กน้อย แบตอยู่ได้ 1 ชม.<br/>
          พิกัด: โซนลาดพร้าว/รัชดา<br/>
          (แนบรูปเครื่อง 4-5 รูป)"
        </div>
        <div class="mt-6 text-center">
          <CTAButtons primaryText="คัดลอกแล้วส่งแชทเลย" secondaryText="ดูวิธีขายโน๊ตบุ๊คเพิ่มเติม" />
        </div>
      </div>
    </div>
  </section>

  <!-- Process Steps -->
  <div class="bg-white pt-8 pb-12 border-t border-slate-100">
    <ProcessSteps />
  </div>

  <RelatedLinks
    title="บริการรับซื้อที่เกี่ยวข้อง"
    links={[
      { label: 'รับซื้อโน๊ตบุ๊คมือสอง', href: '/รับซื้อโน๊ตบุ๊คมือสอง/', description: 'บริการรับซื้อโน๊ตบุ๊คทั่วไปทุกสภาพ' },
      { label: 'เช็คราคาโน๊ตบุ๊ค', href: '/เช็คราคาโน๊ตบุ๊ค/', description: 'ตารางราคาและแนวทางการประเมินตามสเปก' },
      { label: 'รับซื้อโน๊ตบุ๊คเปิดไม่ติด เครื่องเสีย', href: '/รับซื้อโน๊ตบุ๊ค/เครื่องเสีย/', description: 'อย่าเพิ่งทิ้ง! โน๊ตบุ๊คพังก็ยังเปลี่ยนเป็นเงินได้' },
      { label: 'พื้นที่ให้บริการนัดรับ', href: '/พื้นที่ให้บริการ/', description: 'เช็กเขตที่ให้บริการนัดรับเครื่องถึงที่' },
    ]}
  />

  <div class="pb-16 pt-8 bg-slate-50 border-t border-slate-100">
    <FAQ faqs={faqs} />
  </div>
</BaseLayout>
