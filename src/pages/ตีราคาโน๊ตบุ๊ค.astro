---
import ServiceLayout from '../layouts/ServiceLayout.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import PriceFactors from '../components/PriceFactors.astro';
import FAQ from '../components/FAQ.astro';
import CTAButtons from '../components/CTAButtons.astro';
import { absoluteUrl } from '../lib/seo';

const title = 'ตีราคาโน๊ตบุ๊ค ประเมินไว ตามสภาพจริง | ร้านรับซื้อโน๊ตบุ๊ค.com';
const description =
  'ตีราคาโน๊ตบุ๊คก่อนขายแบบไม่ยัดเยียด ส่งรูป + สเปก + สภาพ เราประเมินไวและอธิบายเหตุผลชัดเจน จ่ายเงินสดเมื่อรับเครื่อง';
const canonical = absoluteUrl('/ตีราคาโน๊ตบุ๊ค/');

const breadcrumbs = [
  { name: 'หน้าแรก', url: absoluteUrl('/') },
  { name: 'ตีราคาโน๊ตบุ๊ค', url: canonical },
];

const faqs = [
  {
    question: 'ตีราคาโน๊ตบุ๊คกับเช็คราคา ต่างกันอย่างไร',
    answer:
      'เช็คราคาเป็นการดูช่วงราคาจากข้อมูลเบื้องต้น ส่วนตีราคาจะละเอียดขึ้น โดยพิจารณาสเปก/สภาพ/อาการ และอุปกรณ์ที่มี เพื่อให้ใกล้เคียงราคาซื้อขายจริงมากขึ้น',
  },
  {
    question: 'ตีราคาโน๊ตบุ๊คเสียได้ไหม',
    answer:
      'ได้ครับ ถ้าเครื่องมีอาการ เช่น เปิดไม่ติด จอแตก แบตเสื่อม หรือคีย์บอร์ดเสีย แนะนำส่งรูป/วิดีโออาการและสเปกมาให้ครบ เพื่อประเมินใกล้เคียงขึ้น',
  },
  {
    question: 'ถ้าส่งรูปไม่ชัด ตีราคาได้ไหม',
    answer:
      'ได้ครับ แต่เพื่อให้แม่นยำ แนะนำถ่ายรูปหน้าจอที่เปิดติด ตัวเครื่องด้านบน/ล่าง พอร์ตต่าง ๆ และรอยตำหนิ (ถ้ามี) รวมถึงรูปสเปกหรือหน้าข้อมูลระบบ',
  },
  {
    question: 'ขอประเมินหลายเครื่องพร้อมกันได้ไหม',
    answer:
      'ได้ครับ ส่งรูปและข้อมูลแยกเป็นเครื่อง ๆ จะช่วยให้ตอบไวและไม่สับสน โดยเฉพาะถ้ามีหลายรุ่นหรือหลายสภาพ',
  },
  {
    question: 'ประเมินฟรีไหม และไม่ขายได้ไหม',
    answer:
      'ฟรีครับ คุณสามารถขอตีราคาเพื่อใช้ตัดสินใจก่อนได้ ไม่มีข้อผูกมัด หากยังไม่พร้อมขายก็ได้เช่นกัน',
  },
  {
    question: 'ต้องเตรียมอะไรเพื่อให้ตีราคาแม่นขึ้น',
    answer:
      'แนะนำส่งรูป 3–5 รูป + รุ่น/สเปก (CPU/RAM/SSD/GPU) + สภาพ/อาการ + อุปกรณ์ที่มี (ที่ชาร์จ/กล่อง) หากมีรูปสุขภาพแบตจะช่วยมาก',
  },
];
---

<ServiceLayout
  title={title}
  description={description}
  canonical={canonical}
  breadcrumbs={breadcrumbs}
  serviceName="ตีราคาโน๊ตบุ๊ค"
  faqs={faqs}
>
  <section class="mx-auto w-full max-w-6xl px-4 pt-10">
    <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">ตีราคาโน๊ตบุ๊ค ประเมินไว ตามสภาพจริง</h1>
    <p class="mt-4 text-base leading-relaxed text-slate-600">
      ถ้าคุณอยากรู้ราคาที่ “ใกล้เคียงการซื้อขายจริง” การ <strong>ตีราคาโน๊ตบุ๊ค</strong> จะช่วยได้มากกว่าการดูราคากลางแบบกว้าง ๆ.
      เราประเมินโดยดูทั้งรุ่น สเปก สภาพภายนอก สุขภาพแบต หน้าจอ และอาการที่แจ้ง รวมถึงความครบของอุปกรณ์
      เพื่อให้คุณเข้าใจว่าราคาเกิดจากอะไรและตัดสินใจได้ง่าย
    </p>
    <p class="mt-4 text-base leading-relaxed text-slate-600">
      แนวทางของเราคือ “ตีราคาแบบอธิบายได้” ไม่เว่อร์และไม่กดราคา. ถ้าข้อมูลยังไม่พอ เราจะถามเพิ่มเฉพาะที่จำเป็น
      เช่น ภาพรอยตำหนิ ภาพสุขภาพแบต หรือภาพสเปก. เมื่อคุณโอเคกับราคาประเมินแล้วจึงค่อยนัดรับเครื่อง/ส่งเครื่อง
      และจ่ายเงินทันทีเมื่อรับเครื่องตามตกลง
    </p>

    <div class="mt-6 rounded-3xl border border-slate-200 bg-slate-50 p-6">
      <h2 class="text-lg font-bold text-slate-900">พร้อมตีราคา? ส่งรูปได้เลย</h2>
      <p class="mt-2 text-sm text-slate-600">
        ถ้าต้องการเช็คราคาแบบเร็ว ๆ อาจเริ่มที่หน้า <a class="underline" href="/เช็คราคาโน๊ตบุ๊ค/">เช็คราคาโน๊ตบุ๊ค</a> ก่อนก็ได้
      </p>
      <div class="mt-4">
        <CTAButtons />
      </div>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-12">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
      <h2 class="text-xl font-extrabold text-slate-900">คำตอบสั้น (AEO): ตีราคาโน๊ตบุ๊คคืออะไร</h2>
      <p class="mt-3 text-base leading-relaxed text-slate-600">
        “ตีราคาโน๊ตบุ๊ค” คือการประเมินแบบละเอียดขึ้นจากข้อมูลจริงของเครื่อง โดยดูสเปก สภาพ อาการ และอุปกรณ์ที่มี เพื่อให้ใกล้เคียงราคาซื้อขายจริงในตลาดมือสอง
        มากกว่าการเดาราคากลางกว้าง ๆ
      </p>
      <p class="mt-3 text-base leading-relaxed text-slate-600">
        ถ้าคุณอยากตีราคาให้ไว ให้ส่งรูปเครื่องชัด ๆ 3–5 รูป + รุ่น/สเปก + สภาพ/อาการ และรูปที่ชาร์จ ถ้าเครื่องมีอาการ เช่น เปิดไม่ติด จอแตก
        ให้ส่งวิดีโออาการสั้น ๆ เพิ่ม จะช่วยมาก
      </p>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-12">
    <div class="grid gap-4 lg:grid-cols-3">
      <div class="rounded-3xl border border-slate-200 bg-slate-50 p-6">
        <h2 class="text-lg font-bold text-slate-900">ตีราคา vs เช็คราคา</h2>
        <p class="mt-2 text-sm leading-relaxed text-slate-700">
          ถ้าคุณต้องการรู้ช่วงราคาแบบเร็ว ให้เริ่มจาก “เช็คราคา” แต่ถ้าคุณอยากเข้าใจเหตุผลของราคาและประเมินตามสภาพจริงมากขึ้น ให้ใช้ “ตีราคา”
        </p>
        <p class="mt-3 text-sm leading-relaxed text-slate-700">
          ดูหน้าเช็คแบบเร็ว: <a class="underline" href="/เช็คราคาโน๊ตบุ๊ค/">เช็คราคาโน๊ตบุ๊ค</a>
        </p>
      </div>
      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm lg:col-span-2">
        <h2 class="text-lg font-bold text-slate-900">ข้อมูลที่ทำให้ตีราคาใกล้เคียงขึ้น (ส่งทีเดียวจบ)</h2>
        <ul class="mt-3 list-disc pl-5 text-sm leading-relaxed text-slate-700">
          <li><strong>รุ่น</strong>: หรือรูปสติ๊กเกอร์ใต้เครื่อง</li>
          <li><strong>สเปก</strong>: CPU / RAM / SSD และ GPU ถ้ามี</li>
          <li><strong>สภาพ</strong>: จอ/บอดี้/บานพับ/พอร์ต และรอยตำหนิ</li>
          <li><strong>แบต</strong>: หมดไว ต้องเสียบตลอด หรือบวม (ควรแจ้ง)</li>
          <li><strong>อุปกรณ์</strong>: ที่ชาร์จ กล่อง ใบเสร็จ (ถ้ามี)</li>
          <li><strong>อาการเสีย</strong> (ถ้ามี): เปิดไม่ติด จอแตก จอฟ้า ค้าง ดับเอง</li>
        </ul>
        <p class="mt-3 text-sm leading-relaxed text-slate-700">
          ถ้ายังไม่แน่ใจสเปก อ่านต่อ:
          <a class="underline" href="/blog/วิธีดูสเปก-cpu-ram-ssd-ของโน๊ตบุ๊ค/">วิธีดูสเปก CPU RAM SSD</a>
        </p>
      </div>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-12">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
      <h2 class="text-xl font-extrabold text-slate-900">ตัวอย่างข้อความที่ใช้ “ตีราคา” ได้เลย</h2>
      <div class="mt-3 rounded-2xl border border-slate-200 bg-slate-50 p-4 text-sm leading-relaxed text-slate-800">
        ขอช่วยตีราคาโน๊ตบุ๊คครับ
        <br />รุ่น ______ (แนบรูปใต้เครื่อง)
        <br />สเปก: CPU ______ / RAM ___GB / SSD ___GB / GPU ______ (ถ้ามี)
        <br />สภาพ: ______ (มีรอย/จอมีเส้น/แบตเสื่อม/ปกติ)
        <br />อุปกรณ์: มีที่ชาร์จ/มีกล่อง (ถ้ามี)
        <br />อยู่โซน ______
      </div>
      <p class="mt-4 text-sm leading-relaxed text-slate-700">
        ถ้าเครื่องมีอาการ เช่น เปิดไม่ติด หรือจอแตก แนะนำส่งวิดีโออาการ 5–10 วินาที เพื่อประเมินตามสภาพจริงได้ใกล้เคียงขึ้น
      </p>
      <div class="mt-5">
        <CTAButtons />
      </div>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-12">
    <div class="rounded-3xl border border-slate-200 bg-slate-50 p-6 shadow-sm sm:p-8">
      <h2 class="text-xl font-extrabold text-slate-900">ตีราคาให้ใกล้เคียงจริง: ส่งข้อมูลแบบไหนดี</h2>
      <p class="mt-3 text-base leading-relaxed text-slate-700">
        การตีราคาจะใกล้เคียงขึ้นมาก ถ้าข้อมูล “ครบและชัด” ตั้งแต่ต้น โดยเฉพาะรูปสภาพจริงและสเปกปัจจุบัน
      </p>
      <div class="mt-4 grid gap-4 lg:grid-cols-2">
        <div class="rounded-2xl border border-slate-200 bg-white p-5">
          <h3 class="text-base font-bold text-slate-900">รูปที่ควรมี (อย่างน้อย 5 รูป)</h3>
          <ul class="mt-2 list-disc pl-5 text-sm leading-relaxed text-slate-700">
            <li>หน้าเครื่องเปิดจอ</li>
            <li>คีย์บอร์ด/ทัชแพด</li>
            <li>ใต้เครื่อง/สติ๊กเกอร์รุ่น</li>
            <li>มุมเครื่องและพอร์ต</li>
            <li>ที่ชาร์จ</li>
          </ul>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white p-5">
          <h3 class="text-base font-bold text-slate-900">ข้อมูลที่ควรพิมพ์แนบ (สั้น ๆ ก็พอ)</h3>
          <ul class="mt-2 list-disc pl-5 text-sm leading-relaxed text-slate-700">
            <li>CPU / RAM / SSD และ GPU ถ้ามี</li>
            <li>สภาพ: มีรอยไหม จอมีเส้นไหม แบตหมดไวไหม</li>
            <li>อุปกรณ์: มีที่ชาร์จไหม มีกล่องไหม</li>
            <li>พื้นที่: อยู่โซนไหน เพื่อแนะนำวิธีนัดรับ/ส่งเครื่อง</li>
          </ul>
        </div>
      </div>
      <p class="mt-4 text-sm leading-relaxed text-slate-700">
        ถ้ายังไม่แน่ใจสเปก อ่านต่อได้ที่
        <a class="underline" href="/blog/วิธีดูสเปก-cpu-ram-ssd-ของโน๊ตบุ๊ค/">วิธีดูสเปก CPU RAM SSD</a>
      </p>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-12">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
      <h2 class="text-xl font-extrabold text-slate-900">ตีราคาเครื่องเสีย (เปิดไม่ติด/จอแตก/แบตเสื่อม) ทำได้ไหม</h2>
      <p class="mt-3 text-base leading-relaxed text-slate-600">
        ทำได้ครับ แต่ควรส่งรูป/วิดีโออาการประกอบเพื่อให้ประเมินใกล้เคียงขึ้น เช่น วิดีโอกดเปิดเครื่อง 5–10 วินาที หรือรูปจอบนพื้นหลังขาว/ดำ
      </p>
      <div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        <a class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-semibold text-slate-900 hover:bg-emerald-50 hover:border-emerald-200" href="/blog/โน๊ตบุ๊คเปิดไม่ติดขายได้ไหม/">เปิดไม่ติด</a>
        <a class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-semibold text-slate-900 hover:bg-emerald-50 hover:border-emerald-200" href="/blog/โน๊ตบุ๊คจอแตกยังมีราคาไหม/">จอแตก</a>
        <a class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-semibold text-slate-900 hover:bg-emerald-50 hover:border-emerald-200" href="/blog/โน๊ตบุ๊คแบตเสื่อมขายได้ไหม/">แบตเสื่อม</a>
        <a class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-semibold text-slate-900 hover:bg-emerald-50 hover:border-emerald-200" href="/blog/โน๊ตบุ๊คเสียขายได้ไหม/">เครื่องเสีย (รวม)</a>
      </div>
      <p class="mt-3 text-sm leading-relaxed text-slate-700">
        ถ้าเป็นเครื่องเกมมิ่ง ให้ส่งรุ่น GPU และรูปที่ชาร์จด้วย จะช่วยให้ตีราคาได้ใกล้เคียงขึ้น
      </p>
      <div class="mt-5">
        <CTAButtons />
      </div>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-12">
    <div class="rounded-3xl border border-slate-200 bg-slate-50 p-6 shadow-sm sm:p-8">
      <h2 class="text-xl font-extrabold text-slate-900">สรุปแบบเร็ว: อยากตีราคาให้ตรง ต้องทำอะไร</h2>
      <ul class="mt-3 list-disc pl-5 text-base leading-relaxed text-slate-700">
        <li>ส่งรูปสภาพจริงให้ชัด (โดยเฉพาะจอ มุมเครื่อง และที่ชาร์จ)</li>
        <li>ส่งสเปกปัจจุบัน หรือส่งรูปหน้าจอให้ร้านอ่านให้</li>
        <li>แจ้งอาการตามจริง ถ้ามี (เปิดไม่ติด/จอแตก/แบตเสื่อม)</li>
        <li>ระบุพื้นที่เพื่อแนะนำวิธีนัดรับ/ส่งเครื่อง</li>
      </ul>
      <p class="mt-4 text-sm leading-relaxed text-slate-700">
        พร้อมเริ่มแล้ว แอดไลน์ <strong>@webuy</strong> ส่งข้อมูลได้เลย หรือโทร <strong>0642579353</strong>
      </p>
      <p class="mt-2 text-xs text-slate-500">
        ถ้าคุณไม่แน่ใจว่าควรถ่ายรูปมุมไหน ให้เริ่มจากรูปใต้เครื่องและรูปที่ชาร์จก่อน แล้วค่อยเติมรูปจอและมุมเครื่องตามที่สะดวก
      </p>
      <p class="mt-2 text-xs text-slate-500">ส่งข้อมูลให้ครบตั้งแต่แรก จะช่วยให้ตีราคาใกล้เคียงขึ้นมาก</p>
      <p class="mt-2 text-xs text-slate-500">เริ่มได้เลยครับ</p>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-12">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
      <h2 class="text-xl font-extrabold text-slate-900">ตีราคาโน๊ตบุ๊คแบบตามสภาพจริง (อธิบายเหตุผลได้)</h2>
      <p class="mt-3 text-base leading-relaxed text-slate-600">
        หลายคนเคยเจอประสบการณ์ “ถามราคาคร่าว ๆ แล้วพอไปจริงราคาต่างมาก” สาเหตุส่วนใหญ่ไม่ได้เกิดจากการตั้งใจเล่นราคา
        แต่เกิดจากข้อมูลที่ส่งมายังไม่เห็น “จุดสำคัญ” เช่น รอยมุมเครื่อง จอมีเส้น แบตบวม หรือพอร์ตหลวม
      </p>
      <p class="mt-3 text-base leading-relaxed text-slate-600">
