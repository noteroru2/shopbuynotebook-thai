---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAButtons from '../components/CTAButtons.astro';
import FAQ from '../components/FAQ.astro';
import { SITE, absoluteUrl } from '../lib/seo';
import { breadcrumbListSchema, faqPageSchema } from '../lib/seo';

const title = 'ติดต่อเรา | ร้านรับซื้อโน๊ตบุ๊ค.com';
const description =
  'ติดต่อร้านรับซื้อโน๊ตบุ๊ค.com เพื่อส่งรูปประเมินราคา หรือสอบถามรายละเอียด รับซื้อโน๊ตบุ๊คมือสองทุกยี่ห้อ ประเมินฟรี จ่ายเงินสด';
const canonical = absoluteUrl('/ติดต่อเรา/');

const breadcrumbs = [
  { name: 'หน้าแรก', url: absoluteUrl('/') },
  { name: 'ติดต่อเรา', url: canonical },
];

const faqs = [
  {
    question: 'ติดต่อช่องทางไหนเร็วที่สุด',
    answer: 'แนะนำแอดไลน์ @webuy แล้วส่งรูปเครื่อง + รุ่น/สเปก + สภาพ/อาการ จะประเมินได้ไวที่สุดครับ',
  },
  {
    question: 'เช็คราคาโน๊ตบุ๊คฟรีไหม',
    answer: 'ฟรีครับ สามารถส่งข้อมูลเพื่อประเมินเบื้องต้นก่อนตัดสินใจขายได้',
  },
  {
    question: 'อยู่ต่างจังหวัดติดต่อได้ไหม',
    answer: 'ได้ครับ ส่งโลเคชันและข้อมูลเครื่องมาได้ เราช่วยแนะนำแนวทางนัดรับ/ส่งเครื่องที่เหมาะกับพื้นที่',
  },
  {
    question: 'เวลาทำการคือช่วงไหน',
    answer: 'ทุกวัน 10:00–20:00 ครับ หากนอกเวลาสามารถทิ้งข้อความในไลน์ @webuy ได้',
  },
];

const schemas = [breadcrumbListSchema(breadcrumbs), faqPageSchema(faqs)];
---

<BaseLayout title={title} description={description} canonical={canonical} schemas={schemas}>
  <section class="mx-auto w-full max-w-6xl px-4 pt-10">
    <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">ติดต่อเรา</h1>
    <p class="mt-4 text-base leading-relaxed text-slate-600">
      วิธีที่เร็วที่สุดคือแอดไลน์ @webuy แล้วส่งรูป + รุ่น/สเปก + อาการ. หากต้องการคุยก่อน โทรได้ตามเบอร์ด้านล่าง
    </p>

    <div class="mt-6 grid gap-4 sm:grid-cols-2">
      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <p class="text-sm font-semibold text-slate-900">โทรศัพท์</p>
        <a class="mt-2 inline-flex text-lg font-bold text-slate-900 underline underline-offset-4" href={`tel:${SITE.telephone}`}>
          {SITE.telephone}
        </a>
        <p class="mt-2 text-sm text-slate-600">เวลาแนะนำ: ทุกวัน 10:00–20:00</p>
      </div>
      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <p class="text-sm font-semibold text-slate-900">LINE</p>
        <a class="mt-2 inline-flex text-lg font-bold text-emerald-600 underline underline-offset-4" href={SITE.lineUrl} target="_blank" rel="noopener noreferrer">
          แอดไลน์ @webuy ส่งรูปประเมินราคา
        </a>
        <p class="mt-2 text-sm text-slate-600">
          LINE: <span class="font-semibold">{SITE.lineHandle}</span> (ส่งรูป + รุ่น/สเปก + อาการ เพื่อประเมินได้ไว)
        </p>
      </div>
      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:col-span-2">
        <p class="text-sm font-semibold text-slate-900">หน้าร้านจริง ({SITE.physicalStoreName})</p>
        <p class="mt-2 text-sm text-slate-600">
          นำทางหรือดูทำเลได้จาก Google Maps — เหมาะสำหรับผู้ที่ต้องการเข้ามาติดต่อหรือส่งของถึงที่ร้าน (โปรดแจ้งนัดผ่าน LINE เพื่อความสะดวก)
        </p>
        <a
          class="mt-4 inline-flex items-center justify-center rounded-2xl border border-emerald-200 bg-emerald-50 px-5 py-3 text-sm font-extrabold text-emerald-900 hover:bg-emerald-100"
          href={SITE.googleMapsUrl}
          target="_blank"
          rel="noopener noreferrer"
        >
          เปิด Google Maps — {SITE.physicalStoreName}
        </a>
      </div>
    </div>

    <div class="mt-6 rounded-3xl border border-slate-200 bg-slate-50 p-6">
      <p class="text-sm font-semibold text-slate-900">พื้นที่ให้บริการ</p>
      <p class="mt-2 text-sm text-slate-700">
        กรุงเทพและปริมณฑล • ทุกจังหวัดในภาคอีสาน • สระแก้ว • จันทบุรี • ตราด • พัทลุง • ภูเก็ต • หาดใหญ่/สงขลา — ดูรายละเอียดที่หน้า <a class="underline" href="/พื้นที่ให้บริการ/">พื้นที่ให้บริการ</a>
      </p>
      <p class="mt-3 text-sm text-slate-700">
        โซเชียล: <a class="underline" href={SITE.sameAs.facebook} target="_blank" rel="noopener noreferrer">Facebook</a> •{' '}
        <a class="underline" href={SITE.sameAs.tiktok} target="_blank" rel="noopener noreferrer">TikTok</a>
      </p>
    </div>

    <div class="mt-8">
      <CTAButtons />
    </div>
  </section>

  <FAQ title="คำถามสั้น ๆ ก่อนติดต่อ" faqs={faqs} />
</BaseLayout>

