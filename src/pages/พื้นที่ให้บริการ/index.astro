---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQ from '../../components/FAQ.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import SeoCTA from '../../components/SeoCTA.astro';
import { SITE } from '../../config/site';
import { absoluteUrl, breadcrumbListSchema, faqPageSchema } from '../../lib/seo';
import { locationFaqs } from '../../data/faqs';
import { serviceAreaGroups } from '../../data/service-areas';

const title = 'พื้นที่ให้บริการรับซื้อโน๊ตบุ๊ค | กรุงเทพ ปริมณฑล อีสาน ภูเก็ต หาดใหญ่';
const description =
  'ดูพื้นที่ให้บริการรับซื้อโน๊ตบุ๊ค กรุงเทพและปริมณฑล ทุกจังหวัดในภาคอีสาน สระแก้ว จันทบุรี ตราด พัทลุง ภูเก็ต หาดใหญ่ และสงขลา';
const canonical = absoluteUrl('/พื้นที่ให้บริการ/');

const breadcrumbs = [
  { name: 'หน้าแรก', url: absoluteUrl('/') },
  { name: 'พื้นที่ให้บริการ', url: canonical },
];

const faqs = locationFaqs.slice(0, 6);
const schemas = [breadcrumbListSchema(breadcrumbs), faqPageSchema(faqs)];
---

<BaseLayout title={title} description={description} canonical={canonical} schemas={schemas}>
  <section class="mx-auto w-full max-w-6xl px-4 pt-10">
    <h1 class="text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">พื้นที่ให้บริการรับซื้อโน๊ตบุ๊ค</h1>
    <p class="mt-4 text-base leading-relaxed text-slate-600">
      ไม่ว่าคุณจะอยู่พื้นที่ไหน แนะนำเริ่มจาก <strong>ส่งรูปประเมินราคา</strong> ผ่าน LINE ก่อน เพื่อให้เช็คราคาเบื้องต้นได้ไว
      จากนั้นค่อยเลือกวิธีรับเครื่องที่เหมาะกับพื้นที่ เช่น นัดรับ/นัดเจอในโซนที่สะดวก หรือส่งเครื่องตามแนวทางที่ตกลงกัน
    </p>
    <p class="mt-4 text-base leading-relaxed text-slate-600">
      พื้นที่ให้บริการของเราอัปเดตตามข้อมูลในเว็บไซต์และ schema: {SITE.serviceAreaGroups.map((g) => g.group).join(' • ')}
    </p>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-10">
    <div class="rounded-3xl border border-slate-200 bg-slate-50 p-6 shadow-sm sm:p-8">
      <h2 class="text-xl font-extrabold text-slate-900">คำตอบสั้น (AEO): อยู่ต่างจังหวัดขายโน๊ตบุ๊คได้ไหม</h2>
      <p class="mt-3 text-base leading-relaxed text-slate-700">
        ได้ครับ คุณสามารถเริ่มจากส่งรูปเครื่อง รุ่น/สเปก และสภาพผ่าน LINE เพื่อเช็คราคาเบื้องต้นก่อน จากนั้นเราจะแนะนำวิธีที่เหมาะกับพื้นที่ของคุณ
        เช่น นัดเจอในโซนที่สะดวก หรือส่งเครื่องผ่านขนส่งตามขั้นตอนที่ตกลงกัน
      </p>
      <p class="mt-3 text-sm leading-relaxed text-slate-700">
        พร้อมเริ่ม แอดไลน์ <strong>{SITE.lineHandle}</strong> หรือโทร <strong>{SITE.phone}</strong>
      </p>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-10">
    <div class="grid gap-4 lg:grid-cols-2">
      {serviceAreaGroups.map((g) => (
        <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
          <h2 class="text-lg font-extrabold text-slate-900">{g.group}</h2>
          <p class="mt-2 text-sm text-slate-700">
            {g.areas.join(' • ')}
          </p>
        </div>
      ))}
    </div>
    <p class="mt-4 text-xs text-slate-500">
      หมายเหตุ: ถ้าพื้นที่ของคุณไม่ได้อยู่ในรายการด้านบน สามารถส่งโลเคชันมาได้ เราช่วยแนะนำทางเลือกที่เหมาะที่สุด
    </p>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-10">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
      <h2 class="text-xl font-extrabold text-slate-900">ต้องส่งอะไรเพื่อให้ประเมินไว (ใช้ได้ทุกพื้นที่)</h2>
      <ul class="mt-4 list-disc pl-5 text-base leading-relaxed text-slate-600">
        <li>รูป 3–5 รูป: หน้าเครื่องเปิดจอ, คีย์บอร์ด, ใต้เครื่อง/สติ๊กเกอร์รุ่น, มุมเครื่อง, ที่ชาร์จ</li>
        <li>สเปก: CPU/RAM/SSD และ GPU ถ้ามี (หรือส่งรูป Task Manager ให้ร้านอ่านให้)</li>
        <li>สภาพ/อาการ: ใช้งานปกติ / มีรอย / แบตเสื่อม / จอมีเส้น / เปิดไม่ติด</li>
        <li>โลเคชันหรือโซนคร่าว ๆ เพื่อแนะนำวิธีนัดรับ/ส่งเครื่องที่เหมาะที่สุด</li>
      </ul>
      <p class="mt-3 text-sm leading-relaxed text-slate-700">
        ถ้าเครื่องมีอาการ แนะนำส่งวิดีโออาการ 5–10 วินาทีด้วย จะช่วยมาก
      </p>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-10">
    <div class="rounded-3xl border border-slate-200 bg-slate-50 p-6 shadow-sm sm:p-8">
      <h2 class="text-xl font-extrabold text-slate-900">การส่งเครื่องทางขนส่ง (เช็กลิสต์สั้น ๆ)</h2>
      <ul class="mt-3 list-disc pl-5 text-base leading-relaxed text-slate-700">
        <li>ถ่ายวิดีโอสภาพเครื่องก่อนแพ็ก (เห็นจอและตัวเครื่อง)</li>
        <li>กันกระแทกมุมเครื่องและฝาจอเป็นพิเศษ</li>
        <li>แยกที่ชาร์จใส่ซองกันกระแทก ไม่ให้กดทับเครื่อง</li>
        <li>ใช้ขนส่งที่มี tracking และเก็บเลขพัสดุไว้</li>
      </ul>
      <p class="mt-4 text-sm leading-relaxed text-slate-700">
        ถ้าคุณต้องการให้เราแนะนำวิธีส่งที่เหมาะกับเคสของคุณ ส่งรูปและโลเคชันมาก่อน แล้วค่อยคุยขั้นตอนที่สบายใจได้
      </p>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-10">
    <div class="rounded-3xl border border-slate-200 bg-slate-50 p-6 shadow-sm sm:p-8">
      <h2 class="text-lg font-extrabold text-slate-900">ลิงก์พื้นที่ยอดนิยม (กรุงเทพ/ปริมณฑล)</h2>
      <div class="mt-4 flex flex-wrap gap-2">
        {[
          { label: 'กรุงเทพ', href: '/รับซื้อโน๊ตบุ๊ค/กรุงเทพ/' },
          { label: 'นนทบุรี', href: '/รับซื้อโน๊ตบุ๊ค/นนทบุรี/' },
          { label: 'ปทุมธานี', href: '/รับซื้อโน๊ตบุ๊ค/ปทุมธานี/' },
          { label: 'สมุทรปราการ', href: '/รับซื้อโน๊ตบุ๊ค/สมุทรปราการ/' },
          { label: 'บางนา', href: '/รับซื้อโน๊ตบุ๊ค/บางนา/' },
          { label: 'ลาดพร้าว', href: '/รับซื้อโน๊ตบุ๊ค/ลาดพร้าว/' },
          { label: 'รังสิต', href: '/รับซื้อโน๊ตบุ๊ค/รังสิต/' },
          { label: 'พระราม 2', href: '/รับซื้อโน๊ตบุ๊ค/พระราม2/' },
          { label: 'รามคำแหง', href: '/รับซื้อโน๊ตบุ๊ค/รามคำแหง/' },
          { label: 'ห้วยขวาง', href: '/รับซื้อโน๊ตบุ๊ค/ห้วยขวาง/' },
        ].map((l) => (
          <a
            href={l.href}
            class="rounded-full border border-slate-200 bg-white px-3 py-1.5 text-xs font-semibold text-slate-800 shadow-sm hover:bg-emerald-50 hover:border-emerald-200"
          >
            {l.label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-10">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
      <h2 class="text-xl font-extrabold text-slate-900">นัดรับ/นัดเจอ vs ส่งขนส่ง (เลือกแบบไหนดี)</h2>
      <p class="mt-3 text-base leading-relaxed text-slate-600">
        วิธีรับเครื่องที่เหมาะสมขึ้นกับพื้นที่และความสะดวกของคุณ โดยทั่วไปมี 2 แนวทางหลัก คือ “นัดรับ/นัดเจอ” และ “ส่งเครื่องทางขนส่ง”
        ทั้งสองแบบสามารถเริ่มจากการส่งรูปเพื่อเช็คราคาเบื้องต้นได้เหมือนกัน
      </p>
      <div class="mt-4 grid gap-4 lg:grid-cols-2">
        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
          <h3 class="text-base font-bold text-slate-900">นัดรับ/นัดเจอ</h3>
          <ul class="mt-2 list-disc pl-5 text-sm leading-relaxed text-slate-700">
            <li>เหมาะกับพื้นที่ที่เดินทางสะดวก หรือมีจุดนัดที่ชัดเจน</li>
            <li>ข้อดีคือคุยรายละเอียดหน้างานได้ง่ายและตรวจสภาพได้ทันที</li>
            <li>ควรเลือกจุดนัดที่ปลอดภัยและมีคนเยอะ</li>
          </ul>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
          <h3 class="text-base font-bold text-slate-900">ส่งเครื่องทางขนส่ง</h3>
          <ul class="mt-2 list-disc pl-5 text-sm leading-relaxed text-slate-700">
            <li>เหมาะกับต่างจังหวัด หรือคนที่ไม่สะดวกนัดเจอ</li>
            <li>ข้อดีคือประหยัดเวลา แต่ต้องแพ็กให้แน่นและมีหลักฐาน</li>
            <li>ควรใช้ขนส่งที่มี tracking และเก็บเลขพัสดุไว้</li>
          </ul>
        </div>
      </div>
      <p class="mt-4 text-sm leading-relaxed text-slate-700">
        ถ้าคุณไม่แน่ใจว่าเคสของคุณเหมาะกับแบบไหน ให้ส่งรูป + โลเคชันมาได้ เราช่วยแนะนำทางเลือกที่เหมาะที่สุด
      </p>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-10">
    <div class="rounded-3xl border border-slate-200 bg-slate-50 p-6 shadow-sm sm:p-8">
      <h2 class="text-xl font-extrabold text-slate-900">ตัวอย่างข้อความที่ส่งเพื่อระบุพื้นที่ (คัดลอกได้)</h2>
      <div class="mt-4 grid gap-4 lg:grid-cols-2">
        <div class="rounded-2xl border border-slate-200 bg-white p-4 text-sm leading-relaxed text-slate-800">
          ขอเช็คราคาโน๊ตบุ๊คครับ
          <br />อยู่โซน ______ (แนบโลเคชันได้)
          <br />รุ่น ______ (แนบรูปใต้เครื่อง)
          <br />สเปก: CPU ______ / RAM ___GB / SSD ___GB
          <br />สภาพใช้งานปกติ มีที่ชาร์จ
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white p-4 text-sm leading-relaxed text-slate-800">
          ขอประเมินโน๊ตบุ๊คตามสภาพครับ
          <br />อยู่โซน ______ (แนบโลเคชันได้)
          <br />รุ่น ______ (แนบรูปใต้เครื่อง)
          <br />อาการ: ______ (เปิดไม่ติด/จอแตก/แบตเสื่อม)
          <br />มีที่ชาร์จครับ (แนบรูป)
        </div>
      </div>
      <p class="mt-4 text-sm leading-relaxed text-slate-700">
        ถ้าคุณส่งรูปให้ครบและแจ้งพื้นที่ให้ชัด เราจะช่วยประเมินและแนะนำวิธีรับเครื่องที่เหมาะที่สุดได้ไวขึ้นมาก
      </p>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-10">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
      <h2 class="text-xl font-extrabold text-slate-900">กรุงเทพและปริมณฑล: เลือกจุดนัดอย่างไรให้ปลอดภัยและสะดวก</h2>
      <p class="mt-3 text-base leading-relaxed text-slate-700">
        พื้นที่เมืองใหญ่มีตัวเลือกการเดินทางหลากหลาย แต่หลักการเดียวกันคือควรเลือกจุดนัดที่มีคนพลุกพล่าน เดินทางเข้าออกสะดวก และมีแสงสว่างเพียงพอถ้าต้องตรวจเครื่องหน้างาน ถ้าคุณอยู่โซนที่มีหลายเขตให้เลือก ให้พิมพ์โลเคชันคร่าว ๆ ในไลน์เพื่อให้เราช่วยหาจุดพบที่เหมาะสมได้เร็วขึ้น
      </p>
      <p class="mt-3 text-base leading-relaxed text-slate-700">
        การพกเครื่องในกระเป๋าที่มีซับฟองหรือปลอกป้องกันแรงกระแทกช่วยลดความเสี่ยงระหว่างเดินทาง และควรถ่ายรูปสภาพเครื่องก่อนออกจากบ้านเป็นหลักฐานเล็กน้อยที่เป็นประโยชน์ต่อทั้งสองฝ่ายหากเกิดเหตุไม่คาดคิดระหว่างทาง
      </p>
      <p class="mt-3 text-sm leading-relaxed text-slate-700">
        สำหรับคีย์เวิร์ดที่เกี่ยวข้องกับการประเมินเบื้องต้น แนะนำเริ่มจากหน้า <a class="underline" href="/เช็คราคาโน๊ตบุ๊ค/">เช็คราคาโน๊ตบุ๊ค</a> แล้วค่อยเลือกทางลัดพื้นที่จากปุ่มด้านบนของหน้านี้
      </p>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-10">
    <div class="rounded-3xl border border-slate-200 bg-slate-50 p-6 shadow-sm sm:p-8">
      <h2 class="text-xl font-extrabold text-slate-900">รับซื้อโน๊ตบุ๊คภาคอีสาน</h2>
      <p class="mt-3 text-base leading-relaxed text-slate-700">
        ภาคอีสานมีหลายจังหวัดและระยะทางภายในจังหวัดที่แตกต่างกัน ดังนั้นการขายโน๊ตบุ๊คมือสองหรือการขอประเมินราคาเบื้องต้นจึงควรเริ่มจากการส่งรูปและสเปกผ่านไลน์ {SITE.lineHandle} ก่อนเสมอ
        เพื่อให้ได้กรอบราคาและขั้นตอนที่ชัดเจนก่อนตัดสินใจเดินทางหรือส่งขนส่ง ไม่ว่าคุณจะอยู่เขตเมืองหรืออำเภอรอบนอก การแจ้งชื่ออำเภอคร่าว ๆ พร้อมรูปเครื่องจะช่วยให้คุยเรื่องแนวทางนัดพบในบริเวณตัวเมือง จุดขนส่ง หรือสถานที่สาธารณะได้เหมาะสมขึ้น
        โดยยังคงต้องสอบถามพื้นที่ให้บริการและเงื่อนไขการนัดหรือส่งเครื่องในแชท ไม่ควรสรุปล่วงหน้าว่ามีหน้าร้านหรือทีมรับถึงที่ในทุกจังหวัด
      </p>
      <p class="mt-3 text-base leading-relaxed text-slate-700">
        หากต้องการภาพรวมคีย์เวิร์ด <strong>รับซื้อโน๊ตบุ๊คภาคอีสาน</strong> อ่านหน้า{' '}
        <a class="font-semibold text-emerald-700 underline underline-offset-4 hover:text-emerald-800" href="/รับซื้อโน๊ตบุ๊ค/ภาคอีสาน/">รับซื้อโน๊ตบุ๊คภาคอีสาน</a>
        {' '}        จากนั้นเลือกเข้าไปหน้าจังหวัดของคุณเพื่อดูรายชื่ออำเภอสำคัญและคำถามที่พบบ่อยเฉพาะพื้นที่
        ทุกหน้าเน้นการประเมินเบื้องต้นผ่านไลน์ {SITE.lineHandle} และการโทร {SITE.phone} เพื่อสอบถามขั้นตอนก่อนส่งมอบเครื่อง
      </p>
      <p class="mt-3 text-sm leading-relaxed text-slate-700">
        ต้องการทางลัดบริการโดยรวมก่อนเลือกพื้นที่ละเอียด ให้อ่านหน้า <a class="underline" href="/รับซื้อโน๊ตบุ๊ค/">รับซื้อโน๊ตบุ๊ค</a> ·{' '}
