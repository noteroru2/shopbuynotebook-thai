---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQ from '../../components/FAQ.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import { getCollection } from 'astro:content';
import { SITE } from '../../config/site';
import { absoluteUrl, breadcrumbListSchema, faqPageSchema } from '../../lib/seo';
import { locationFaqs } from '../../data/faqs';

const title = 'พื้นที่ให้บริการรับซื้อโน๊ตบุ๊ค | กรุงเทพ ปริมณฑล อีสาน เหนือ กลาง ใต้ และทุกจังหวัด';
const description =
  'ดูพื้นที่ให้บริการรับซื้อโน๊ตบุ๊คครอบคลุมทุกภาค 77 จังหวัดทั่วไทย พร้อมหน้าพื้นที่ให้บริการแต่ละจังหวัดสำหรับเช็กราคาโน๊ตบุ๊คก่อนขาย';
const canonical = absoluteUrl('/พื้นที่ให้บริการ/');

const breadcrumbs = [
  { name: 'หน้าแรก', url: absoluteUrl('/') },
  { name: 'พื้นที่ให้บริการ', url: canonical },
];

const faqs = locationFaqs.slice(0, 6);
const schemas = [breadcrumbListSchema(breadcrumbs), faqPageSchema(faqs)];

// ดึงข้อมูล location ทั้งหมดและจัดกลุ่มตาม region
const allLocations = await getCollection('locations');

const locationsByRegion: Record<string, typeof allLocations> = {};
allLocations.forEach((loc) => {
  const region = loc.data.region || 'พื้นที่อื่นๆ';
  if (!locationsByRegion[region]) {
    locationsByRegion[region] = [];
  }
  locationsByRegion[region].push(loc);
});

// เรียงจังหวัดตามตัวอักษรในแต่ละภูมิภาค
Object.keys(locationsByRegion).forEach((region) => {
  locationsByRegion[region].sort((a, b) => a.data.title.localeCompare(b.data.title, 'th'));
});

// ลำดับภูมิภาคที่ต้องการแสดงก่อนหลัง
const regionOrder = [
  'กรุงเทพและปริมณฑล',
  'ภาคกลาง',
  'ภาคเหนือ',
  'ภาคอีสาน',
  'ภาคตะวันออก',
  'ภาคตะวันตก',
  'ภาคใต้'
];

const sortedRegions = Object.keys(locationsByRegion).sort((a, b) => {
  const indexA = regionOrder.indexOf(a);
  const indexB = regionOrder.indexOf(b);
  if (indexA !== -1 && indexB !== -1) return indexA - indexB;
  if (indexA !== -1) return -1;
  if (indexB !== -1) return 1;
  return a.localeCompare(b, 'th');
});

---

<BaseLayout title={title} description={description} canonical={canonical} schemas={schemas}>
  <section class="mx-auto w-full max-w-6xl px-4 pt-10">
    <h1 class="text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">พื้นที่ให้บริการรับซื้อโน๊ตบุ๊ค ทั่วประเทศ</h1>
    <p class="mt-4 text-base leading-relaxed text-slate-600">
      ไม่ว่าคุณจะอยู่พื้นที่ไหน แนะนำเริ่มจาก <strong>ส่งรูปประเมินราคา</strong> ผ่าน LINE ก่อน เพื่อให้เช็คราคาเบื้องต้นได้ไว
      จากนั้นค่อยเลือกวิธีรับเครื่องที่เหมาะกับพื้นที่ เช่น นัดรับ/นัดเจอในโซนที่สะดวก หรือส่งเครื่องผ่านขนส่ง
    </p>
    <p class="mt-4 text-base leading-relaxed text-slate-600">
      ปัจจุบันเรารองรับพื้นที่ให้บริการครอบคลุมทุกภูมิภาคทั่วไทยกว่า 77 จังหวัด และพื้นที่สำคัญต่างๆ ลองเลือกพื้นที่ของคุณจากรายการด้านล่างได้เลย
    </p>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-10">
    <div class="rounded-3xl border border-slate-200 bg-slate-50 p-6 shadow-sm sm:p-8">
      <h2 class="text-xl font-extrabold text-slate-900">คำตอบสั้น (AEO): อยู่ต่างจังหวัดขายโน๊ตบุ๊คได้ไหม</h2>
      <p class="mt-3 text-base leading-relaxed text-slate-700">
        ได้ครับ คุณสามารถเริ่มจากส่งรูปเครื่อง รุ่น/สเปก และสภาพผ่าน LINE เพื่อเช็คราคาเบื้องต้นก่อน จากนั้นเราจะแนะนำวิธีที่เหมาะกับพื้นที่ของคุณ
        เช่น นัดเจอในโซนที่สะดวก หรือส่งเครื่องผ่านขนส่งตามขั้นตอนที่ตกลงกัน
      </p>
      <p class="mt-3 text-sm leading-relaxed text-slate-700">
        พร้อมเริ่ม แอดไลน์ <strong>{SITE.lineHandle}</strong> หรือโทร <strong>{SITE.phone}</strong>
      </p>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-10">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
      <h2 class="text-2xl font-extrabold text-slate-900 mb-6">เลือกพื้นที่ให้บริการตามภูมิภาค</h2>
      <div class="space-y-8">
        {sortedRegions.map((region) => (
          <div>
            <h3 class="text-lg font-bold text-slate-900 border-b border-slate-200 pb-2 mb-4">{region}</h3>
            <div class="flex flex-wrap gap-2">
              {locationsByRegion[region].map((loc) => (
                <a
                  href={`/รับซื้อโน๊ตบุ๊ค/${loc.data.slug}/`}
                  class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1.5 text-sm font-medium text-slate-800 shadow-sm hover:bg-emerald-50 hover:border-emerald-200 transition-colors"
                >
                  {loc.data.title}
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
      <p class="mt-6 text-xs text-slate-500">
        หมายเหตุ: ถ้าพื้นที่ของคุณไม่ได้อยู่ในรายการด้านบน หรือเป็นพื้นที่ย่อย สามารถส่งโลเคชันมาทาง LINE ได้ เราช่วยแนะนำทางเลือกที่เหมาะที่สุด
      </p>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-10">
    <div class="grid gap-4 lg:grid-cols-2">
      <div class="rounded-3xl border border-slate-200 bg-slate-50 p-6 shadow-sm">
        <h2 class="text-lg font-extrabold text-slate-900">ต้องส่งอะไรเพื่อให้ประเมินไว</h2>
        <ul class="mt-4 list-disc pl-5 text-sm leading-relaxed text-slate-600">
          <li>รูป 3–5 รูป: หน้าเครื่องเปิดจอ, คีย์บอร์ด, ใต้เครื่อง/สติ๊กเกอร์รุ่น, มุมเครื่อง, ที่ชาร์จ</li>
          <li>สเปก: CPU/RAM/SSD และ GPU ถ้ามี (หรือส่งรูป Task Manager)</li>
          <li>สภาพ/อาการ: ใช้งานปกติ / มีรอย / แบตเสื่อม / จอมีเส้น / เปิดไม่ติด</li>
          <li>โลเคชันหรือโซนคร่าว ๆ เพื่อแนะนำวิธีนัดรับ/ส่งเครื่อง</li>
        </ul>
      </div>
      
      <div class="rounded-3xl border border-slate-200 bg-slate-50 p-6 shadow-sm">
        <h2 class="text-lg font-extrabold text-slate-900">การส่งเครื่องทางขนส่ง (เช็กลิสต์สั้น ๆ)</h2>
        <ul class="mt-4 list-disc pl-5 text-sm leading-relaxed text-slate-700">
          <li>ถ่ายวิดีโอสภาพเครื่องก่อนแพ็ก (เห็นจอและตัวเครื่อง)</li>
          <li>กันกระแทกมุมเครื่องและฝาจอเป็นพิเศษ</li>
          <li>แยกที่ชาร์จใส่ซองกันกระแทก ไม่ให้กดทับเครื่อง</li>
          <li>ใช้ขนส่งที่มี tracking และเก็บเลขพัสดุไว้</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-10">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
      <h2 class="text-xl font-extrabold text-slate-900">นัดรับ/นัดเจอ vs ส่งขนส่ง (เลือกแบบไหนดี)</h2>
      <p class="mt-3 text-base leading-relaxed text-slate-600">
        วิธีรับเครื่องที่เหมาะสมขึ้นกับพื้นที่และความสะดวกของคุณ โดยทั่วไปมี 2 แนวทางหลัก คือ “นัดรับ/นัดเจอ” และ “ส่งเครื่องทางขนส่ง”
        ทั้งสองแบบสามารถเริ่มจากการส่งรูปเพื่อเช็คราคาเบื้องต้นได้เหมือนกัน
      </p>
      <div class="mt-4 grid gap-4 lg:grid-cols-2">
        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
          <h3 class="text-base font-bold text-slate-900">นัดรับ/นัดเจอ</h3>
          <ul class="mt-2 list-disc pl-5 text-sm leading-relaxed text-slate-700">
            <li>เหมาะกับพื้นที่ที่เดินทางสะดวก หรือมีจุดนัดที่ชัดเจน</li>
            <li>ข้อดีคือคุยรายละเอียดหน้างานได้ง่ายและตรวจสภาพได้อย่างรวดเร็ว</li>
            <li>ควรเลือกจุดนัดที่ปลอดภัยและมีคนเยอะ</li>
          </ul>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
          <h3 class="text-base font-bold text-slate-900">ส่งเครื่องทางขนส่ง</h3>
          <ul class="mt-2 list-disc pl-5 text-sm leading-relaxed text-slate-700">
            <li>เหมาะกับต่างจังหวัด หรือคนที่ไม่สะดวกนัดเจอ</li>
            <li>ข้อดีคือประหยัดเวลา แต่ต้องแพ็กให้แน่นและมีหลักฐาน</li>
            <li>ควรใช้ขนส่งที่มี tracking และเก็บเลขพัสดุไว้</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-10">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
      <h2 class="text-xl font-extrabold text-slate-900">พร้อมเริ่ม: แอดไลน์หรือโทรเพื่อระบุพื้นที่และส่งรูป</h2>
      <p class="mt-3 text-base leading-relaxed text-slate-700">
        แอดไลน์ <strong>{SITE.lineHandle}</strong> ส่งรูปเครื่องและโซนที่อยู่ หรือโทร <strong>{SITE.phone}</strong> หากอยากคุยก่อน จากนั้นเราจะช่วยแนะนำวิธีนัดหรือส่งที่เหมาะสมให้คุณเลือกต่อ อ่านแนวทางเตรียมข้อความเพิ่มเติมที่หน้า <a class="underline" href="/วิธีขายโน๊ตบุ๊ค/">วิธีขายโน๊ตบุ๊ค</a>
      </p>
    </div>
  </section>

  <RelatedLinks
    title="ลิงก์ที่เกี่ยวข้องกับการรับซื้อและการเช็คราคา"
    links={[
      { label: 'รับซื้อโน๊ตบุ๊ค', href: '/', description: 'เลือกทางลัดตามยี่ห้อและอาการ' },
      { label: 'รับซื้อโน๊ตบุ๊คมือสอง', href: '/รับซื้อโน๊ตบุ๊คมือสอง/', description: 'เหมาะกับเครื่องใช้งานได้และเครื่องเก่า' },
      { label: 'ขายโน๊ตบุ๊ค', href: '/ขายโน๊ตบุ๊ค/', description: 'เตรียมเครื่องและล้างข้อมูลก่อนส่งมอบ' },
      { label: 'บทความ', href: '/blog/', description: 'คู่มือดูสเปก จอแตก แบตเสื่อม และเปิดไม่ติด' },
    ]}
  />

  <div class="pb-16">
    {faqs.length ? <FAQ faqs={faqs} /> : null}
  </div>
</BaseLayout>
