---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';
import CTAButtons from '../../components/CTAButtons.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import { getCollection, render } from 'astro:content';
import { absoluteUrl, breadcrumbListSchema, faqPageSchema } from '../../lib/seo';
import { blogPostingSchema } from '../../lib/schema';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const toSlug = (p: any) => (p.data.slug ? p.data.slug : String(p.id).replace(/\.(md|mdx)$/i, ''));
  return posts.map((p) => ({ params: { slug: toSlug(p) }, props: { post: p } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const toSlug = (p: any) => (p.data.slug ? p.data.slug : String(p.id).replace(/\.(md|mdx)$/i, ''));
function normalizeCanonical(value: string) {
  const trimmed = value.trim();
  if (!trimmed) return '';
  if (trimmed.startsWith('http://') || trimmed.startsWith('https://')) return trimmed.endsWith('/') ? trimmed : `${trimmed}/`;
  const path = trimmed.startsWith('/') ? trimmed : `/${trimmed}`;
  return absoluteUrl(path.endsWith('/') ? path : `${path}/`);
}

const canonical = post.data.canonical ? normalizeCanonical(post.data.canonical) : absoluteUrl(`/blog/${toSlug(post)}/`);
const breadcrumbs = [
  { name: 'หน้าแรก', url: absoluteUrl('/') },
  { name: 'บทความ', url: absoluteUrl('/blog/') },
  { name: post.data.title, url: canonical },
];
const isoDate = (d: Date) => d.toISOString();
const schemas = [
  breadcrumbListSchema(breadcrumbs),
  ...(post.data.faqs?.length ? [faqPageSchema(post.data.faqs)] : []),
  blogPostingSchema({
    headline: post.data.title,
    description: post.data.description,
    url: canonical,
    datePublished: isoDate(post.data.date),
    dateModified: post.data.dateModified ? isoDate(post.data.dateModified) : undefined,
    image: post.data.featuredImage ? absoluteUrl(post.data.featuredImage) : undefined,
  }),
];
---

<BaseLayout
  title={`${post.data.title} | ร้านรับซื้อโน๊ตบุ๊ค.com`}
  description={post.data.description}
  canonical={canonical}
  ogImage={post.data.ogImage ? absoluteUrl(post.data.ogImage) : post.data.featuredImage ? absoluteUrl(post.data.featuredImage) : undefined}
  schemas={schemas}
>
  <Breadcrumbs items={breadcrumbs} />
  <article class="mx-auto w-full max-w-6xl px-4 pb-10 pt-10">
    <header class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
      <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
        {post.data.category} • {post.data.date.toLocaleDateString('th-TH')}
      </p>
      <h1 class="mt-3 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">{post.data.title}</h1>
      <p class="mt-4 text-base leading-relaxed text-slate-600">{post.data.description}</p>
      <div class="mt-6 flex flex-wrap gap-3">
        <CTAButtons primaryText={post.data.ctaText ?? 'แอดไลน์ @webuy ส่งรูปประเมินราคา'} secondaryText="โทร" />
      </div>
    </header>

    <div class="mt-8 rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8 lg:p-10">
      <div
        class:list={[
          'prose prose-slate max-w-none',
          'prose-headings:scroll-mt-28 prose-headings:font-extrabold prose-headings:tracking-tight prose-headings:text-slate-900',
          'prose-h2:text-xl prose-h2:mt-10 prose-h2:mb-4 prose-h3:text-lg prose-h3:mt-8 prose-h3:mb-3',
          'prose-p:text-base prose-p:leading-relaxed prose-p:text-slate-700 prose-p:my-4',
          'prose-li:my-1 prose-li:text-slate-700 prose-ul:my-4 prose-ol:my-4',
          'prose-strong:text-slate-900 prose-strong:font-semibold',
          'prose-a:font-semibold prose-a:text-emerald-700 prose-a:underline prose-a:underline-offset-4 hover:prose-a:text-emerald-800',
          'prose-hr:my-10 prose-hr:border-slate-200',
          'prose-blockquote:border-l-emerald-500 prose-blockquote:text-slate-600 prose-blockquote:not-italic',
          'prose-code:rounded prose-code:bg-slate-100 prose-code:px-1.5 prose-code:py-0.5 prose-code:text-sm prose-code:text-slate-800 prose-code:before:content-none prose-code:after:content-none',
          'prose-pre:rounded-2xl prose-pre:border prose-pre:border-slate-200 prose-pre:bg-slate-50',
        ]}
      >
        <Content />
      </div>
    </div>
  </article>

  {post.data.faqs?.length ? <FAQ title="คำถามท้ายบทความ" faqs={post.data.faqs} /> : null}
  {post.data.relatedLinks?.length ? <RelatedLinks title="อ่านต่อ/หน้าที่เกี่ยวข้อง" links={post.data.relatedLinks} /> : null}

  <section class="mx-auto w-full max-w-6xl px-4 py-14">
    <div class="rounded-3xl border border-slate-200 bg-slate-50 p-6 shadow-sm sm:p-10">
      <h2 class="text-2xl font-bold tracking-tight text-slate-900">อยากขายโน๊ตบุ๊ควันนี้?</h2>
      <p class="mt-3 text-sm leading-relaxed text-slate-600">
        ไปที่หน้า <a class="underline" href="/">รับซื้อโน๊ตบุ๊ค</a> หรือส่งรูปประเมินผ่าน LINE ได้เลย
      </p>
      <div class="mt-6">
        <CTAButtons />
      </div>
    </div>
  </section>
</BaseLayout>

