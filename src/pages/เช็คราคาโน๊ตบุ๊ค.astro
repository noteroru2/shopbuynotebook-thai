---
import ServicePageShell from '../components/ServicePageShell.astro';

const title = 'เช็คราคาโน๊ตบุ๊ค ประเมินราคาฟรี แจ้งราคาก่อนขาย | ร้านรับซื้อโน๊ตบุ๊ค.com';
const description =
  'บริการเช็คราคาโน๊ตบุ๊คและประเมินราคาโน๊ตบุ๊คฟรีผ่าน LINE ส่งรูปและสเปกเพื่อรับราคาเบื้องต้น เทียบราคาตลาด แจ้งราคาก่อนตัดสินใจขาย';

const faqs = [
  {
    question: 'เช็คราคาโน๊ตบุ๊คฟรีไหม?',
    answer: 'ฟรีครับ ส่งรูป รุ่น สเปก และสภาพมาทาง LINE เราประเมินเบื้องต้นให้ก่อนตัดสินใจขาย',
  },
  {
    question: 'ใช้เวลานานแค่ไหนในการเช็คราคา?',
    answer:
      'โดยทั่วไปตอบกลับภายในเวลาทำการ เมื่อได้รูปและสเปกครบ หากข้อมูลไม่ครบอาจถามเพิ่มเติมก่อนให้ราคา',
  },
  {
    question: 'ราคาที่เช็คผ่าน LINE ตรงกับหน้างานไหม?',
    answer:
      'ราคาเบื้องต้นอิงจากข้อมูลที่ส่งมา หากสภาพจริงตรงตามที่แจ้ง ราคาหน้างานจะใกล้เคียง หากต่างจากที่แจ้งจะอธิบายเหตุผลก่อนตกลง',
  },
];
---

<ServicePageShell
  title={title}
  description={description}
  canonicalPath="/เช็คราคาโน๊ตบุ๊ค/"
  breadcrumbLabel="เช็คราคาโน๊ตบุ๊ค"
  serviceName="เช็คราคาโน๊ตบุ๊ค"
  h1="เช็คราคาโน๊ตบุ๊ค"
  h1Accent="ประเมินราคาฟรี แจ้งราคาก่อนตัดสินใจขาย"
  heroSubtitle="ส่งรูป รุ่น สเปก และสภาพเครื่องมาทาง LINE เพื่อรับราคาเบื้องต้นโดยไม่มีค่าใช้จ่าย"
  accentClass="text-teal-400"
  gradientFrom="from-teal-900/60"
  proseLinkClass="prose-a:text-teal-600 hover:prose-a:text-teal-500"
  faqs={faqs}
>
  <p class="lead">
    หน้านี้เน้นคำว่า <strong>เช็คราคาโน๊ตบุ๊ค</strong> และ <strong>ประเมินราคาโน๊ตบุ๊ค</strong>
    สำหรับผู้ที่อยากรู้ราคาก่อนขาย หากพร้อมขายแล้วดูบริการหลักที่หน้า
    <a href="/">รับซื้อโน๊ตบุ๊ค</a>
  </p>

  <h2>ข้อมูลที่ต้องส่งเพื่อเช็คราคา</h2>
  <ul>
    <li><strong>รุ่นและยี่ห้อ</strong> — เช่น ASUS Vivobook, Dell Inspiron, MacBook Air M1</li>
    <li><strong>สเปก</strong> — CPU, RAM, SSD/HDD, การ์ดจอ (แคปหน้าจอสเปกจะช่วยได้มาก)</li>
    <li><strong>รูปเครื่อง</strong> — ด้านบน ด้านล่าง หน้าจอ คีย์บอร์ด และรอยตำหนิ (ถ้ามี)</li>
    <li><strong>อาการเสีย</strong> — จอแตก แบตเสื่อม เปิดไม่ติด คีย์บอร์ดเสีย ไม่มีที่ชาร์จ</li>
    <li><strong>อุปกรณ์ที่มี</strong> — ที่ชาร์จ กล่อง ใบเสร็จ</li>
  </ul>

  <h2>วิธีที่เราประเมินราคา</h2>
  <p>
    เราเทียบราคาตลาดมือสองจากรุ่น สเปก สภาพ และอุปกรณ์ที่มี ไม่ใช้การคาดเดาแบบลอย ๆ
    ราคาเบื้องต้นที่แจ้งผ่าน LINE เป็นแนวทางก่อนตัดสินใจ หากสภาพจริงตรงตามที่ส่งมา ราคาหน้างานจะใกล้เคียง
  </p>

  <h2>ปัจจัยที่ทำให้ราคาเปลี่ยน</h2>
  <h3>สเปกฮาร์ดแวร์</h3>
  <p>CPU รุ่นใหม่ RAM มาก SSD ความจุสูง และการ์ดจอแยก มักช่วยดึงราคาได้ดีกว่าเครื่องสเปกต่ำ</p>
  <h3>สภาพและอาการ</h3>
  <ul>
    <li>ไม่มีที่ชาร์จ — ราคาลดตามความครบของอุปกรณ์</li>
    <li>จอแตก/เป็นเส้น — ราคาลดตามความเสียหาย</li>
    <li>แบตเสื่อม — ราคาลดตามอาการ แบตบวมอาจลดมากกว่าแบตหมดเร็ว</li>
    <li>เปิดไม่ติด — ประเมินตามรุ่นและว่ามีข้อมูลสเปกครบหรือไม่</li>
  </ul>

  <h2>หลังได้ราคาเบื้องต้นแล้วทำอย่างไร</h2>
  <ol>
    <li>ยืนยันราคาและเงื่อนไขกับทีมงาน</li>
    <li>สำรองและล้างข้อมูลส่วนตัวก่อนส่งมอบ (หรือขอคำแนะนำได้)</li>
    <li>นัดรับเครื่องหรือส่งขนส่งตามพื้นที่</li>
    <li>ตรวจสภาพตามที่แจ้ง จ่ายเงินเมื่อตกลงราคา</li>
  </ol>

  <p>
    ต้องการขั้นตอนละเอียดขึ้น อ่านหน้า <a href="/ขายโน๊ตบุ๊ค/">ขายโน๊ตบุ๊ค</a> หรือ
    <a href="/วิธีขายโน๊ตบุ๊ค/">วิธีขายโน๊ตบุ๊ค</a>
  </p>
</ServicePageShell>
