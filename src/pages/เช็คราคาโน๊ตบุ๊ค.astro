---
import ServiceLayout from '../layouts/ServiceLayout.astro';
import PriceFactors from '../components/PriceFactors.astro';
import FAQ from '../components/FAQ.astro';
import CTAButtons from '../components/CTAButtons.astro';
import { absoluteUrl } from '../lib/seo';

const title = 'เช็คราคาโน๊ตบุ๊ค ก่อนขาย ประเมินฟรี | ร้านรับซื้อโน๊ตบุ๊ค.com';
const description =
  'เช็คราคาโน๊ตบุ๊คก่อนขายแบบเร็ว ๆ แค่ส่งรูป + สเปก + สภาพ เราประเมินฟรี ตอบไว ช่วยให้ตัดสินใจขายได้ง่ายขึ้น ทั้ง Windows และ MacBook';
const canonical = absoluteUrl('/เช็คราคาโน๊ตบุ๊ค/');

const breadcrumbs = [
  { name: 'หน้าแรก', url: absoluteUrl('/') },
  { name: 'เช็คราคาโน๊ตบุ๊ค', url: canonical },
];

const faqs = [
  {
    question: 'ต้องส่งข้อมูลอะไรบ้างเพื่อเช็คราคาให้แม่น',
    answer:
      'อย่างน้อย 3 อย่าง: รูปตัวเครื่อง, รุ่น/สเปก (CPU/RAM/SSD), และสภาพ/อาการ. ถ้ามีรูปแบต/จำนวนรอบชาร์จ (MacBook) หรือสุขภาพแบตจะช่วยได้มาก',
  },
  {
    question: 'เช็คราคาโน๊ตบุ๊คเสียได้ไหม',
    answer:
      'ได้ครับ ถ้าเครื่องมีอาการ เช่น เปิดไม่ติด จอแตก แบตเสื่อม หรือคีย์บอร์ดเสีย แนะนำส่งวิดีโอสั้น ๆ ให้เห็นอาการร่วมกับรูปสเปก เพื่อให้ประเมินใกล้เคียงขึ้น',
  },
  {
    question: 'ประเมินทางรูปจะต่างจากราคาจริงไหม',
    answer:
      'ราคาจริงอาจปรับตามสภาพเมื่อเห็นเครื่องจริง (เช่น รอยที่ไม่เห็นในรูป หรืออาการที่พบเพิ่ม). เราพยายามประเมินให้ใกล้เคียงที่สุดโดยขอข้อมูลให้ครบตั้งแต่ต้น',
  },
  {
    question: 'ส่งรูปกี่รูปถึงจะพอ',
    answer:
      'แนะนำ 3–5 รูป: หน้าเครื่องเปิดจอ, คีย์บอร์ด, ฝาหลัง/สติ๊กเกอร์รุ่น และอุปกรณ์ที่มี (ที่ชาร์จ/กล่อง). ถ้ามีตำหนิให้ถ่ายเพิ่มอีก 1 รูป',
  },
  {
    question: 'เช็คราคาแล้วไม่ขายได้ไหม',
    answer:
      'ได้ครับ การประเมินเป็นบริการฟรี เพื่อให้คุณตัดสินใจได้ง่ายขึ้น ไม่มีค่าใช้จ่ายและไม่มีข้อผูกมัด',
  },
  {
    question: 'ไม่มีที่ชาร์จหรือไม่มีกล่อง ประเมินได้ไหม',
    answer:
      'ประเมินได้ครับ แค่แจ้งให้ครบเพื่อประเมินตรงขึ้น อุปกรณ์ครบช่วยให้ประเมินแม่นขึ้น แต่ไม่ใช่เงื่อนไขบังคับ',
  },
  {
    question: 'ควรล้างข้อมูลก่อนนัดรับ/ส่งเครื่องไหม',
    answer:
      'แนะนำครับ เพื่อความปลอดภัยของข้อมูลส่วนตัว หากไม่แน่ใจขั้นตอน เราช่วยแนะนำการสำรองและล้างข้อมูลตามระบบได้',
  },
];
---

<ServiceLayout
  title={title}
  description={description}
  canonical={canonical}
  breadcrumbs={breadcrumbs}
  serviceName="เช็คราคาโน๊ตบุ๊ค"
  faqs={faqs}
>
  <section class="mx-auto w-full max-w-6xl px-4 pt-10">
    <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">เช็คราคาโน๊ตบุ๊คก่อนขาย ประเมินฟรี</h1>
    <p class="mt-4 text-base leading-relaxed text-slate-600">
      การเช็คราคาก่อนขายช่วยให้คุณ “ไม่เสียเวลา” และ “ไม่พลาดราคา” โดยเฉพาะช่วงที่ตลาดมือสองมีการเปลี่ยนแปลงเร็ว.
      วิธีที่ง่ายที่สุดคือส่งรูป + สเปก + สภาพ เพื่อให้เราประเมินเบื้องต้นให้คุณฟรี. คุณจะเห็นช่วงราคาที่เหมาะสม
      และสามารถตัดสินใจได้ว่าจะขายทันทีหรือรอจังหวะที่เหมาะกว่า
    </p>
    <p class="mt-4 text-base leading-relaxed text-slate-600">
      สิ่งที่มีผลต่อราคา ได้แก่ ยี่ห้อ/รุ่น ปีที่ซื้อ สเปกจริง (RAM/SSD) สภาพภายนอกและหน้าจอ สุขภาพแบตเตอรี่
      รวมถึงอุปกรณ์ที่มี เช่น ที่ชาร์จ กล่อง และใบเสร็จ (ถ้ามี). ถ้าเครื่องมีอาการเสีย แนะนำแจ้งตรง ๆ เพื่อประเมินได้ตรง
      และช่วยประหยัดเวลาทั้งสองฝ่าย
    </p>
    <p class="mt-4 text-base leading-relaxed text-slate-600">
      เคล็ดลับให้เช็คราคาไวคือ “ส่งข้อมูลให้ครบตั้งแต่แรก”: ระบุรุ่นให้ชัด (เช่น VivoBook/ThinkPad/MacBook Air M1),
      บอกความจุ RAM/SSD และถ้ามีการ์ดจอแยกให้ระบุรุ่น GPU ด้วย รวมถึงแจ้งสภาพแบตและอุปกรณ์ที่มี ข้อมูลเหล่านี้ช่วยให้ประเมินตรงขึ้น
      และลดการถามซ้ำหลายรอบ
    </p>

    <div class="mt-6 rounded-3xl border border-slate-200 bg-slate-50 p-6">
      <h2 class="text-lg font-bold text-slate-900">เริ่มเช็คราคาเลย</h2>
      <p class="mt-2 text-sm text-slate-600">
        ส่งข้อมูลผ่าน LINE จะไวที่สุด
      </p>
      <div class="mt-4">
        <CTAButtons />
      </div>
      <p class="mt-3 text-xs text-slate-500">
        ลิงก์ที่เกี่ยวข้อง: <a class="underline" href="/ตีราคาโน๊ตบุ๊ค/">ตีราคาโน๊ตบุ๊ค</a> •{' '}
        <a class="underline" href="/รับซื้อโน๊ตบุ๊คมือสอง/">รับซื้อโน๊ตบุ๊คมือสอง</a> • <a class="underline" href="/">หน้าแรก</a>
      </p>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-12">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
      <h2 class="text-xl font-extrabold text-slate-900">คำตอบสั้น (AEO): เช็คราคาโน๊ตบุ๊คต้องส่งอะไรบ้าง</h2>
      <p class="mt-3 text-base leading-relaxed text-slate-600">
        ถ้าคุณอยากเช็คราคาโน๊ตบุ๊คให้ไว ให้ส่ง 3 อย่างนี้ก่อน: <strong>รูปเครื่อง</strong>, <strong>รุ่น/สเปก</strong>, และ <strong>สภาพ/อาการ</strong>.
        รูปเครื่องช่วยให้เห็นสภาพจริง รุ่น/สเปกช่วยให้เทียบตลาดได้ และสภาพ/อาการช่วยให้ประเมินตามความเสี่ยงได้ใกล้เคียงขึ้น
      </p>
      <p class="mt-3 text-base leading-relaxed text-slate-600">
        แนะนำรูปอย่างน้อย 3–5 รูป: หน้าเครื่องเปิดจอ, คีย์บอร์ด, ฝาหลัง/สติ๊กเกอร์รุ่น, มุมเครื่องที่มีรอย และรูปที่ชาร์จ
        ถ้าเครื่องมีอาการ เช่น เปิดไม่ติด หรือจอแตก ให้ส่งวิดีโอสั้น ๆ เพิ่ม จะช่วยมาก
      </p>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-12">
    <div class="grid gap-4 lg:grid-cols-3">
      <div class="rounded-3xl border border-slate-200 bg-slate-50 p-6">
        <h2 class="text-lg font-bold text-slate-900">เช็คราคา vs ตีราคา ต่างกันไหม</h2>
        <p class="mt-2 text-sm leading-relaxed text-slate-700">
          “เช็คราคา” มักเป็นการดูช่วงราคาแบบเร็วจากข้อมูลเบื้องต้น ส่วน “ตีราคา” จะละเอียดขึ้นและอธิบายปัจจัยตามสภาพจริงมากขึ้น
        </p>
        <p class="mt-3 text-sm leading-relaxed text-slate-700">
          ถ้าคุณอยากอ่านหน้าเน้นปัจจัยราคา ดูที่
          <a class="underline" href="/ตีราคาโน๊ตบุ๊ค/">ตีราคาโน๊ตบุ๊ค</a>
        </p>
      </div>
      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm lg:col-span-2">
        <h2 class="text-lg font-bold text-slate-900">เช็กลิสต์ข้อมูลที่ช่วยให้ประเมินใกล้เคียงขึ้น</h2>
        <ul class="mt-3 list-disc pl-5 text-sm leading-relaxed text-slate-700">
          <li><strong>รุ่น</strong>: หรือรูปสติ๊กเกอร์ใต้เครื่อง</li>
          <li><strong>สเปก</strong>: CPU / RAM / SSD และ GPU ถ้ามี</li>
          <li><strong>สภาพ</strong>: ใช้งานปกติ / มีรอย / จอมีเส้น / แบตเสื่อม / เปิดไม่ติด</li>
          <li><strong>อุปกรณ์</strong>: ที่ชาร์จมีไหม มีกล่องไหม</li>
          <li><strong>พื้นที่</strong>: อยู่โซนไหน เพื่อแนะนำวิธีนัดรับ/ส่งเครื่อง</li>
        </ul>
        <p class="mt-3 text-sm leading-relaxed text-slate-700">
          ถ้ายังไม่แน่ใจสเปก อ่านต่อได้ที่
          <a class="underline" href="/blog/วิธีดูสเปก-cpu-ram-ssd-ของโน๊ตบุ๊ค/">วิธีดูสเปก CPU RAM SSD</a>
        </p>
      </div>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-12">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
      <h2 class="text-xl font-extrabold text-slate-900">ตัวอย่างข้อความที่ส่งเช็คราคาได้เลย (คัดลอกได้)</h2>
      <p class="mt-3 text-base leading-relaxed text-slate-600">
        ตัวอย่าง 1: เครื่องใช้งานปกติ
      </p>
      <div class="mt-3 rounded-2xl border border-slate-200 bg-slate-50 p-4 text-sm leading-relaxed text-slate-800">
        ขอเช็คราคาโน๊ตบุ๊คครับ
        <br />รุ่น ______
        <br />CPU ______ / RAM ___GB / SSD ___GB
        <br />สภาพใช้งานปกติ มีที่ชาร์จ
        <br />อยู่โซน ______
      </div>
      <p class="mt-4 text-base leading-relaxed text-slate-600">
        ตัวอย่าง 2: เครื่องมีอาการ
      </p>
      <div class="mt-3 rounded-2xl border border-slate-200 bg-slate-50 p-4 text-sm leading-relaxed text-slate-800">
        ขอประเมินราคาโน๊ตบุ๊คครับ
        <br />รุ่น ______ (แนบรูปใต้เครื่อง)
        <br />อาการ: ______ (เปิดไม่ติด/จอแตก/แบตเสื่อม)
        <br />มีที่ชาร์จครับ (แนบรูป)
        <br />อยู่โซน ______
      </div>
      <p class="mt-4 text-sm leading-relaxed text-slate-700">
        ถ้าเครื่องเปิดไม่ติดหรือจอแตก แนะนำส่งวิดีโออาการ 5–10 วินาทีด้วย จะช่วยให้ประเมินไวขึ้นมาก
      </p>
      <div class="mt-5">
        <CTAButtons />
      </div>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-12">
    <div class="grid gap-4 lg:grid-cols-3">
      <div class="rounded-3xl border border-slate-200 bg-slate-50 p-6">
        <h2 class="text-lg font-bold text-slate-900">เช็คราคาให้ไว: รูปแบบไหนดีที่สุด</h2>
        <ul class="mt-3 list-disc pl-5 text-sm leading-relaxed text-slate-700">
          <li>รูปหน้าเครื่องเปิดจอ (เห็นจอชัด)</li>
          <li>รูปคีย์บอร์ด/ทัชแพด (เห็นรอยใช้งาน)</li>
          <li>รูปใต้เครื่อง/สติ๊กเกอร์รุ่น (ยืนยันรุ่น)</li>
          <li>รูปมุมเครื่องและพอร์ต (รอยบุบ/พอร์ตหลวม)</li>
          <li>รูปที่ชาร์จ (สำคัญมาก)</li>
        </ul>
      </div>
      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm lg:col-span-2">
        <h2 class="text-lg font-bold text-slate-900">เช็คสเปกไม่เป็น? ส่งรูปให้ร้านอ่านให้ได้</h2>
        <p class="mt-2 text-sm leading-relaxed text-slate-700">
          ถ้าคุณไม่ถนัดพิมพ์สเปก ให้ส่งรูปหน้า Task Manager → Performance (CPU, Memory, Disk, GPU) หรือรูปหน้า Settings → About
          ก็เพียงพอให้ประเมินเบื้องต้นได้แล้ว
        </p>
        <p class="mt-3 text-sm leading-relaxed text-slate-700">
          คู่มือแบบละเอียด:
          <a class="underline" href="/blog/วิธีดูสเปก-cpu-ram-ssd-ของโน๊ตบุ๊ค/">วิธีดูสเปก CPU RAM SSD</a> •{' '}
          <a class="underline" href="/blog/วิธีดูรุ่นโน๊ตบุ๊ค-windows-ก่อนส่งประเมินราคา/">วิธีดูรุ่นโน๊ตบุ๊ค Windows</a>
        </p>
        <p class="mt-3 text-sm leading-relaxed text-slate-700">
          ถ้าเป็น MacBook ให้ส่งรูป About This Mac และถ้ามี Battery Health/Cycle Count ส่งเพิ่มได้ จะช่วยให้ประเมินใกล้เคียงขึ้น
        </p>
      </div>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-12">
    <div class="rounded-3xl border border-slate-200 bg-slate-50 p-6 shadow-sm sm:p-8">
      <h2 class="text-xl font-extrabold text-slate-900">เครื่องมีอาการเสีย จะเช็คราคาได้ไหม</h2>
      <p class="mt-3 text-base leading-relaxed text-slate-700">
        เช็คราคาได้ครับ แต่ควรส่งข้อมูลเพิ่มเพื่อให้ประเมินใกล้เคียงขึ้น เช่น วิดีโออาการ 5–10 วินาที และรูปตำหนิให้ชัด
      </p>
      <div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        <a class="rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-900 hover:bg-emerald-50 hover:border-emerald-200" href="/blog/โน๊ตบุ๊คเปิดไม่ติดขายได้ไหม/">เปิดไม่ติด</a>
        <a class="rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-900 hover:bg-emerald-50 hover:border-emerald-200" href="/blog/โน๊ตบุ๊คจอแตกยังมีราคาไหม/">จอแตก</a>
        <a class="rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-900 hover:bg-emerald-50 hover:border-emerald-200" href="/blog/โน๊ตบุ๊คแบตเสื่อมขายได้ไหม/">แบตเสื่อม</a>
        <a class="rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-900 hover:bg-emerald-50 hover:border-emerald-200" href="/blog/โน๊ตบุ๊คเสียขายได้ไหม/">เครื่องเสีย (รวม)</a>
      </div>
      <p class="mt-3 text-sm leading-relaxed text-slate-700">
        ถ้าเป็นเครื่องเกมมิ่ง แนะนำส่งรุ่น GPU และรูปที่ชาร์จด้วย
        <a class="underline" href="/blog/gaming-notebook-มือสองขายได้ราคาดีกว่าไหม/">ดูคู่มือเกมมิ่ง</a>
      </p>
      <div class="mt-5">
        <CTAButtons />
      </div>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-12">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
      <h2 class="text-xl font-extrabold text-slate-900">ความปลอดภัยข้อมูลก่อนส่งมอบ</h2>
      <p class="mt-3 text-base leading-relaxed text-slate-600">
        คุณสามารถเช็คราคาได้ก่อนโดยไม่ต้องล้างเครื่องทันที แต่ก่อนส่งมอบจริง แนะนำสำรองและล้างข้อมูลเพื่อความปลอดภัยเสมอ
      </p>
      <p class="mt-3 text-sm leading-relaxed text-slate-700">
        อ่านต่อ: <a class="underline" href="/blog/ก่อนขายโน๊ตบุ๊คต้องล้างข้อมูลอย่างไร/">ก่อนขายโน๊ตบุ๊คต้องล้างข้อมูลอย่างไร</a>
      </p>
    </div>
