---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAButtons from '../components/CTAButtons.astro';
import SeoCTA from '../components/SeoCTA.astro';
import RelatedLinks from '../components/RelatedLinks.astro';
import { absoluteUrl } from '../lib/seo';

const title = 'ไม่พบหน้าที่ต้องการ | ร้านรับซื้อโน๊ตบุ๊ค.com';
const description = 'ขออภัย ไม่พบหน้าที่คุณต้องการ ลองกลับไปหน้าแรกหรือเลือกบริการที่เกี่ยวข้อง';
const canonical = absoluteUrl('/404.html');
---

<BaseLayout title={title} description={description} canonical={canonical} noindex={true}>
  <section class="mx-auto w-full max-w-6xl px-4 pt-12">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-10">
      <h1 class="text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">ไม่พบหน้าที่ต้องการ</h1>
      <p class="mt-4 text-base leading-relaxed text-slate-600">
        ขอโทษครับ ลิงก์นี้อาจถูกย้ายหรือพิมพ์ผิด คุณสามารถกลับไปหน้าแรกหรือเลือกหน้าที่เกี่ยวข้องด้านล่างได้
      </p>
      <div class="mt-6 flex flex-col gap-4">
        <a class="inline-flex items-center justify-center rounded-2xl bg-slate-900 px-5 py-3 text-sm font-extrabold text-white hover:bg-slate-800 sm:inline-flex sm:w-fit" href="/">
          กลับหน้าแรก
        </a>
        <CTAButtons primaryText="แอดไลน์ @webuy ส่งรูปประเมินราคา" secondaryText="โทร" />
      </div>
    </div>
  </section>

  <RelatedLinks
    links={[
      { label: 'รับซื้อโน๊ตบุ๊คมือสอง', href: '/รับซื้อโน๊ตบุ๊คมือสอง/', description: 'บริการหลักสำหรับเครื่องใช้งานปกติ/เครื่องเก่า' },
      { label: 'เช็คราคาโน๊ตบุ๊ค', href: '/เช็คราคาโน๊ตบุ๊ค/', description: 'ส่งรูป + สเปก เพื่อประเมินราคาเบื้องต้นฟรี' },
      { label: 'รับซื้อ Notebook', href: '/รับซื้อ-notebook/', description: 'Windows Notebook / MacBook / Gaming Notebook' },
      { label: 'บทความ', href: '/blog/', description: 'คู่มือเตรียมเครื่องก่อนขาย' },
    ]}
  />

  <SeoCTA />
</BaseLayout>

